---
// ── ANALIZA ──────────────────────────────────────────────────
// useNavigate → <a href="/ks-guz">
// onMouseEnter/Leave → CSS :hover
// Komponent statyczny — zero JS
// Tło jasne (#EBE1CA), czcionki ciemne, zdjęcie w ciemnej ramce
// ─────────────────────────────────────────────────────────────

// Funkcja do optymalizacji obrazów Cloudinary
function optimizeCloudinaryImage(url, width, height, options = {}) {
  if (!url?.includes('cloudinary.com')) return url;
  
  const {
    crop = 'fill',
    quality = 'auto',
    format = 'auto',
    dpr = 'auto'
  } = options;
  
  const transformations = [
    `c_${crop}`,
    `w_${width}`,
    `h_${height}`,
    `q_${quality}`,
    `f_${format}`,
    `dpr_${dpr}`
  ].join(',');
  
  const [base, path] = url.split('/upload/');
  return `${base}/upload/${transformations}/${path}`;
}

// Zoptymalizowany URL obrazu dla teasera (300x400)
const teaserImageUrl = optimizeCloudinaryImage(
  "https://res.cloudinary.com/dmb0xngy0/image/upload/q_auto/f_auto/v1776448708/TG_vunjd2.png",
  300,   // szerokość kontenera
  400,   // wysokość dla proporcji 3:4
  { quality: 'auto:best' }  // Wyższa jakość dla portretu
);
---

<section
  id="ks-guz-teaser"
  style="background:#EBE1CA; padding:clamp(3.5rem,9vw,7rem) clamp(1rem,4vw,2rem); position:relative; overflow:hidden;"
>
  <!-- Subtle glow -->
  <div style="position:absolute; inset:0; pointer-events:none; background:radial-gradient(ellipse at 25% 50%,rgba(201,168,76,0.06) 0%,transparent 65%);"></div>

  <div style="max-width:1100px; margin:0 auto; position:relative;">
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(min(100%,300px),1fr)); gap:clamp(2.5rem,6vw,5rem); align-items:center;">

      <!-- Text column — dark text on light bg -->
      <div>
        <p class="reveal section-label" style="color:#6B5B43; margin-bottom:clamp(0.75rem,2vw,1.25rem);">
          Fundament duchowy projektu
        </p>
        <h2 class="reveal section-title" style="color:#1A1209; margin-bottom:clamp(1.25rem,3vw,1.75rem); font-size:clamp(2rem,6vw,3.25rem);">
          Ks. prof.<br />Tadeusz Guz
        </h2>
        <blockquote class="reveal" style="font-family:'Playfair Display',serif; font-style:italic; font-size:clamp(1.0625rem,2.8vw,1.3rem); line-height:1.88; color:#4A3A28; border-left:2px solid rgba(201,168,76,0.55); padding-left:clamp(0.875rem,2.5vw,1.25rem); margin:0 0 clamp(1.5rem,3vw,2rem);">
          „Prawdziwa kultura rodzi się tam, gdzie człowiek odważy się zapytać
          o Boga, o dobro i o piękno."
        </blockquote>
        <p class="reveal body-text" style="color:#6B5B43; margin-bottom:clamp(1.75rem,4vw,2.5rem); font-size:clamp(1.0625rem,2.5vw,1.125rem);">
          Filozof, teolog i kapłan — twórca intelektualnej wizji projektu Ateny&nbsp;Roztocza.
          Ponad 20 lat wykładów łączących dziedzictwo Aten, Jerozolimy i Rzymu.
        </p>
        <a href="/ks-guz" class="reveal ks-guz-cta">
          Poznaj Księdza Profesora →
        </a>
      </div>

      <!-- Zdjęcie w ramce ozdobnej -->
      <div class="reveal" style="display:flex; justify-content:center;">
        <div style="width:min(300px,100%); aspect-ratio:3/4; position:relative; overflow:hidden;">
          <!-- Zdjęcie zoptymalizowane przez Cloudinary -->
          <img
            src={teaserImageUrl}
            alt="Ks. prof. Tadeusz Guz"
            width="300"
            height="400"
            style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block;"
            loading="lazy"
          />
          <!-- Ramka ozdobna SVG -->
          <svg viewBox="0 0 300 400" style="position:absolute; inset:0; width:100%; height:100%; opacity:0.35; pointer-events:none; z-index:1;">
            <rect x="14" y="14" width="272" height="372" fill="none" stroke="#C9A84C" stroke-width="1" />
            <rect x="24" y="24" width="252" height="352" fill="none" stroke="#C9A84C" stroke-width="0.5" />
            <line x1="14" y1="14" x2="24" y2="24" stroke="#C9A84C" stroke-width="0.5" />
            <line x1="286" y1="14" x2="276" y2="24" stroke="#C9A84C" stroke-width="0.5" />
            <line x1="14" y1="386" x2="24" y2="376" stroke="#C9A84C" stroke-width="0.5" />
            <line x1="286" y1="386" x2="276" y2="376" stroke="#C9A84C" stroke-width="0.5" />
          </svg>
          <!-- Podpis pod zdjęciem -->
          <div style="position:absolute; bottom:0; left:0; right:0; z-index:2; background:linear-gradient(to top,rgba(26,18,9,0.85) 0%,rgba(26,18,9,0.4) 60%,transparent 100%); padding:2.5rem 1.25rem 1rem; text-align:center;">
            <div style="font-family:'Playfair Display',serif; font-size:clamp(0.875rem,2.5vw,1.1rem); color:rgba(232,201,122,0.65); margin-bottom:0.25rem; letter-spacing:0.04em;">
              Ks. prof. dr hab.
            </div>
            <div style="font-family:'Playfair Display',serif; font-size:clamp(1.3rem,4vw,1.85rem); font-weight:300; color:#E8C97A; letter-spacing:0.05em; margin-bottom:clamp(0.6rem,1.5vw,0.9rem); line-height:1.2;">
              Tadeusz Guz
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .ks-guz-cta {
    font-family: 'Inter', serif;
    font-size: clamp(0.9rem, 2vw, 0.9375rem);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #1A1209;
    background: linear-gradient(135deg, #C9A84C, #E8C97A);
    padding: clamp(0.8rem, 2.5vw, 0.95rem) clamp(1.75rem, 4vw, 2.5rem);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    font-weight: 600;
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }
  .ks-guz-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 26px rgba(201, 168, 76, 0.35);
  }
</style>
