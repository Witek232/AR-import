---
// ── ANALIZA ──────────────────────────────────────────────────
// useRef videoRef      → id="hero-video" + querySelector
// useState videoLoaded → JS classList
// useState videoError  → JS onerror handler
// useNavigate          → <a href="">
// scrollToFilary       → scrollIntoView w <script>
// ─────────────────────────────────────────────────────────────
---

<section
  id="hero"
  style="position:relative; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; overflow:hidden;"
>
  <!-- Gradient background -->
  <div style="position:absolute; inset:0; z-index:0; background:linear-gradient(160deg,#0D0A05 0%,#1A1209 40%,#2C1A08 70%,#0f0804 100%);"></div>

  <!-- Glow orbs -->
  <div style="position:absolute; inset:0; z-index:1; overflow:hidden; pointer-events:none;">
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-orb hero-orb-3"></div>
  </div>

  <!-- Video background -->
  <video
    id="hero-video"
    autoplay muted loop playsinline preload="metadata"
    style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; z-index:2; opacity:0; transition:opacity 2s ease; filter:sepia(0%) brightness(1.0) contrast(1.1); pointer-events:none;"
  >
    <source src="https://res.cloudinary.com/dmb0xngy0/video/upload/v1774209400/0322_gdjvnc.mp4" type="video/mp4" />
  </video>

  <!-- Gold particles -->
  <div style="position:absolute; inset:0; z-index:3; pointer-events:none; overflow:hidden;">
    {Array.from({ length: 18 }, (_, i) => (
      <div
        class="gold-particle"
        style={`left:${5 + i * 5.5}%; animation-delay:${i * 0.7}s; animation-duration:${6 + (i % 5) * 1.5}s; width:${i % 3 === 0 ? '3px' : i % 3 === 1 ? '2px' : '1.5px'}; height:${i % 3 === 0 ? '3px' : i % 3 === 1 ? '2px' : '1.5px'}; opacity:${0.35 + (i % 4) * 0.12};`}
      ></div>
    ))}
  </div>

  <!-- SVG Greek Columns -->
  <svg viewBox="0 0 1440 900" style="position:absolute; inset:0; width:100%; height:100%; z-index:4; opacity:0.09; pointer-events:none;" preserveAspectRatio="xMidYMid slice">
    {[70, 125, 180].map((x, i) => (
      <g stroke="#C9A84C" stroke-width="1" fill="none">
        <rect x={x} y={220} width={28} height={560} rx="2" />
        <rect x={x - 7} y={215} width={42} height={16} rx="1" />
        <rect x={x - 4} y={200} width={36} height={15} rx="1" />
        <rect x={x - 7} y={776} width={42} height={14} rx="1" />
        <rect x={x - 11} y={790} width={50} height={11} rx="1" />
        {Array.from({ length: 5 }, (_, j) => (
          <line x1={x + 5 + j * 4} y1={231} x2={x + 5 + j * 4} y2={776} opacity="0.35" />
        ))}
      </g>
    ))}
    {[1240, 1295, 1350].map((x, i) => (
      <g stroke="#C9A84C" stroke-width="1" fill="none">
        <rect x={x} y={220} width={28} height={560} rx="2" />
        <rect x={x - 7} y={215} width={42} height={16} rx="1" />
        <rect x={x - 4} y={200} width={36} height={15} rx="1" />
        <rect x={x - 7} y={776} width={42} height={14} rx="1" />
        <rect x={x - 11} y={790} width={50} height={11} rx="1" />
        {Array.from({ length: 5 }, (_, j) => (
          <line x1={x + 5 + j * 4} y1={231} x2={x + 5 + j * 4} y2={776} opacity="0.35" />
        ))}
      </g>
    ))}
    <rect x="55"  y="184" width="560" height="14" rx="1" stroke="#C9A84C" stroke-width="1" fill="none" />
    <rect x="825" y="184" width="560" height="14" rx="1" stroke="#C9A84C" stroke-width="1" fill="none" />
    {Array.from({ length: 18 }, (_, i) => (
      <rect x={63 + i * 28} y={189} width={13} height={7} stroke="#C9A84C" stroke-width="0.4" fill="none" opacity="0.7" />
    ))}
    {Array.from({ length: 18 }, (_, i) => (
      <rect x={833 + i * 28} y={189} width={13} height={7} stroke="#C9A84C" stroke-width="0.4" fill="none" opacity="0.7" />
    ))}
    {[[720,55],[390,95],[1060,75],[190,125],[1210,105],[610,38],[880,48],[145,48],[1310,65],[510,145]].map(([cx,cy]) => (
      <circle cx={cx} cy={cy} r="1.1" fill="#E8C97A" opacity="0.75" />
    ))}
  </svg>

  <!-- Vignette -->
  <div style="position:absolute; inset:0; z-index:5; background:radial-gradient(ellipse at center,transparent 25%,rgba(13,10,5,0.55) 100%); pointer-events:none;"></div>

  <!-- Bottom fade -->
  <div style="position:absolute; bottom:0; left:0; right:0; height:180px; z-index:6; background:linear-gradient(to bottom,transparent,rgba(13,10,5,0.8)); pointer-events:none;"></div>

  <!-- Main content -->
  <div style="position:relative; z-index:7; text-align:center; width:100%; max-width:960px; margin:0 auto; padding:clamp(5.5rem,14vw,8.5rem) clamp(1.25rem,5vw,3rem) clamp(5rem,11vw,7.5rem); display:flex; flex-direction:column; align-items:center;">

    <!-- Eyebrow -->
    <p style="font-family:'Crimson Pro',serif; font-size:clamp(0.68rem,2vw,0.8rem); letter-spacing:0.3em; text-transform:uppercase; color:rgba(201,168,76,0.65); margin-bottom:clamp(0.75rem,2.5vw,1.25rem); animation:fade-in 1.2s ease forwards;">
      Projekt kulturalno · filozoficzno · religijny
    </p>

    <!-- Main title -->
    <h1 class="gold-shimmer" style="font-family:'Cormorant Garamond',serif; font-weight:300; font-size:clamp(2.8rem,10vw,7.5rem); line-height:1; margin-bottom:clamp(0.2rem,0.8vw,0.4rem); animation:fade-in-up 1s ease 0.2s both;">
      Ateny Roztocza
    </h1>

    <!-- Ornamental divider -->
    <div style="display:flex; align-items:center; justify-content:center; gap:clamp(0.5rem,2vw,1rem); margin:clamp(1rem,2.5vw,1.5rem) 0; animation:fade-in 1s ease 0.5s both;">
      <div style="width:clamp(28px,7vw,70px); height:1px; background:linear-gradient(to right,transparent,#C9A84C);"></div>
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
        <path d="M10 2L12.5 7.5L18 10L12.5 12.5L10 18L7.5 12.5L2 10L7.5 7.5L10 2Z" fill="#C9A84C" opacity="0.85" />
      </svg>
      <div style="width:clamp(28px,7vw,70px); height:1px; background:linear-gradient(to left,transparent,#C9A84C);"></div>
    </div>

    <!-- Subtitle -->
    <p style="font-family:'IM Fell English',serif; font-style:italic; font-size:clamp(1.05rem,3.5vw,1.65rem); color:rgba(232,201,122,0.78); letter-spacing:0.05em; margin-bottom:clamp(1.25rem,3.5vw,2rem); animation:fade-in-up 1s ease 0.4s both;">
      Jerozolima · Ateny · Rzym
    </p>

    <!-- Description -->
    <p style="font-family:'Crimson Pro',serif; font-size:clamp(1rem,2.8vw,1.2rem); line-height:1.85; color:rgba(245,237,216,0.72); max-width:620px; margin:0 auto clamp(1.75rem,4.5vw,3rem); animation:fade-in-up 1s ease 0.6s both;">
      Centrum kultury chrześcijańskiej na Roztoczu. Spotkania z dziedzictwem
      Grecji, Rzymu i Jerozolimy — seminaria, wykłady, publikacje
      i 22-letnie archiwum audiowizualne.
    </p>

    <!-- CTA Buttons -->
    <div class="hero-cta-row" style="display:flex; gap:clamp(0.65rem,2vw,1rem); justify-content:center; flex-wrap:wrap; animation:fade-in-up 1s ease 0.8s both; margin-bottom:clamp(3rem,7vw,4.5rem);">
      <a href="#o-projekcie" class="hero-btn-primary">Poznaj projekt</a>
      <a href="/multimedia"  class="hero-btn-secondary">Archiwum · 2006–2026</a>
    </div>

    <!-- Scroll indicator -->
    <button
      id="hero-scroll-btn"
      aria-label="Przewiń w dół"
      class="hero-scroll-btn"
      style="display:flex; flex-direction:column; align-items:center; gap:8px; animation:fade-in 2s ease 1.5s both; cursor:pointer; background:none; border:none; padding:0.5rem;"
    >
      <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.58rem,1.6vw,0.68rem); letter-spacing:0.3em; text-transform:uppercase; color:rgba(201,168,76,0.5);">
        Przewiń
      </span>
      <div class="scroll-line"></div>
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:0.5; animation:scroll-bob 1.8s ease-in-out infinite;">
        <path d="M2 5l5 5 5-5" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
  </div>
</section>

<style>
  .hero-orb { position:absolute; border-radius:50%; filter:blur(80px); pointer-events:none; }
  .hero-orb-1 {
    width:clamp(200px,40vw,500px); height:clamp(200px,40vw,500px);
    background:radial-gradient(circle,rgba(201,168,76,0.09) 0%,transparent 70%);
    top:-5%; left:-5%;
    animation:orb-drift-1 18s ease-in-out infinite alternate;
  }
  .hero-orb-2 {
    width:clamp(250px,50vw,600px); height:clamp(250px,50vw,600px);
    background:radial-gradient(circle,rgba(122,28,46,0.07) 0%,transparent 70%);
    bottom:10%; right:-10%;
    animation:orb-drift-2 22s ease-in-out infinite alternate;
  }
  .hero-orb-3 {
    width:clamp(150px,30vw,350px); height:clamp(150px,30vw,350px);
    background:radial-gradient(circle,rgba(201,168,76,0.06) 0%,transparent 70%);
    top:40%; left:40%;
    animation:orb-drift-1 14s ease-in-out 4s infinite alternate;
  }

  .gold-particle {
    position:absolute; bottom:-10px; border-radius:50%;
    background:#C9A84C;
    animation:particle-rise linear infinite;
  }

  .hero-btn-primary {
    font-family:'Crimson Pro',serif;
    font-size:clamp(0.85rem,2.3vw,0.95rem);
    letter-spacing:0.14em; text-transform:uppercase;
    text-decoration:none; color:#1A1209;
    background:linear-gradient(135deg,#C9A84C,#E8C97A);
    padding:clamp(0.7rem,2.2vw,0.9rem) clamp(1.4rem,4.5vw,2.4rem);
    transition:all 0.3s ease; display:inline-block;
    font-weight:600; border:none; cursor:pointer;
  }
  .hero-btn-primary:hover { transform:translateY(-2px); box-shadow:0 8px 28px rgba(201,168,76,0.45); }

  .hero-btn-secondary {
    font-family:'Crimson Pro',serif;
    font-size:clamp(0.85rem,2.3vw,0.95rem);
    letter-spacing:0.14em; text-transform:uppercase;
    text-decoration:none; color:#E8C97A;
    border:1px solid rgba(201,168,76,0.45);
    padding:clamp(0.7rem,2.2vw,0.9rem) clamp(1.4rem,4.5vw,2.4rem);
    transition:all 0.3s ease; display:inline-block;
    background:transparent; cursor:pointer;
  }
  .hero-btn-secondary:hover { border-color:#C9A84C; background:rgba(201,168,76,0.09); transform:translateY(-2px); }

  .scroll-line {
    width:1px; height:clamp(26px,4.5vw,38px);
    background:linear-gradient(to bottom,rgba(201,168,76,0.5),transparent);
    animation:scroll-line-pulse 2s ease-in-out infinite;
  }

  @keyframes orb-drift-1 {
    from { transform:translate(0,0) scale(1); }
    to   { transform:translate(4%,6%) scale(1.12); }
  }
  @keyframes orb-drift-2 {
    from { transform:translate(0,0) scale(1); }
    to   { transform:translate(-5%,-4%) scale(1.08); }
  }
  @keyframes particle-rise {
    0%   { transform:translateY(0) scale(1); opacity:0; }
    10%  { opacity:1; }
    90%  { opacity:0.5; }
    100% { transform:translateY(-100vh) scale(0.5); opacity:0; }
  }
  @keyframes scroll-line-pulse {
    0%,100% { opacity:0.5; transform:scaleY(1); }
    50%      { opacity:1;   transform:scaleY(1.15); }
  }
  @keyframes scroll-bob {
    0%,100% { transform:translateY(0); }
    50%      { transform:translateY(4px); }
  }

  @media (max-width:640px) {
    .hero-btn-primary, .hero-btn-secondary { width:100%; text-align:center; max-width:290px; }
    .hero-cta-row { flex-direction:column; align-items:center; }
  }
</style>

<script>
  // ── Video autoplay ────────────────────────────────────────
  const video = document.getElementById('hero-video') as HTMLVideoElement;
  if (video) {
    const tryPlay = () => { video.play().catch(() => { video.style.display = 'none'; }); };

    video.addEventListener('canplay', () => {
      video.style.opacity = '0.5';
    }, { once: true });

    video.addEventListener('error', () => {
      video.style.display = 'none';
    }, { once: true });

    if (video.readyState >= 3) tryPlay();
    else video.addEventListener('canplaythrough', tryPlay, { once: true });
  }

  // ── Scroll to #filary ─────────────────────────────────────
  document.getElementById('hero-scroll-btn')?.addEventListener('click', () => {
    document.getElementById('filary')?.scrollIntoView({ behavior: 'smooth' });
  });
</script>
