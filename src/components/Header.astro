const pathname = Astro.url.pathname;

/* ─────────────────────────────────────
   Language detection
───────────────────────────────────── */

let currentLang = 'PL';
let basePath = pathname;

if (pathname.startsWith('/en')) {
  currentLang = 'EN';
  basePath = pathname.slice(3) || '/';
}
else if (pathname.startsWith('/de')) {
  currentLang = 'DE';
  basePath = pathname.slice(3) || '/';
}
else if (pathname.startsWith('/es')) {
  currentLang = 'ES';
  basePath = pathname.slice(3) || '/';
}
else if (pathname.startsWith('/it')) {
  currentLang = 'IT';
  basePath = pathname.slice(3) || '/';
}

const langs = [
  { code: 'PL', label: 'PL', prefix: '' },
  { code: 'EN', label: 'EN', prefix: '/en' },
  { code: 'DE', label: 'DE', prefix: '/de' },
  { code: 'ES', label: 'ES', prefix: '/es' },
  { code: 'IT', label: 'IT', prefix: '/it' }
];

function getLangUrl(prefix: string): string {
  const path = basePath === '/' ? '' : basePath;
  return (prefix + path) || '/';
}

/* ─────────────────────────────────────
   Navigation
───────────────────────────────────── */

const navItems = [
  {
    label: 'O projekcie',
    href: '/o-projekcie',
    children: [
      { label: 'Jak powstaja Ateny Roztocza', href: '/o-projekcie' },
      { label: 'Trzy filary', href: '/#filary' },
      { label: 'Ks. prof. Tadeusz Guz', href: '/ks-guz' }
    ]
  },
  {
    label: 'Multimedia',
    href: '/multimedia',
    children: [
      { label: 'Materialy audiowizualne', href: '/multimedia' },
      { label: 'Artykuly - Nasz Dziennik', href: '/multimedia?tab=nasz-dziennik' },
      { label: 'Artykuly - Niedziela', href: '/multimedia?tab=niedziela' },
      { label: 'Inne publikacje', href: '/multimedia?tab=inne' }
    ]
  },
  { label: 'Wydarzenia', href: '/wydarzenia' },
  { label: 'Galeria', href: '/galeria' },
  { label: 'Kontakt', href: '/kontakt' }
];

/* ─────────────────────────────────────
   Active link logic (with language prefix)
───────────────────────────────────── */

function cleanPath(path: string) {
  return path.replace(/^\/(en|de|es|it)/, '');
}

function isActive(href: string): boolean {
  const cleanHref = href.split('?')[0].split('#')[0];
  const current = cleanPath(pathname);

  if (cleanHref === '/' || cleanHref === '') return current === '/';

  return current.startsWith(cleanHref);
}

/* ─────────────────────────────────────
   Styles
───────────────────────────────────── */

const navLinkStyles = navItems.map((item) => {
  const base =
    'padding:0.45rem 0.7rem; display:flex; align-items:center; gap:4px;';
  return isActive(item.href) ? base + 'color:#E8C97A;' : base;
});

const navSimpleStyles = navItems.map((item) => {
  const base =
    'padding:0.45rem 0.7rem; display:block;';
  return isActive(item.href)
    ? base + 'color:#E8C97A; border-bottom:1px solid rgba(201,168,76,0.45);'
    : base + 'border-bottom:none;';
});

const mobileBtnStyles = navItems.map((item) => {
  const base =
    'flex:1; text-align:left; padding:0.95rem 1.25rem; font-family:Crimson Pro,serif; font-size:1rem; letter-spacing:0.07em; text-transform:uppercase; background:none; border:none; cursor:pointer; min-height:52px; display:flex; align-items:center; text-decoration:none;';
  return isActive(item.href)
    ? base + 'color:#E8C97A;'
    : base + 'color:rgba(245,237,216,0.82);';
});
