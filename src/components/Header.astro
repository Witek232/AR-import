const pathname = Astro.url.pathname;

/* ─────────────────────────
   Language detection
───────────────────────── */

const langPrefixes = ['en','de','es','it'];

let currentLang = 'pl';
let basePath = pathname;

for (const l of langPrefixes) {
  if (pathname.startsWith('/' + l)) {
    currentLang = l;
    basePath = pathname.slice(l.length + 1) || '/';
  }
}

function getLangUrl(prefix){
  const path = basePath === '/' ? '' : basePath;
  return (prefix + path) || '/';
}

/* ─────────────────────────
   Navigation
───────────────────────── */

const navItems = [
{
label:'O projekcie',
href:'/o-projekcie',
children:[
{label:'Jak powstaja Ateny Roztocza',href:'/o-projekcie'},
{label:'Trzy filary',href:'/#filary'},
{label:'Ks. prof. Tadeusz Guz',href:'/ks-guz'}
]
},
{
label:'Multimedia',
href:'/multimedia',
children:[
{label:'Materialy audiowizualne',href:'/multimedia'},
{label:'Artykuly - Nasz Dziennik',href:'/multimedia?tab=nasz-dziennik'},
{label:'Artykuly - Niedziela',href:'/multimedia?tab=niedziela'},
{label:'Inne publikacje',href:'/multimedia?tab=inne'}
]
},
{label:'Wydarzenia',href:'/wydarzenia'},
{label:'Galeria',href:'/galeria'},
{label:'Kontakt',href:'/kontakt'}
];

/* ─────────────────────────
   Active link
───────────────────────── */

function stripLang(path){
  return path.replace(/^\/(en|de|es|it)/,'') || '/';
}

function isActive(href){
  const current = stripLang(pathname);
  const clean = href.split('?')[0].split('#')[0];

  if(clean === '/') return current === '/';

  return current.startsWith(clean);
}

/* ─────────────────────────
   Languages
───────────────────────── */

const langs = [
{code:'pl',label:'PL',prefix:''},
{code:'en',label:'EN',prefix:'/en'},
{code:'de',label:'DE',prefix:'/de'},
{code:'es',label:'ES',prefix:'/es'},
{code:'it',label:'IT',prefix:'/it'}
];
