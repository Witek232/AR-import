---
const pathname = Astro.url.pathname;

let currentLang = 'PL';
let basePath = pathname;

if (pathname.startsWith('/en')) { currentLang = 'EN'; basePath = pathname.slice(3) || '/'; }
else if (pathname.startsWith('/de')) { currentLang = 'DE'; basePath = pathname.slice(3) || '/'; }
else if (pathname.startsWith('/es')) { currentLang = 'ES'; basePath = pathname.slice(3) || '/'; }
else if (pathname.startsWith('/it')) { currentLang = 'IT'; basePath = pathname.slice(3) || '/'; }

const langs = [
  { code: 'PL', label: 'PL', prefix: '' },
  { code: 'EN', label: 'EN', prefix: '/en' },
  { code: 'DE', label: 'DE', prefix: '/de' },
  { code: 'ES', label: 'ES', prefix: '/es' },
  { code: 'IT', label: 'IT', prefix: '/it' },
];

function getLangUrl(prefix: string): string {
  const path = basePath === '/' ? '' : basePath;
  return (prefix + path) || '/';
}

const navItems = [
  {
    label: 'O projekcie',
    href: '/o-projekcie',
    children: [
      { label: 'Jak powstają Ateny Roztocza', href: '/o-projekcie' },
      { label: 'Trzy filary', href: '/#filary' },
      { label: 'Ks. prof. Tadeusz Guz', href: '/ks-guz' },
    ],
  },
  {
    label: 'Multimedia',
    href: '/multimedia',
    children: [
      { label: 'Materiały audiowizualne', href: '/multimedia' },
      { label: 'Artykuły — Nasz Dziennik', href: '/multimedia?tab=nasz-dziennik' },
      { label: 'Artykuły — Niedziela', href: '/multimedia?tab=niedziela' },
      { label: 'Inne publikacje', href: '/multimedia?tab=inne' },
    ],
  },
  { label: 'Wydarzenia', href: '/wydarzenia' },
  { label: 'Galeria', href: '/galeria' },
  { label: 'Kontakt', href: '/kontakt' },
];

function isActive(href: string): boolean {
  const clean = href.split('?')[0].split('#')[0];
  if (clean === '/' || clean === '') return pathname === '/';
  return pathname.startsWith(clean);
}

const navLinkStyles = navItems.map((item) => {
  const base = 'padding:0.45rem 0.7rem; display:flex; align-items:center; gap:4px;';
  return isActive(item.href) ? base + 'color:#E8C97A;' : base;
});

const navSimpleStyles = navItems.map((item) => {
  const base = 'padding:0.45rem 0.7rem; display:block;';
  return isActive(item.href)
    ? base + 'color:#E8C97A; border-bottom:1px solid rgba(201,168,76,0.45);'
    : base + 'border-bottom:none;';
});

const mobileBtnStyles = navItems.map((item) => {
  const base = 'flex:1; text-align:left; padding:0.95rem 1.25rem; font-family:Crimson Pro,serif; font-size:1rem; letter-spacing:0.07em; text-transform:uppercase; background:none; border:none; cursor:pointer; min-height:52px; display:flex; align-items:center; text-decoration:none;';
  return isActive(item.href) ? base + 'color:#E8C97A;' : base + 'color:rgba(245,237,216,0.82);';
});
---

<header
id="site-header"
style="position:fixed; top:0; left:0; right:0; z-index:1000; background:linear-gradient(to bottom,rgba(13,10,5,0.88),transparent); transition:all 0.4s ease;"
>

<div
id="header-inner"
style="max-width:1280px; margin:0 auto; padding:0.85rem clamp(1rem,3vw,2rem); display:flex; align-items:center; justify-content:space-between; gap:1rem;"
>

<a
href="/"
aria-label="Ateny Roztocza — strona główna"
style="text-decoration:none; display:flex; flex-direction:column; gap:2px;"
>
<span style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.25rem,3.5vw,1.7rem); color:#E8C97A;">
Ateny Roztocza
</span>
<span style="font-family:'Crimson Pro',serif; font-size:0.65rem; color:rgba(232,201,122,0.5); letter-spacing:0.2em;">
Jerozolima · Ateny · Rzym
</span>
</a>

<nav class="desktop-nav" style="display:flex; align-items:center;">

{navItems.map((item, i) => (

item.children ? (

<div class="dropdown-parent" style="position:relative; padding:0.5rem 0;">

<a
href={item.href}
class="nav-link"
style={navLinkStyles[i]}
>

{item.label}

<svg width="9" height="6">
<path d="M1 1l3.5 4 3.5-4" stroke="currentColor"/>
</svg>

</a>

<div class="dropdown">

{item.children.map((child) => (

<a href={child.href} class="dropdown-btn">

{child.label}

</a>

))}

</div>

</div>

) : (

<a
href={item.href}
class="nav-link"
style={navSimpleStyles[i]}
>

{item.label}

</a>

)

))}

</nav>

<div style="display:flex; align-items:center; gap:0.15rem;">

{langs.map((lang) => (

<a
href={getLangUrl(lang.prefix)}
class={currentLang === lang.code ? 'lang-btn lang-active' : 'lang-btn'}
>

{lang.label}

</a>

))}

</div>

</div>

</header>

<style>

.lang-btn{
font-family:'Crimson Pro',serif;
font-size:0.75rem;
color:rgba(232,201,122,0.35);
padding:4px 5px;
text-decoration:none;
}

.lang-btn:hover{
color:#E8C97A;
}

.lang-active{
color:#E8C97A;
font-weight:600;
}

.dropdown{
position:absolute;
top:100%;
left:0;
background:rgba(10,7,3,0.98);
border:1px solid rgba(201,168,76,0.15);
display:none;
}

.dropdown-parent:hover .dropdown{
display:block;
}

.dropdown-btn{
display:block;
padding:0.6rem 1rem;
color:rgba(232,201,122,0.7);
text-decoration:none;
font-family:'Crimson Pro',serif;
}

.dropdown-btn:hover{
color:#E8C97A;
background:rgba(201,168,76,0.08);
}

</style>
