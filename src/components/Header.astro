<!-- SEO -->

{langs.map(l => (
<link rel="alternate" hreflang={l.code} href={getLangUrl(l.prefix)} />
))}

<link rel="alternate" hreflang="x-default" href="/" />

<header id="site-header">

<div class="header-inner">

<a href="/" class="logo">
<span class="logo-title">Ateny Roztocza</span>
<span class="logo-sub">Jerozolima · Ateny · Rzym</span>
</a>

<nav class="desktop-nav">

{navItems.map(item => (

item.children ?

<div class="nav-group">

<a href={item.href} class={`nav-link ${isActive(item.href) ? 'active':''}`}>
{item.label}
</a>

<div class="dropdown">

{item.children.map(child => (

<a href={child.href} class="dropdown-link">
{child.label}
</a>

))}

</div>

</div>

:

<a href={item.href} class={`nav-link ${isActive(item.href)?'active':''}`}>
{item.label}
</a>

))}

</nav>

<div class="header-right">

<div class="lang-switch">

{langs.map(l => (

<a
href={getLangUrl(l.prefix)}
class={`lang ${currentLang===l.code?'active':''}`}
>
{l.label}
</a>

))}

</div>

<button id="hamburger" aria-label="Menu">
<span></span>
<span></span>
<span></span>
</button>

</div>

</div>

</header>

<div id="overlay"></div>

<nav id="mobile-menu">

{navItems.map(item => (

<div class="mobile-item">

<a
href={item.children ? '#' : item.href}
class="mobile-link"
data-has={item.children ? '1':'0'}
>
{item.label}
</a>

{item.children && (

<div class="mobile-sub">

{item.children.map(child => (

<a href={child.href}>
{child.label}
</a>

))}

</div>

)}

</div>

))}

<div class="mobile-langs">

{langs.map(l => (

<a href={getLangUrl(l.prefix)}>
{l.label}
</a>

))}

</div>

</nav>

<style>
/* styl pozostaje taki jak wcześniej */
</style>

<script>

const burger=document.getElementById("hamburger")
const menu=document.getElementById("mobile-menu")
const overlay=document.getElementById("overlay")

burger.onclick=()=>{
menu.classList.toggle("open")
overlay.style.display=menu.classList.contains("open")?"block":"none"
}

overlay.onclick=()=>{
menu.classList.remove("open")
overlay.style.display="none"
}

document.querySelectorAll(".mobile-link").forEach(link=>{
if(link.dataset.has==="1"){
link.onclick=(e)=>{
e.preventDefault()
const sub=link.nextElementSibling
sub.style.display=sub.style.display==="block"?"none":"block"
}
}
})

</script>
