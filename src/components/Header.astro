---
const pathname = Astro.url.pathname;

let currentLang = 'PL';
let basePath = pathname;

if      (pathname.startsWith('/en')) { currentLang = 'EN'; basePath = pathname.slice(3) || '/'; }
else if (pathname.startsWith('/de')) { currentLang = 'DE'; basePath = pathname.slice(3) || '/'; }
else if (pathname.startsWith('/es')) { currentLang = 'ES'; basePath = pathname.slice(3) || '/'; }
else if (pathname.startsWith('/it')) { currentLang = 'IT'; basePath = pathname.slice(3) || '/'; }

const langs = [
  { code: 'PL', label: 'PL', prefix: '' },
  { code: 'EN', label: 'EN', prefix: '/en' },
  { code: 'DE', label: 'DE', prefix: '/de' },
  { code: 'ES', label: 'ES', prefix: '/es' },
  { code: 'IT', label: 'IT', prefix: '/it' },
];

function getLangUrl(prefix: string): string {
  const path = basePath === '/' ? '' : basePath;
  return (prefix + path) || '/';
}

const navItems = [
  {
    label: 'O projekcie',
    href: '/o-projekcie',
    children: [
      { label: 'Jak powstaja Ateny Roztocza', href: '/o-projekcie' },
      { label: 'Trzy filary',                 href: '/#filary'     },
      { label: 'Ks. prof. Tadeusz Guz',       href: '/ks-guz'      },
    ],
  },
  {
    label: 'Multimedia',
    href: '/multimedia',
    children: [
      { label: 'Materialy audiowizualne',  href: '/multimedia'                   },
      { label: 'Artykuly - Nasz Dziennik', href: '/multimedia?tab=nasz-dziennik' },
      { label: 'Artykuly - Niedziela',     href: '/multimedia?tab=niedziela'     },
      { label: 'Inne publikacje',          href: '/multimedia?tab=inne'          },
    ],
  },
  { label: 'Wydarzenia', href: '/wydarzenia' },
  { label: 'Galeria',    href: '/galeria'    },
  { label: 'Kontakt',    href: '/kontakt'    },
];

function isActive(href: string): boolean {
  const clean = href.split('?')[0].split('#')[0];
  if (clean === '/' || clean === '') return pathname === '/';
  return pathname.startsWith(clean);
}

const navLinkStyles = navItems.map((item) => {
  const base = 'padding:0.45rem 0.7rem; display:flex; align-items:center; gap:4px;';
  return isActive(item.href) ? base + 'color:#E8C97A;' : base;
});

const navSimpleStyles = navItems.map((item) => {
  const base = 'padding:0.45rem 0.7rem; display:block;';
  return isActive(item.href)
    ? base + 'color:#E8C97A; border-bottom:1px solid rgba(201,168,76,0.45);'
    : base + 'border-bottom:none;';
});

const mobileBtnStyles = navItems.map((item) => {
  const base = 'flex:1; text-align:left; padding:0.95rem 1.25rem; font-family:Crimson Pro,serif; font-size:1rem; letter-spacing:0.07em; text-transform:uppercase; background:none; border:none; cursor:pointer; min-height:52px; display:flex; align-items:center; text-decoration:none;';
  return isActive(item.href) ? base + 'color:#E8C97A;' : base + 'color:rgba(245,237,216,0.82);';
});
---

<header
  id="site-header"
  style="position:fixed; top:0; left:0; right:0; z-index:1000; background:linear-gradient(to bottom,rgba(13,10,5,0.88),transparent); transition:all 0.4s ease;"
>
  <div
    id="header-inner"
    style="max-width:1280px; margin:0 auto; padding:0.85rem clamp(1rem,3vw,2rem); display:flex; align-items:center; justify-content:space-between; gap:1rem; transition:padding 0.4s ease;"
  >

    <a href="/" style="text-decoration:none; display:flex; flex-direction:column; gap:2px; flex-shrink:0;">
      <span id="logo-title" style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.25rem,3.5vw,1.7rem); font-weight:300; color:#E8C97A; letter-spacing:0.08em; transition:font-size 0.4s ease; line-height:1;">
        Ateny Roztocza
      </span>
      <span style="font-family:'Crimson Pro',serif; font-size:0.65rem; color:rgba(232,201,122,0.5); letter-spacing:0.2em; text-transform:uppercase;">
        Jerozolima · Ateny · Rzym
      </span>
    </a>

    <nav class="desktop-nav" style="display:flex; align-items:center;">
      {navItems.map((item, i) =>
        item.children ? (
          <div class="dropdown-parent" style="position:relative; padding:0.5rem 0;">
            <a href={item.href} class="nav-link" style={navLinkStyles[i]}>
              {item.label}
              <svg width="9" height="6" viewBox="0 0 9 6" fill="none" style="opacity:0.5; flex-shrink:0; margin-left:2px;">
                <path d="M1 1l3.5 4 3.5-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </a>
            <div class="dropdown">
              {item.children.map((child) => (
                <a href={child.href} class="dropdown-btn">{child.label}</a>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href} class="nav-link" style={navSimpleStyles[i]}>
            {item.label}
          </a>
        )
      )}
    </nav>

    <div style="display:flex; align-items:center; gap:0.15rem; flex-shrink:0;">
      {langs.map((lang) => (
        <a href={getLangUrl(lang.prefix)} class={currentLang === lang.code ? 'lang-btn lang-active' : 'lang-btn'}>
          {lang.label}
        </a>
      ))}
      <button
        id="hamburger"
        aria-label="Otworz menu"
        aria-expanded="false"
        style="display:none; background:none; border:1px solid rgba(201,168,76,0.28); cursor:pointer; color:#E8C97A; padding:8px 10px; margin-left:0.5rem; width:44px; height:44px; align-items:center; justify-content:center; flex-shrink:0;"
      >
        <svg id="icon-closed" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8">
          <line x1="3" y1="6.5"  x2="21" y2="6.5"  stroke-linecap="round"/>
          <line x1="3" y1="11.5" x2="21" y2="11.5" stroke-linecap="round"/>
          <line x1="3" y1="16.5" x2="21" y2="16.5" stroke-linecap="round"/>
        </svg>
        <svg id="icon-open" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" style="display:none;">
          <path d="M5 5l14 14M19 5L5 19" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

  </div>
</header>

<div id="mobile-overlay" style="display:none; position:fixed; inset:0; z-index:999; background:rgba(0,0,0,0.55);"></div>

<div
  id="mobile-drawer"
  style="position:fixed; top:0; right:0; bottom:0; width:min(320px,88vw); z-index:1001; background:rgba(10,7,3,0.99); border-left:1px solid rgba(201,168,76,0.18); transform:translateX(100%); transition:transform 0.35s ease; overflow-y:auto; display:flex; flex-direction:column;"
>
  <div style="padding:1.25rem; border-bottom:1px solid rgba(201,168,76,0.12); display:flex; align-items:center; justify-content:space-between;">
    <div>
      <div style="font-family:'Cormorant Garamond',serif; font-size:1.3rem; color:#E8C97A; font-weight:300;">Ateny Roztocza</div>
      <div style="font-family:'Crimson Pro',serif; font-size:0.6rem; color:rgba(232,201,122,0.45); letter-spacing:0.18em; text-transform:uppercase; margin-top:2px;">Jerozolima · Ateny · Rzym</div>
    </div>
    <button id="drawer-close" style="background:none; border:1px solid rgba(201,168,76,0.25); color:#C9A84C; width:40px; height:40px; display:flex; align-items:center; justify-content:center; cursor:pointer;">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d="M4 4l10 10M14 4L4 14" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <nav style="padding:0.5rem 0; flex:1;">
    {navItems.map((item, i) => (
      <div class="m-item">
        <div style="display:flex; align-items:center; border-bottom:1px solid rgba(201,168,76,0.07);">
          
            href={item.children ? undefined : item.href}
            class="m-link"
            data-has-ch={item.children ? 'yes' : 'no'}
            data-key={item.label}
            style={mobileBtnStyles[i]}
          >
            {item.label}
          </a>
          {item.children && (
            <button class="m-expand" data-key={item.label} style="background:none; border:none; cursor:pointer; color:#C9A84C; padding:0.95rem 1.25rem; min-height:52px; display:flex; align-items:center;">
              <svg class="m-chevron" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" style="transition:transform 0.25s ease;">
                <path d="M3 6l5 5 5-5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          )}
        </div>
        {item.children && (
          <div class="m-sub" data-key={item.label} style="max-height:0; overflow:hidden; transition:max-height 0.3s ease; background:rgba(201,168,76,0.03);">
            {item.children.map((child) => (
              <a href={child.href} style="display:flex; align-items:center; gap:0.5rem; padding:0.8rem 1.25rem 0.8rem 2rem; font-family:'Crimson Pro',serif; font-size:0.95rem; color:rgba(232,201,122,0.65); text-decoration:none; border-bottom:1px solid rgba(201,168,76,0.06); min-height:48px;">
                <span style="color:rgba(201,168,76,0.4);">›</span>
                {child.label}
              </a>
            ))}
          </div>
        )}
      </div>
    ))}
  </nav>

  <div style="padding:1rem 1.25rem 2rem; border-top:1px solid rgba(201,168,76,0.1); display:flex; gap:0.4rem; flex-wrap:wrap; align-items:center;">
    <span style="font-family:'Crimson Pro',serif; font-size:0.75rem; letter-spacing:0.15em; text-transform:uppercase; color:rgba(201,168,76,0.4); margin-right:0.25rem;">Jezyk</span>
    {langs.map((lang) => (
      <a href={getLangUrl(lang.prefix)} class={currentLang === lang.code ? 'ml-btn ml-active' : 'ml-btn'}>
        {lang.label}
      </a>
    ))}
  </div>
</div>

<style>
  .nav-link {
    font-family: 'Crimson Pro', serif;
    font-size: clamp(0.85rem, 1.8vw, 0.95rem);
    letter-spacing: 0.06em;
    color: rgba(232,201,122,0.72);
    text-decoration: none;
    transition: color
