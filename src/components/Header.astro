```astro
---
const pathname = Astro.url.pathname;

/* LANG */

const languages=['pl','en','de','es','it'];

let currentLang='pl';

for(const l of languages){
if(pathname.startsWith('/'+l)) currentLang=l
}

/* TRANSLATIONS */

const t={
pl:{
about:"O projekcie",
multimedia:"Multimedia",
events:"Wydarzenia",
gallery:"Galeria",
contact:"Kontakt",
pillars:"Trzy filary"
},
en:{
about:"About",
multimedia:"Media",
events:"Events",
gallery:"Gallery",
contact:"Contact",
pillars:"Three pillars"
},
de:{
about:"Über das Projekt",
multimedia:"Medien",
events:"Veranstaltungen",
gallery:"Galerie",
contact:"Kontakt",
pillars:"Drei Säulen"
},
es:{
about:"Sobre el proyecto",
multimedia:"Multimedia",
events:"Eventos",
gallery:"Galería",
contact:"Contacto",
pillars:"Tres pilares"
},
it:{
about:"Sul progetto",
multimedia:"Media",
events:"Eventi",
gallery:"Galleria",
contact:"Contatto",
pillars:"Tre pilastri"
}
}

/* NAV */

const nav=[
{key:'about',href:'/o-projekcie'},
{key:'multimedia',href:'/multimedia'},
{key:'events',href:'/wydarzenia'},
{key:'gallery',href:'/galeria'},
{key:'contact',href:'/kontakt'}
]

function label(k){
return t[currentLang][k] || k
}
---

<header>

<nav>

{nav.map(i=>(

<a href={i.href}>
{label(i.key)}
</a>

))}

</nav>

</header>
```
