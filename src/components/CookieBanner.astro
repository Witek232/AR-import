---
// src/components/CookieBanner.astro
---

<div id="cookie-banner" style="display:none; position:fixed; bottom:0; left:0; right:0; z-index:9999; background:rgba(13,10,5,0.97); border-top:1px solid rgba(201,168,76,0.25); backdrop-filter:blur(12px); padding:clamp(1rem,3vw,1.5rem) clamp(1rem,4vw,2rem);">
  <div style="max-width:1100px; margin:0 auto; display:flex; flex-wrap:wrap; align-items:center; gap:clamp(1rem,3vw,1.5rem); justify-content:space-between;">
    
    <div style="flex:1; min-width:280px;">
      <p style="font-family:'Inter',serif; font-size:clamp(0.85rem,2vw,0.95rem); color:rgba(245,237,216,0.8); line-height:1.65; margin:0;">
        Używamy plików cookies, aby zapewnić najlepsze doświadczenia na naszej stronie. Kontynuując przeglądanie, wyrażasz zgodę na ich użycie zgodnie z naszą <a href="/polityka-cookies" style="color:#E8C97A; text-decoration:underline; text-underline-offset:3px;">Polityką Cookies</a> i <a href="/polityka-prywatnosci" style="color:#E8C97A; text-decoration:underline; text-underline-offset:3px;">Polityką Prywatności</a>.
      </p>
    </div>

    <div style="display:flex; gap:0.75rem; flex-shrink:0;">
      <button id="cookie-reject" style="font-family:'Inter',serif; font-size:0.85rem; letter-spacing:0.1em; text-transform:uppercase; padding:0.65rem 1.25rem; background:none; border:1px solid rgba(201,168,76,0.4); color:#E8C97A; cursor:pointer; transition:all 0.2s; white-space:nowrap;">
        Tylko niezbędne
      </button>
      <button id="cookie-accept" style="font-family:'Inter',serif; font-size:0.85rem; letter-spacing:0.1em; text-transform:uppercase; padding:0.65rem 1.25rem; background:linear-gradient(135deg,#C9A84C,#E8C97A); border:none; color:#0D0A05; font-weight:600; cursor:pointer; transition:all 0.2s; white-space:nowrap;">
        Akceptuję wszystkie
      </button>
    </div>

  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  const rejectBtn = document.getElementById('cookie-reject');

  function getConsent() {
    return localStorage.getItem('cookie-consent');
  }

  function setConsent(type: string) {
    localStorage.setItem('cookie-consent', type);
    if (banner) banner.style.display = 'none';
    
    // Opcjonalnie: załaduj skrypty analityczne, jeśli zaakceptowano
    if (type === 'accepted') {
      // Tutaj w przyszłości wstrzykniesz np. Google Analytics
      console.log('Cookies accepted: Analytics can be loaded.');
    }
  }

  // Pokaż banner tylko jeśli nie podjęto jeszcze decyzji
  if (!getConsent()) {
    if (banner) banner.style.display = 'block';
  }

  acceptBtn?.addEventListener('click', () => setConsent('accepted'));
  rejectBtn?.addEventListener('click', () => setConsent('rejected'));
</script>

<style>
  #cookie-reject:hover {
    background: rgba(201,168,76,0.1) !important;
    border-color: #E8C97A !important;
  }
  #cookie-accept:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
</style>
