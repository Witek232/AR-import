---
// ── ANALIZA ──────────────────────────────────────────────────
// Komponent STATYCZNY — zero interakcji.
// useRef + useEffect (IntersectionObserver) → zastąpiony przez
// globalny initReveal() w Layout.astro + klasy CSS reveal-delay-*
// ─────────────────────────────────────────────────────────────

const pillars = [
  {
    numeral:     'I',
    city:        'Jerozolima',
    latinName:   'Hierosolyma',
    symbol:      '✝',
    description: 'Duchowa kolebka chrześcijaństwa. Tradycja biblijna i patrystyczna jako fundament tożsamości europejskiej. Objawienie, które weszło w historię i kulturę.',
    accentColor: '#9E2A40',
  },
  {
    numeral:     'II',
    city:        'Ateny',
    latinName:   'Athenae',
    symbol:      'Φ',
    description: 'Filozofia i rozum. Logos grecki jako język, którym myśl chrześcijańska wyraziła swe treści. Dialog wiary i rozumu, sokratejski nakaz poznania siebie.',
    accentColor: '#C9A84C',
  },
  {
    numeral:     'III',
    city:        'Rzym',
    latinName:   'Roma Aeterna',
    symbol:      'Σ',
    description: 'Prawo, instytucje i sztuka organizacji życia zbiorowego. Cywilizacja łacińska jako forma, w której chrześcijaństwo ukształtowało Europę przez dwa tysiąclecia.',
    accentColor: '#6B8A4E',
  },
];
---

<section
  id="filary"
  style="background:#1A1209; padding:clamp(3.5rem,9vw,7rem) clamp(1rem,4vw,2rem); position:relative; overflow:hidden;"
>
  <!-- Subtle grid texture -->
  <div style="position:absolute; inset:0; pointer-events:none; background-image:repeating-linear-gradient(0deg,transparent,transparent 59px,rgba(201,168,76,0.025) 59px,rgba(201,168,76,0.025) 60px);"></div>

  <div style="max-width:1200px; margin:0 auto; position:relative;">

    <!-- Section header -->
    <div class="reveal" style="text-align:center; margin-bottom:clamp(2.5rem,6vw,4rem);">
      <p class="section-label" style="color:rgba(201,168,76,0.55); margin-bottom:0.85rem;">
        Fundamenty projektu
      </p>
      <h2 class="section-title" style="color:#E8C97A; font-size:clamp(2rem,6vw,3.75rem); margin-bottom:0;">
        Trzy Filary Cywilizacji
      </h2>
      <div class="section-ornament">
        <div class="section-ornament-line"></div>
        <svg width="14" height="14" viewBox="0 0 16 16" fill="#C9A84C">
          <path d="M8 1l1.8 4.4L14.4 6l-3.2 3.1.75 4.4L8 11.4l-3.95 2.1.75-4.4L1.6 6l4.6-.6L8 1z" />
        </svg>
        <div class="section-ornament-line"></div>
      </div>
    </div>

    <!-- Cards -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(min(100%,280px),1fr)); gap:clamp(1.25rem,3vw,2rem);">
      {pillars.map((pillar, i) => (
        <div
          class={`reveal reveal-delay-${i + 1} card-hover gold-border-hover`}
          style="background:rgba(255,255,255,0.025); border:1px solid rgba(201,168,76,0.14); padding:clamp(1.5rem,4vw,2.5rem) clamp(1.25rem,3.5vw,2rem); position:relative; cursor:default;"
        >
          <!-- Latin numeral watermark -->
          <div style={`font-family:'Cormorant Garamond',serif; font-size:clamp(4rem,10vw,6rem); font-weight:300; color:${pillar.accentColor}; opacity:0.18; position:absolute; top:0.75rem; right:1.25rem; line-height:1; letter-spacing:-0.04em; pointer-events:none; user-select:none;`}>
            {pillar.numeral}
          </div>

          <!-- Symbol -->
          <div style={`font-family:'Cormorant Garamond',serif; font-size:clamp(1.5rem,4vw,2rem); color:${pillar.accentColor}; margin-bottom:clamp(0.75rem,2vw,1rem); opacity:0.9;`}>
            {pillar.symbol}
          </div>

          <!-- City name -->
          <h3 style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.75rem,5vw,2.4rem); font-weight:400; color:#F5EDD8; margin-bottom:0.2rem; line-height:1.1;">
            {pillar.city}
          </h3>

          <!-- Latin subtitle -->
          <p style={`font-family:'IM Fell English',serif; font-style:italic; font-size:clamp(0.875rem,2vw,0.9375rem); color:rgba(201,168,76,0.55); margin-bottom:clamp(1rem,2.5vw,1.35rem); letter-spacing:0.05em;`}>
            {pillar.latinName}
          </p>

          <!-- Accent line -->
          <div style={`width:36px; height:1px; background:linear-gradient(to right,${pillar.accentColor},transparent); margin-bottom:clamp(1rem,2.5vw,1.35rem);`}></div>

          <!-- Description -->
          <p style="font-family:'Crimson Pro',serif; font-size:clamp(1.0625rem,2.5vw,1.125rem); line-height:1.82; color:rgba(245,237,216,0.68);">
            {pillar.description}
          </p>
        </div>
      ))}
    </div>

    <!-- Bottom quote -->
    <div class="reveal" style="text-align:center; margin-top:clamp(2.5rem,6vw,4.5rem);">
      <p style="font-family:'IM Fell English',serif; font-style:italic; font-size:clamp(1.0625rem,3vw,1.375rem); color:rgba(201,168,76,0.58); max-width:680px; margin:0 auto; line-height:1.85;">
        „Trzy korzenie wyrosły z jednej gleby i dały człowiekowi Zachodu
        jego tożsamość duchową, intelektualną i prawną."
      </p>
    </div>

  </div>
</section>
