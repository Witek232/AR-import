---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { processArticles } from '../../data/articleHelpers';

export async function getStaticPaths() {
  const allArticles = await getCollection('articles');
  const allCycles = await getCollection('cycles');
  const { cycles } = processArticles(allArticles, allCycles);

  return cycles.map(cycle => {
    const cycleSlug = cycle.id.replace(/\.md$/, '');
    return {
      params: { cycleSlug: cycleSlug },
      props: { cycle },
    };
  });
}

const { cycle } = Astro.props;
---

<Layout title={cycle.data.title} description={cycle.data.description}>
  <div class="page-transition">
    
    <div class="page-hero">
      <div style="position:relative; z-index:2; max-width:800px; margin:0 auto;">
        <a href="/cykle" style="display: inline-flex; align-items: center; gap: 0.5rem; font-family: 'Inter', serif; font-size: 0.9rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold); text-decoration: none; margin-bottom: 1.5rem;">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 3L5 9l6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Wszystkie cykle
        </a>
        <h1 class="section-title gold-shimmer" style="font-size: clamp(2rem, 6vw, 3.5rem); margin-bottom:1.5rem;">
          {cycle.data.title}
        </h1>
        <p style="font-family:var(--font-heading),serif; font-style:italic; font-size:clamp(1rem, 2.2vw, 1.2rem); color:rgba(232,201,122,0.7); max-width:600px; margin:0 auto; line-height:1.75;">
          {cycle.data.description}
        </p>
      </div>
    </div>

    <!-- Lista artykułów w cyklu -->
    <div style="background: var(--parchment); padding: clamp(3rem, 8vw, 5rem) clamp(1.25rem, 5vw, 3rem);">
      <div style="max-width: 800px; margin: 0 auto;">
        
        <ol class="cycle-article-list">
          {cycle.articles.map((art, index) => (
            <li class="cycle-article-item">
              <span class="item-number">{index + 1}.</span>
              <div class="item-content">
                <a href={art.href} target={art.target} rel={art.rel} class="item-title">
                  {art.data.title}
                </a>
                <span class="item-meta">{art.data.dateDisplay} · {art.data.source}</span>
              </div>
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0; color: var(--gold);"><path d="M5 12l5-5-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </li>
          ))}
        </ol>

      </div>
    </div>
  </div>
</Layout>

<style>
  .cycle-article-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid rgba(201,168,76,0.3);
  }
  .cycle-article-item {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid rgba(201,168,76,0.3);
    transition: background 0.2s;
  }
  .item-number {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: var(--gold);
    min-width: 2rem;
    text-align: center;
  }
  .item-content {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .item-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.2rem, 3vw, 1.5rem);
    color: var(--ink-deep);
    text-decoration: none;
    line-height: 1.3;
    transition: color 0.2s;
  }
  .item-title:hover {
    color: var(--gold);
  }
  .item-meta {
    font-family: 'Inter', serif;
    font-size: 0.9rem;
    color: var(--text-muted);
  }
</style>
