---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { processArticles } from '../../data/articleHelpers';

const allArticles = await getCollection('articles');
const allCycles = await getCollection('cycles');
const { cycles } = processArticles(allArticles, allCycles);
---

<Layout title="Cykle Artykułów" description="Przeglądaj nasze publikacje w ujęciu cyklowym.">
  <div class="page-transition">
    
    <div class="page-hero">
      <div style="position:relative; z-index:2; max-width:800px; margin:0 auto;">
        <p class="section-label" style="color: rgba(201,168,76,0.65); margin-bottom:1rem;">Zagłęb się w temat</p>
        <h1 class="section-title gold-shimmer" style="font-size: clamp(2rem, 6vw, 3.5rem); margin-bottom:1.5rem;">
          Cykle Artykułów
        </h1>
        <div class="section-ornament" style="margin-top:2rem; margin-bottom:0;">
          <div class="section-ornament-line"></div>
          <svg width="12" height="12" viewBox="0 0 16 16" fill="#C9A84C">
            <path d="M8 1l1.8 4.4L14.4 6l-3.2 3.1.75 4.4L8 11.4l-3.95 2.1.75-4.4L1.6 6l4.6-.6L8 1z" />
          </svg>
          <div class="section-ornament-line"></div>
        </div>
      </div>
    </div>

    <!-- Siatka Kafelków -->
    <div style="background: var(--parchment); padding: clamp(3rem, 8vw, 5rem) clamp(1.25rem, 5vw, 3rem);">
      <div style="max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem;">
        
        {cycles.map(cycle => (
          <a href={cycle.href} class="cycle-tile">
            <h2 class="cycle-tile-title">{cycle.data.title}</h2>
            <p class="cycle-tile-desc">{cycle.data.description}</p>
            <div class="cycle-tile-footer">
              <span>{cycle.articles.length} {cycle.articles.length === 1 ? 'część' : 'części'}</span>
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5-5-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </a>
        ))}

      </div>
    </div>

  </div>
</Layout>

<style>
  .cycle-tile {
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border: 1px solid rgba(201,168,76,0.2);
    padding: 2rem;
    text-decoration: none;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .cycle-tile:hover {
    transform: translateY(-5px);
    border-color: var(--gold);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }
  .cycle-tile-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    color: var(--ink-deep);
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .cycle-tile-desc {
    font-family: 'Crimson Pro', serif;
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex-grow: 1;
    margin-bottom: 1.5rem;
  }
  .cycle-tile-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: 'Crimson Pro', serif;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    color: var(--gold);
    text-transform: uppercase;
    border-top: 1px solid rgba(201,168,76,0.15);
    padding-top: 1rem;
  }
</style>
