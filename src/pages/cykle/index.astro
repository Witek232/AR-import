---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { processArticles } from '../../data/articleHelpers';

const allArticles = await getCollection('articles');
const allCycles = await getCollection('cycles');
const { cycles } = processArticles(allArticles, allCycles);
---

<Layout title="Cykle Artykułów" description="Przeglądaj nasze publikacje w ujęciu cyklowym.">
  <div class="page-transition">
    
    <div class="page-hero">
      <div style="position:relative; z-index:2; max-width:800px; margin:0 auto;">
        <p class="section-label" style="color: rgba(201,168,76,0.65); margin-bottom:1rem;">Zagłęb się w temat</p>
        <h1 class="section-title gold-shimmer" style="font-size: clamp(2rem, 6vw, 3.5rem); margin-bottom:1.5rem;">
          Cykle Artykułów
        </h1>
        <div class="section-ornament" style="margin-top:2rem; margin-bottom:0;">
          <div class="section-ornament-line"></div>
          <svg width="12" height="12" viewBox="0 0 16 16" fill="#C9A84C">
            <path d="M8 1l1.8 4.4L14.4 6l-3.2 3.1.75 4.4L8 11.4l-3.95 2.1.75-4.4L1.6 6l4.6-.6L8 1z" />
          </svg>
          <div class="section-ornament-line"></div>
        </div>
      </div>
    </div>

    <!-- Lista cykli — jeden pod drugim -->
    <div style="background: var(--parchment); padding: clamp(3rem, 8vw, 5rem) clamp(1.25rem, 5vw, 3rem);">
      <div style="max-width: 900px; margin: 0 auto; display: flex; flex-direction: column; gap: clamp(1.25rem, 3vw, 1.75rem);">
        
        {cycles.map((cycle, index) => (
          <a href={cycle.href} class="cycle-tile">
            
            <!-- Numer + treść -->
            <div class="cycle-tile-number">
              {String(index + 1).padStart(2, '0')}
            </div>

            <div class="cycle-tile-body">
              <h2 class="cycle-tile-title">{cycle.data.title}</h2>
              <p class="cycle-tile-desc">{cycle.data.description}</p>
            </div>

            <!-- Meta + strzałka -->
            <div class="cycle-tile-meta">
              <span class="cycle-tile-count">
                {cycle.articles.length} {cycle.articles.length === 1 ? 'część' : 'części'}
              </span>
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" class="cycle-tile-arrow">
                <path d="M7 4l8 8-8 8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>

          </a>
        ))}

      </div>
    </div>

  </div>
</Layout>

<style>
  .cycle-tile {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: clamp(1.25rem, 3vw, 2rem);
    align-items: center;
    background: var(--bg, #EDE0C4);
    border: 1px solid rgba(201,168,76,0.2);
    padding: clamp(1.5rem, 3.5vw, 2.5rem);
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
  }

  .cycle-tile:hover {
    transform: translateY(-4px);
    border-color: var(--gold, #C9A84C);
    box-shadow: 0 10px 30px rgba(26,18,9,0.12);
  }

  .cycle-tile:hover .cycle-tile-title {
    color: var(--gold, #C9A84C);
  }

  .cycle-tile:hover .cycle-tile-number {
    color: var(--gold, #C9A84C);
  }

  .cycle-tile:hover .cycle-tile-arrow {
    stroke: var(--gold, #C9A84C);
    transform: translateX(4px);
  }

  /* Numer */
  .cycle-tile-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 300;
    color: rgba(201,168,76,0.35);
    line-height: 1;
    min-width: clamp(2.5rem, 6vw, 3.5rem);
    text-align: center;
    transition: color 0.3s ease;
  }

  /* Treść */
  .cycle-tile-body {
    flex: 1;
    min-width: 0;
  }

  .cycle-tile-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.25rem, 3.5vw, 1.75rem);
    font-weight: 400;
    color: var(--ink-deep, #1A1209);
    line-height: 1.25;
    margin-bottom: 0.5rem;
    transition: color 0.3s ease;
  }

  .cycle-tile-desc {
    font-family: 'Crimson Pro', serif;
    font-style: italic;
    font-size: clamp(0.9rem, 2.2vw, 1rem);
    color: rgba(26,18,9,0.5);
    line-height: 1.65;
    margin: 0;
  }

  /* Meta */
  .cycle-tile-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .cycle-tile-count {
    font-family: 'Crimson Pro', serif;
    font-size: clamp(0.72rem, 1.8vw, 0.82rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold, #C9A84C);
    white-space: nowrap;
  }

  .cycle-tile-arrow {
    stroke: rgba(201,168,76,0.4);
    transition: stroke 0.3s ease, transform 0.3s ease;
  }

  /* Responsive */
  @media (max-width: 600px) {
    .cycle-tile {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .cycle-tile-number {
      font-size: 1.5rem;
      text-align: left;
    }

    .cycle-tile-meta {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding-top: 1rem;
      border-top: 1px solid rgba(201,168,76,0.15);
    }
  }
</style>
