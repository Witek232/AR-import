---
import Layout from '../layouts/Layout.astro';

const albums = [
  {
    id: 'spotkania',
    title: 'Spotkania i seminaria',
    year: '2006–2024',
    count: 48,
    cover: 'https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=600&q=70',
    photos: [
      { src: 'https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=1200&q=80', caption: 'Wykład inauguracyjny — Ateny Roztocza 2006' },
      { src: 'https://images.unsplash.com/photo-1491975474562-1f4e30bc9468?w=1200&q=80', caption: 'Seminarium filozoficzne — Roztocze 2018' },
      { src: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=1200&q=80', caption: 'Ks. prof. Tadeusz Guz podczas wykładu' },
      { src: 'https://images.unsplash.com/photo-1517048676732-d65bc937f952?w=1200&q=80', caption: 'Dyskusja po seminarium — 2022' },
      { src: 'https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=1200&q=80', caption: 'Konferencja naukowa — Lublin 2023' },
      { src: 'https://images.unsplash.com/photo-1475721027785-f74eccf877e2?w=1200&q=80', caption: 'Spotkanie z uczestnikami projektu' },
    ],
  },
  {
    id: 'roztocze',
    title: 'Roztocze — przestrzeń projektu',
    year: '2010–2024',
    count: 32,
    cover: 'https://images.unsplash.com/photo-1501854140801-50d01698950b?w=600&q=70',
    photos: [
      { src: 'https://images.unsplash.com/photo-1501854140801-50d01698950b?w=1200&q=80', caption: 'Roztocze — wschód słońca nad doliną' },
      { src: 'https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=1200&q=80', caption: 'Las bukowy — natura w służbie kontemplacji' },
      { src: 'https://images.unsplash.com/photo-1470770841072-f978cf4d019e?w=1200&q=80', caption: 'Roztocze — wieczorny krajobraz' },
      { src: 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1200&q=80', caption: 'Widok na okolice centrum projektu' },
    ],
  },
];
---

<Layout
  title="Galeria"
  description="Archiwum fotograficzne projektu Ateny Roztocza — ludzie, miejsca, chwile z ponad 20 lat działalności."
>
  <div class="page-transition">

    <!-- Hero -->
    <div class="page-hero">
      <div style="position:relative; z-index:2; max-width:700px; margin:0 auto;">
        <p style="font-family:'Crimson Pro',serif; font-size:clamp(0.65rem,1.5vw,0.75rem); letter-spacing:0.35em; text-transform:uppercase; color:rgba(201,168,76,0.65); margin-bottom:1.25rem;">
          Archiwum fotograficzne
        </p>
        <h1 class="section-title gold-shimmer" style="font-size:clamp(2.4rem,7vw,4.8rem); margin-bottom:1rem;">
          Galeria
        </h1>
        <p style="font-family:'IM Fell English',serif; font-style:italic; font-size:clamp(1rem,2.2vw,1.25rem); color:rgba(232,201,122,0.7);">
          Obrazy z historii projektu — ludzie, miejsca, chwile
        </p>
      </div>
    </div>

    <!-- Content -->
    <div style="background:#F5EDD8; min-height:60vh; padding:clamp(2.5rem,5vw,4rem) clamp(1.25rem,4vw,2rem);">
      <div style="max-width:1200px; margin:0 auto;">

        <!-- Back button — hidden initially -->
        <button
          id="back-btn"
          style="display:none; align-items:center; gap:0.5rem; font-family:'Crimson Pro',serif; font-size:clamp(0.88rem,2vw,0.95rem); letter-spacing:0.08em; text-transform:uppercase; background:none; border:none; cursor:pointer; color:rgba(26,18,9,0.5); margin-bottom:2.5rem; padding:0.5rem 0; min-height:44px; transition:color 0.2s;"
        >
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 16 16">
            <path d="M12 8H4M7 4L3 8l4 4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Powrót do albumów
        </button>

        <!-- Album list — visible initially -->
        <div
          id="album-list"
          style="display:grid; grid-template-columns:repeat(auto-fill,minmax(min(100%,320px),1fr)); gap:clamp(1.5rem,3vw,2.5rem);"
        >
          {albums.map((album) => (
            <div
              class="album-card card-hover gold-border-hover"
              data-album-id={album.id}
              style="cursor:pointer; background:#EDE0C4; border:1px solid rgba(26,18,9,0.08); overflow:hidden; position:relative;"
            >
              <div style="position:relative; padding-bottom:65%; overflow:hidden;">
                <img
                  src={album.cover}
                  alt={album.title}
                  class="sepia-filter"
                  style="position:absolute; top:0; left:0; width:100%; height:100%; object-fit:cover;"
                />
                <div style="position:absolute; bottom:0; left:0; right:0; background:linear-gradient(to top,rgba(26,18,9,0.7),transparent); padding:1.5rem 1.25rem 0.75rem;">
                  <span style="font-family:'Crimson Pro',serif; font-size:0.72rem; letter-spacing:0.18em; text-transform:uppercase; color:rgba(232,201,122,0.8);">
                    {album.count} fotografii · {album.year}
                  </span>
                </div>
              </div>
              <div style="padding:clamp(1rem,2.5vw,1.5rem);">
                <h3 style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.15rem,3vw,1.5rem); font-weight:400; color:#1A1209; margin:0;">
                  {album.title}
                </h3>
                <p style="font-family:'Crimson Pro',serif; font-size:0.88rem; color:rgba(26,18,9,0.45); margin-top:0.4rem; font-style:italic;">
                  Kliknij, aby przeglądać zdjęcia
                </p>
              </div>
            </div>
          ))}
        </div>

        <!-- Photo grid header — hidden initially -->
        <div id="pg-header" style="display:none; margin-bottom:2.5rem;">
          <h2 id="pg-title" class="section-title" style="color:#1A1209; margin-bottom:0.35rem;"></h2>
          <p id="pg-subtitle" style="font-family:'Crimson Pro',serif; font-size:clamp(0.88rem,2vw,0.98rem); color:rgba(26,18,9,0.45); font-style:italic;"></p>
        </div>

        <!-- Photo grid — hidden initially, populated by JS -->
        <div
          id="photo-grid"
          style="display:none; grid-template-columns:repeat(auto-fill,minmax(min(100%,260px),1fr)); gap:clamp(0.75rem,2vw,1.25rem);"
        ></div>

      </div>
    </div>

  </div>

  <!-- ── LIGHTBOX ── hidden initially -->
  <div
    id="lightbox"
    role="dialog"
    aria-modal="true"
    tabindex="-1"
    style="display:none; position:fixed; inset:0; background:rgba(7,5,2,0.97); z-index:3000; flex-direction:column; align-items:center; justify-content:center;"
  >
    <!-- Top bar -->
    <div style="position:absolute; top:0; left:0; right:0; display:flex; align-items:center; justify-content:space-between; padding:clamp(0.75rem,2vw,1.25rem) clamp(1rem,3vw,2rem); background:linear-gradient(to bottom,rgba(7,5,2,0.9),transparent); z-index:10;">
      <span id="lb-counter" style="font-family:'Cormorant Garamond',serif; font-size:clamp(1rem,2.5vw,1.3rem); color:rgba(201,168,76,0.8); letter-spacing:0.15em;"></span>
      <span class="lb-kbd-hint" style="font-family:'Crimson Pro',serif; font-size:0.72rem; letter-spacing:0.12em; color:rgba(201,168,76,0.3);">
        ← → nawigacja &nbsp;·&nbsp; ESC zamknij
      </span>
      <button id="lb-close" aria-label="Zamknij lightbox" style="background:rgba(201,168,76,0.12); border:1px solid rgba(201,168,76,0.25); border-radius:50%; width:44px; height:44px; display:flex; align-items:center; justify-content:center; cursor:pointer; color:rgba(232,201,122,0.75); font-size:1.1rem; transition:all 0.2s; flex-shrink:0;">✕</button>
    </div>

    <!-- Arrows + main image -->
    <div style="display:flex; align-items:center; justify-content:center; width:100%; height:100%; padding:clamp(4rem,8vw,5.5rem) clamp(0.5rem,2vw,1rem) clamp(7rem,14vw,9rem); gap:clamp(0.5rem,2vw,1.5rem); box-sizing:border-box;">
      <button id="lb-prev" aria-label="Poprzednie zdjęcie" class="lb-arrow">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <polyline points="15 18 9 12 15 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div style="flex:1; display:flex; align-items:center; justify-content:center; max-width:min(900px,calc(100vw - clamp(120px,18vw,200px))); max-height:100%;">
        <img id="lb-img" src="" alt="" class="sepia-filter"
          style="max-width:100%; max-height:100%; object-fit:contain; display:block; box-shadow:0 8px 60px rgba(0,0,0,0.7);" />
      </div>

      <button id="lb-next" aria-label="Następne zdjęcie" class="lb-arrow">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <polyline points="9 18 15 12 9 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <!-- Caption + thumbnails -->
    <div style="position:absolute; bottom:0; left:0; right:0; background:linear-gradient(to top,rgba(7,5,2,0.97) 0%,rgba(7,5,2,0.85) 60%,transparent 100%); padding:clamp(1.5rem,4vw,2.5rem) clamp(1rem,4vw,3rem) clamp(1rem,3vw,1.75rem); z-index:10;">
      <p id="lb-caption" style="font-family:'IM Fell English',serif; font-style:italic; font-size:clamp(0.9rem,2vw,1.1rem); color:rgba(232,201,122,0.75); text-align:center; margin-bottom:clamp(0.75rem,2vw,1.25rem); line-height:1.5;"></p>
      <div id="lb-thumbs" style="display:flex; gap:clamp(0.35rem,1vw,0.6rem); justify-content:center; flex-wrap:nowrap; overflow-x:auto; scrollbar-width:none; padding-bottom:2px;"></div>
    </div>
  </div>

</Layout>

<style>
  .lb-kbd-hint { display: none; }
  @media (min-width: 640px) { .lb-kbd-hint { display: block; } }

  .lb-arrow {
    flex-shrink: 0;
    width: clamp(44px, 7vw, 64px);
    height: clamp(44px, 7vw, 64px);
    border-radius: 50%;
    background: rgba(201, 168, 76, 0.13);
    border: 1.5px solid rgba(201, 168, 76, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.22s;
    color: #E8C97A;
    z-index: 10;
  }
  .lb-arrow:hover {
    background: rgba(201, 168, 76, 0.28);
    border-color: rgba(201, 168, 76, 0.7);
    transform: scale(1.08);
  }
  #lb-close:hover { background: rgba(201,168,76,0.25) !important; color: #E8C97A !important; }
  #back-btn:hover { color: #C9A84C !important; }

  @keyframes fadeInPhoto {
    from { opacity: 0; transform: scale(0.97); }
    to   { opacity: 1; transform: scale(1); }
  }
  .lb-fade { animation: fadeInPhoto 0.25s ease; }
</style>

<script define:vars={{ albums }}>
  // ── State ─────────────────────────────────────────────────
  let activeAlbumId = null;
  let lightboxIndex = null;

  // ── DOM refs ──────────────────────────────────────────────
  const albumListEl = document.getElementById('album-list');
  const backBtn     = document.getElementById('back-btn');
  const pgHeader    = document.getElementById('pg-header');
  const pgTitle     = document.getElementById('pg-title');
  const pgSubtitle  = document.getElementById('pg-subtitle');
  const photoGrid   = document.getElementById('photo-grid');
  const lightbox    = document.getElementById('lightbox');
  const lbImg       = document.getElementById('lb-img');
  const lbCaption   = document.getElementById('lb-caption');
  const lbCounter   = document.getElementById('lb-counter');
  const lbThumbs    = document.getElementById('lb-thumbs');

  function getAlbum(id) { return albums.find(a => a.id === id) ?? null; }
  function getActive()  { return getAlbum(activeAlbumId); }

  // ── Album navigation ───────────────────────────────────────
  function openAlbum(id) {
    const album = getAlbum(id);
    if (!album) return;
    activeAlbumId = id;

    backBtn.style.display      = 'flex';
    albumListEl.style.display  = 'none';
    pgTitle.textContent        = album.title;
    pgSubtitle.textContent     = `${album.photos.length} fotografii · ${album.year} · kliknij zdjęcie aby powiększyć`;
    pgHeader.style.display     = 'block';

    // Build photo grid
    photoGrid.innerHTML = '';
    album.photos.forEach((photo, i) => {
      const cell = document.createElement('div');
      cell.className = 'card-hover';
      cell.style.cssText = `cursor:pointer; overflow:hidden; position:relative; aspect-ratio:${i % 3 === 0 ? '4/3' : '1/1'}; border-radius:2px;`;
      cell.innerHTML = `
        <img src="${photo.src}" alt="${photo.caption}" class="sepia-filter" loading="lazy"
          style="width:100%; height:100%; object-fit:cover; display:block; transition:transform 0.4s ease;" />
        <div style="position:absolute; bottom:0; left:0; right:0; background:linear-gradient(to top,rgba(13,10,5,0.85) 0%,rgba(13,10,5,0.4) 60%,transparent 100%); padding:2rem 0.85rem 0.75rem;">
          <p style="font-family:'Crimson Pro',serif; font-style:italic; font-size:clamp(0.78rem,1.8vw,0.86rem); color:rgba(232,201,122,0.9); margin:0; line-height:1.4;">${photo.caption}</p>
        </div>
        <div style="position:absolute; top:0.6rem; right:0.6rem; background:rgba(13,10,5,0.55); border-radius:50%; width:32px; height:32px; display:flex; align-items:center; justify-content:center;">
          <svg width="14" height="14" fill="none" stroke="rgba(232,201,122,0.85)" stroke-width="1.5" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35" stroke-linecap="round"/>
            <path d="M11 8v6M8 11h6" stroke-linecap="round"/>
          </svg>
        </div>`;
      cell.addEventListener('click', () => openLightbox(i));
      photoGrid.appendChild(cell);
    });

    photoGrid.style.display = 'grid';
    pgHeader.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function closeAlbum() {
    activeAlbumId = null;
    closeLightbox();
    backBtn.style.display      = 'none';
    albumListEl.style.display  = 'grid';
    pgHeader.style.display     = 'none';
    photoGrid.style.display    = 'none';
    photoGrid.innerHTML        = '';
  }

  // ── Lightbox ───────────────────────────────────────────────
  function openLightbox(index) {
    const album = getActive();
    if (!album) return;
    lightboxIndex = index;
    document.body.style.overflow = 'hidden';
    lightbox.style.display       = 'flex';
    renderPhoto();
    buildThumbs();
    lightbox.focus();
  }

  function closeLightbox() {
    lightboxIndex = null;
    document.body.style.overflow = '';
    lightbox.style.display       = 'none';
  }

  function goPrev() {
    const album = getActive();
    if (!album || lightboxIndex === null) return;
    lightboxIndex = (lightboxIndex - 1 + album.photos.length) % album.photos.length;
    renderPhoto();
    syncThumbs();
  }

  function goNext() {
    const album = getActive();
    if (!album || lightboxIndex === null) return;
    lightboxIndex = (lightboxIndex + 1) % album.photos.length;
    renderPhoto();
    syncThumbs();
  }

  function renderPhoto() {
    const album = getActive();
    if (!album || lightboxIndex === null) return;
    const photo = album.photos[lightboxIndex];
    lbImg.src = photo.src;
    lbImg.alt = photo.caption;
    lbImg.className = 'sepia-filter lb-fade';
    void lbImg.offsetWidth; // reset animation
    lbCaption.textContent = photo.caption;
    lbCounter.innerHTML   = `${String(lightboxIndex + 1).padStart(2,'0')}<span style="color:rgba(201,168,76,0.35);margin:0 0.4rem;">/</span>${String(album.photos.length).padStart(2,'0')}`;
    lightbox.setAttribute('aria-label', `Zdjęcie ${lightboxIndex + 1} z ${album.photos.length}: ${photo.caption}`);
  }

  function buildThumbs() {
    const album = getActive();
    if (!album) return;
    lbThumbs.innerHTML = '';
    album.photos.forEach((ph, i) => {
      const btn = document.createElement('button');
      btn.setAttribute('aria-label', `Zdjęcie ${i + 1}: ${ph.caption}`);
      btn.style.cssText = 'flex-shrink:0; padding:0; border-radius:2px; overflow:hidden; cursor:pointer; background:none; outline:none; transition:all 0.2s ease;';
      btn.style.width   = 'clamp(44px,8vw,64px)';
      btn.style.height  = 'clamp(34px,6vw,48px)';
      const img = document.createElement('img');
      img.src = ph.src.replace('w=1200','w=120');
      img.alt = '';
      img.className = 'sepia-filter';
      img.style.cssText = 'width:100%; height:100%; object-fit:cover; display:block;';
      btn.appendChild(img);
      btn.addEventListener('click', () => { lightboxIndex = i; renderPhoto(); syncThumbs(); });
      lbThumbs.appendChild(btn);
    });
    syncThumbs();
  }

  function syncThumbs() {
    lbThumbs.querySelectorAll('button').forEach((btn, i) => {
      const active = i === lightboxIndex;
      btn.style.border    = active ? '2px solid #C9A84C'               : '2px solid rgba(201,168,76,0.2)';
      btn.style.opacity   = active ? '1'                               : '0.5';
      btn.style.transform = active ? 'scale(1.1)'                      : 'scale(1)';
    });
  }

  // ── Event wiring ───────────────────────────────────────────
  document.querySelectorAll('.album-card').forEach(card => {
    card.addEventListener('click', () => openAlbum(card.dataset.albumId));
  });

  backBtn.addEventListener('click', closeAlbum);
  document.getElementById('lb-close').addEventListener('click', closeLightbox);
  document.getElementById('lb-prev').addEventListener('click', goPrev);
  document.getElementById('lb-next').addEventListener('click', goNext);

  // Close on backdrop
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });

  // Keyboard
  window.addEventListener('keydown', (e) => {
    if (lightboxIndex === null) return;
    if (e.key === 'Escape')     closeLightbox();
    if (e.key === 'ArrowLeft')  goPrev();
    if (e.key === 'ArrowRight') goNext();
  });
</script>

Fix 2 — src/lib/sanity.ts (wymagany stub)
Plik musi istnieć przed buildem. Jeśli Sanity nie jest jeszcze skonfigurowane, użyj stubów zwracających puste dane — strony zbudują się poprawnie:
typescript// src/lib/sanity.ts
// ── Konfiguracja ──────────────────────────────────────────────
// Zamień na właściwe wartości po skonfigurowaniu Sanity Studio

import { createClient } from '@sanity/client';

const client = createClient({
  projectId: import.meta.env.SANITY_PROJECT_ID ?? 'YOUR_PROJECT_ID',
  dataset:   import.meta.env.SANITY_DATASET    ?? 'production',
  apiVersion: '2024-01-01',
  useCdn: true,
});

// ── Typy ──────────────────────────────────────────────────────

export interface Czesc {
  youtubeId:   string;
  label?:      string;
  czas?:       string;
  opisCzesci?: string;
}

export interface Material {
  _id:          string;
  tytul:        string;
  slug:         { current: string };
  rok:          number;
  data?:        string;
  kategoria?:   string;
  miejsce?:     string;
  tagi?:        string[];
  opis?:        { _type: string; children?: { text: string }[] }[];
  czesci:       Czesc[];
  liczbaCzesci: number;
}

// ── Queries ───────────────────────────────────────────────────

/**
 * Zwraca posortowaną malejąco tablicę lat, dla których istnieją materiały.
 */
export async function getLataArchiwum(): Promise<number[]> {
  try {
    const lata = await client.fetch<number[]>(
      `array::unique(*[_type == "material"].rok) | order(@  desc)`
    );
    return lata ?? [];
  } catch {
    // Gdy Sanity nie jest jeszcze skonfigurowane — zwróć puste
    return [];
  }
}

/**
 * Zwraca wszystkie materiały dla danego roku, posortowane malejąco po dacie.
 */
export async function getMaterialyRoku(rok: number): Promise<Material[]> {
  try {
    return await client.fetch<Material[]>(
      `*[_type == "material" && rok == $rok] | order(data desc) {
        _id, tytul, slug, rok, data, kategoria, miejsce, tagi,
        "liczbaCzesci": count(czesci),
        czesci[]{ youtubeId, label, czas, opisCzesci }
      }`,
      { rok }
    );
  } catch {
    return [];
  }
}

/**
 * Zwraca pojedynczy materiał po roku i slugu.
 */
export async function getMaterial(rok: number, slug: string): Promise<Material | null> {
  try {
    const result = await client.fetch<Material | null>(
      `*[_type == "material" && rok == $rok && slug.current == $slug][0] {
        _id, tytul, slug, rok, data, kategoria, miejsce, tagi, opis,
        "liczbaCzesci": count(czesci),
        czesci[]{ youtubeId, label, czas, opisCzesci }
      }`,
      { rok, slug }
    );
    return result ?? null;
  } catch {
    return null;
  }
}
