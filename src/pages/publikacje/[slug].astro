---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { processArticles, getCycleNavigation } from '../../data/articleHelpers';

export async function getStaticPaths() {
  const allArticles = await getCollection('articles');
  const allCycles = await getCollection('cycles');
  const { cycles } = processArticles(allArticles, allCycles);

  return allArticles.map(article => {
    const slug = article.id.replace(/\.md$/, '');
    return {
      params: { slug: slug },
      props: { article, cycles },
    };
  });
}

const { article, cycles } = Astro.props;
const { Content } = await render(article);

const { prev, next, cycleData } = getCycleNavigation(article, cycles);
---

<Layout title={article.data.title} description={article.data.excerpt}>
  <div class="page-transition">

    <!-- ── HERO ────────────────────────────────────────────── -->
    <div class="page-hero">
      <div style="position:relative; z-index:2; max-width:800px; margin:0 auto;">
        
        {cycleData && (
          <a href={cycleData.href} class="section-label" style="color: rgba(201,168,76,0.65); margin-bottom:1rem; text-decoration:none; display:block; transition: color 0.2s;" onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='rgba(201,168,76,0.65)'">
            Cykl: {cycleData.data.title}
          </a>
        )}

        <p class="section-label" style="color: rgba(201,168,76,0.65); margin-bottom:1rem;">
          {article.data.dateDisplay} · {article.data.source}
        </p>
        
        <h1 class="section-title gold-shimmer" style="font-size: clamp(2rem, 6vw, 3.5rem); margin-bottom:1.5rem;">
          {article.data.title}
        </h1>
        
        {article.data.excerpt && (
          <p style="font-family:'Charm'; font-style:italic; font-size:clamp(1rem, 2.2vw, 1.2rem); color:rgba(232,201,122,0.7); max-width:600px; margin:0 auto; line-height:1.75;">
            {article.data.excerpt}
          </p>
        )}

        <div class="section-ornament" style="margin-top:2rem; margin-bottom:0;">
          <div class="section-ornament-line"></div>
          <svg width="12" height="12" viewBox="0 0 16 16" fill="#C9A84C">
            <path d="M8 1l1.8 4.4L14.4 6l-3.2 3.1.75 4.4L8 11.4l-3.95 2.1.75-4.4L1.6 6l4.6-.6L8 1z" />
          </svg>
          <div class="section-ornament-line"></div>
        </div>

      </div>
    </div>

    <!-- ── TREŚĆ ARTYKUŁU ──────────────────────────────────── -->
    <div style="background: var(--parchment); position: relative;">
      <article class="article-prose" style="max-width: 800px; margin: 0 auto; padding: clamp(3rem, 8vw, 5rem) clamp(1.25rem, 5vw, 3rem);">
        <Content />
      </article>

      {/* ── PRZYCISK LINKU ZEWNĘTRZNEGO ── */}
      {article.data.externalLink && (
        <div style="max-width: 800px; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 3rem) clamp(3rem, 8vw, 5rem); text-align: center;">
          <div class="gold-hr" style="margin-bottom: 2rem;"></div>
          <a href={article.data.externalLink} target="_blank" rel="noopener noreferrer" class="card-hover" style="display: inline-flex; align-items: center; gap: 0.75rem; padding: 1rem 2.5rem; background: var(--ink); color: var(--gold-light); text-decoration: none; font-family: 'Crimson Pro', serif; letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.95rem; border: 1px solid rgba(201,168,76,0.3);">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;"><path d="M7 17L17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Przejdź do oryginalnego artykułu
          </a>
        </div>
      )}

      {/* ── NAWIGACJA CYKLU ── */}
      {cycleData && (
        <div style="max-width: 800px; margin: 0 auto; padding: clamp(2rem, 5vw, 3rem) clamp(1.25rem, 5vw, 3rem); border-top: 1px solid rgba(201,168,76,0.3);">
          
          <div class="gold-hr" style="margin-bottom: 2rem;"></div>
          
          <div style="display: flex; flex-direction: column; gap: 1.5rem; text-align: center;">
            
            {next ? (
              <a href={next.href} target={next.target} rel={next.rel} style="display: inline-flex; align-items: center; justify-content: center; gap: 0.75rem; padding: 1rem 2.5rem; background: var(--ink); color: var(--gold-light); text-decoration: none; font-family: 'Crimson Pro', serif; letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.95rem; border: 1px solid rgba(201,168,76,0.3); transition: background 0.2s;" onmouseover="this.style.background='var(--ink-deep)'" onmouseout="this.style.background='var(--ink)'">
                Następna część cyklu
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5-5-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            ) : (
              <div style="font-family: 'Charm', serif; font-style: italic; color: var(--gold); font-size: 1.1rem; margin-bottom: 1rem;">
                ✦ To jest ostatnia część tego cyklu ✦
              </div>
            )}

            <a href={cycleData.href} style="display: inline-flex; align-items: center; gap: 0.5rem; font-family: 'Crimson Pro', serif; font-size: 0.9rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--text-muted)'">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 3L5 9l6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Zobacz spis treści cyklu
            </a>
          </div>

        </div>
      )}

      {/* ── POWRÓT DO LISTY ── */}
      <div style="max-width: 800px; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 3rem) clamp(3rem, 8vw, 5rem);">
        <a href="/multimedia" style="display: inline-flex; align-items: center; gap: 0.5rem; font-family: 'Crimson Pro', serif; font-size: 0.95rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--text-muted)'">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 3L5 9l6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Powrót do publikacji
        </a>
      </div>
    </div>

  </div>
</Layout>

<style>
  /* ── SPECJALNE STYLOWANIE DLA MARKDOWN (PROSE) ── */
  .article-prose :global(h2) {
    font-family: 'Playfair Display', serif;
    font-weight: 400;
    font-size: clamp(2.1rem, 4.8vw, 2.7rem);  /* +20% */
    color: var(--ink);
    margin-top: 3.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(201,168,76,0.3);
    line-height: 1.2;
  }

  .article-prose :global(h3) {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: clamp(1.68rem, 3.6vw, 2.1rem);  /* +20% */
    color: var(--ink-deep);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .article-prose :global(p) {
    font-family: 'Crimson Pro', serif;
    font-size: clamp(1.0625rem, 2.5vw, 1.1875rem);
    line-height: 1.85;
    color: var(--text-dark);
    margin-bottom: 1.5rem;
    text-align: justify;
    hyphens: auto;
  }

  .article-prose :global(blockquote) {
    font-family: 'Charm', serif;
    font-style: italic;
    font-size: clamp(1.0625rem, 2.5vw, 1.1875rem);
    line-height: 1.85;
    color: var(--text-dark);
    border-left: 3px solid var(--gold);
    padding-left: clamp(1rem, 3vw, 1.5rem);
    margin: 2.5rem 0;
    background: rgba(201,168,76,0.03);
    padding-top: 1rem;
    padding-bottom: 1rem;
    padding-right: 1rem;
  }

  .article-prose :global(blockquote p) {
    margin-bottom: 0;
    font-family: 'Charm', serif;
    font-style: italic;
  }

  .article-prose :global(strong) {
    color: var(--ink-deep);
    font-weight: 600;
  }

  .article-prose :global(em) {
    color: var(--text-muted);
  }

  .article-prose :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gold), transparent);
    margin: 3rem 0;
    opacity: 0.5;
  }

  .article-prose :global(ul), .article-prose :global(ol) {
    font-family: 'Crimson Pro', serif;
    font-size: clamp(1.0625rem, 2.5vw, 1.1875rem);
    line-height: 1.85;
    color: var(--text-dark);
    padding-left: 2rem;
    margin-bottom: 1.5rem;
  }

  .article-prose :global(li) {
    margin-bottom: 0.5rem;
  }
</style>
