---
import Layout from '../../../layouts/Layout.astro';
import {
  years,
  multimediaData,
  getEntriesByYear,
  getEntry,
  categoryLabels,
  categoryColors,
} from '../../../data/multimediaData';

export function getStaticPaths() {
  return years.flatMap((rok) =>
    (multimediaData[rok] ?? []).map((entry) => ({
      params: { year: String(rok), slug: entry.slug },
    }))
  );
}

const { year, slug } = Astro.params;
const rok      = parseInt(year);
const entry    = getEntry(rok, slug);
const listRoku = getEntriesByYear(rok);
const idx      = listRoku.findIndex((e) => e.slug === slug);

const hasPrev    = idx < listRoku.length - 1;
const hasNext    = idx > 0;
const poprzedni  = hasPrev ? listRoku[idx + 1] : null;
const nastepny   = hasNext ? listRoku[idx - 1] : null;

const catColor     = entry ? categoryColors[entry.category] : '#C9A84C';
const catLabel     = entry ? categoryLabels[entry.category] : '';
const catMetaStyle = 'font-family:Crimson Pro,serif;font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;background:rgba(201,168,76,0.12);color:' + catColor + ';padding:0.25rem 0.75rem;border:1px solid ' + catColor + '55;';

const descParas = entry
  ? entry.description.trim().split('\n').filter((p) => p.trim().length > 0).map((p) => p.trim())
  : [];

const sidebarLinks = listRoku
  .filter((e) => e.slug !== slug)
  .slice(0, 8)
  .map((e) => ({
    href:     '/multimedia/' + rok + '/' + e.slug,
    catLabel: categoryLabels[e.category],
    catColor: categoryColors[e.category] + '99',
    title:    e.title,
  }));

const yearHref  = '/multimedia/' + rok;
const prevHref  = poprzedni ? '/multimedia/' + rok + '/' + poprzedni.slug : '';
const nextHref  = nastepny  ? '/multimedia/' + rok + '/' + nastepny.slug  : '';

const parts = entry?.parts ?? [];
const hasEntry = !!entry;
---

<Layout
  title={entry?.title ?? 'Materiał audiowizualny'}
  description={entry ? entry.title + ' · ' + rok + ' · Ateny Roztocza' : ''}
>

{!hasEntry && (
  <div style="background:#F5EDD8;min-height:60vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:5rem 2rem;">
    <div>
      <p style="font-family:'Cormorant Garamond',serif;font-size:2rem;color:rgba(26,18,9,0.3);">Materiał nie został znaleziony.</p>
      <a href={yearHref} style="color:#C9A84C;margin-top:1rem;display:inline-block;font-family:'Crimson Pro',serif;font-size:0.85rem;letter-spacing:0.15em;text-transform:uppercase;text-decoration:none;border-bottom:1px solid rgba(201,168,76,0.4);">
        ← Wróć do {rok}
      </a>
    </div>
  </div>
)}

{hasEntry && entry && (
  <div class="page-transition">

    <!-- HERO -->
    <section style="background:#1A1209;color:#F5EDD8;padding:clamp(4rem,10vw,7rem) clamp(1rem,4vw,2rem) clamp(2rem,5vw,3rem);">
      <div style="max-width:1100px;margin:0 auto;">
        <nav style="font-family:'Crimson Pro',serif;font-size:0.82rem;letter-spacing:0.1em;margin-bottom:1.75rem;">
          <a href="/multimedia" class="bc-link" style="color:rgba(201,168,76,0.6);text-decoration:none;">Multimedia</a>
          <span style="margin:0 0.6rem;color:rgba(201,168,76,0.25);">›</span>
          <a href={yearHref} class="bc-link" style="color:rgba(201,168,76,0.6);text-decoration:none;">{rok}</a>
          <span style="margin:0 0.6rem;color:rgba(201,168,76,0.25);">›</span>
          <span style="color:rgba(201,168,76,0.85);">{entry.title}</span>
        </nav>
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;margin-bottom:1.25rem;">
          <span style={catMetaStyle}>{catLabel}</span>
          <span style="font-size:0.85rem;color:rgba(245,237,216,0.5);">{entry.date}</span>
          {entry.place && (
            <span style="font-size:0.85rem;color:rgba(245,237,216,0.5);">📍 {entry.place}</span>
          )}
          {parts.length > 1 && (
            <span style="font-size:0.85rem;color:rgba(245,237,216,0.5);">▶ {parts.length} części</span>
          )}
        </div>
        <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(1.75rem,4vw,3.5rem);font-weight:400;line-height:1.2;color:#F5EDD8;margin-bottom:1.25rem;">
          {entry.title}
        </h1>
        {entry.tags && entry.tags.length > 0 && (
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
            {entry.tags.map((t) => (
              <span style="font-size:0.8rem;color:rgba(201,168,76,0.6);background:rgba(201,168,76,0.08);padding:0.2rem 0.65rem;border-radius:2px;">#{t}</span>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- TREŚĆ -->
    <section style="background:#0D0A05;padding:clamp(3rem,6vw,5rem) clamp(1rem,4vw,2rem);">
      <div class="entry-layout" style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 280px;gap:3rem;align-items:start;">

        <div>
          <div style="margin-bottom:2.5rem;padding-left:1.5rem;border-left:3px solid #C9A84C;">
            {descParas.map((para) => (
              <p style="font-family:'IM Fell English',serif;font-style:italic;font-size:1.05rem;color:rgba(245,237,216,0.8);line-height:1.8;margin-bottom:0.75rem;">{para}</p>
            ))}
          </div>

          {parts.length > 1 && (
            <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:#C9A84C;margin-bottom:1.75rem;font-weight:400;">Materiał wideo</h2>
          )}

          {parts.map((part, i) => {
            const partNum  = i < 9 ? '0' + (i + 1) : String(i + 1);
            const isFirst  = i === 0;
            const isMulti  = parts.length > 1;
            const thumbSrc = 'https://img.youtube.com/vi/' + part.id + '/maxresdefault.jpg';
            const errSrc   = 'https://img.youtube.com/vi/' + part.id + '/mqdefault.jpg';
            const altText  = isMulti ? entry.title + ' — ' + part.label : entry.title;
            return (
              <div style="margin-bottom:3rem;">
                {isMulti && (
                  <div style="display:flex;gap:1rem;align-items:flex-start;margin-bottom:1rem;padding-bottom:0.75rem;border-bottom:1px solid rgba(201,168,76,0.15);">
                    <span style="font-family:'Cormorant Garamond',serif;font-size:2.5rem;color:rgba(201,168,76,0.2);line-height:1;">{partNum}</span>
                    <div>
                      <h3 style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;color:#F5EDD8;margin-bottom:0.2rem;">{part.label}</h3>
                      <span style="font-size:0.8rem;color:rgba(245,237,216,0.4);">⏱ {part.duration}</span>
                    </div>
                  </div>
                )}
                {part.description && (
                  <p style="font-size:0.9rem;color:rgba(245,237,216,0.6);margin-bottom:1rem;font-style:italic;font-family:'Crimson Pro',serif;">{part.description}</p>
                )}
                <div class="yt-wrap" data-yt-id={part.id} style="position:relative;aspect-ratio:16/9;background:#000;cursor:pointer;overflow:hidden;border-radius:2px;">
                  <img
                    src={thumbSrc}
                    alt={altText}
                    loading={isFirst ? 'eager' : 'lazy'}
                    class="yt-thumb"
                    style="width:100%;height:100%;object-fit:cover;transition:transform 0.3s,filter 0.3s;"
                    onerror={'this.src=\'' + errSrc + '\''}
                  />
                  <div class="yt-play" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:72px;height:50px;background:rgba(255,0,0,0.92);border-radius:14px;display:flex;align-items:center;justify-content:center;pointer-events:none;transition:transform 0.2s,background 0.2s;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="white"><path d="M5 3l14 9-14 9V3z"/></svg>
                  </div>
                  <div style="position:absolute;bottom:0;left:0;right:0;padding:1rem;background:linear-gradient(transparent,rgba(0,0,0,0.7));display:flex;justify-content:space-between;align-items:flex-end;pointer-events:none;">
                    <span style="font-size:0.8rem;color:rgba(255,255,255,0.8);font-family:'Crimson Pro',serif;">▶ Kliknij aby odtworzyć</span>
                    <span style="font-size:0.8rem;color:rgba(255,255,255,0.7);">{part.duration}</span>
                  </div>
                </div>
              </div>
            );
          })}
        </div>

        <!-- Sidebar -->
        <aside style="position:sticky;top:90px;">
          <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(201,168,76,0.15);padding:1.5rem;">
            <h4 style="font-family:'Cormorant Garamond',serif;font-size:1rem;color:#C9A84C;margin-bottom:1rem;padding-bottom:0.75rem;border-bottom:1px solid rgba(201,168,76,0.15);">
              Inne z {rok}
            </h4>
            <ul style="list-style:none;padding:0;margin:0;">
              {sidebarLinks.map((link) => (
                <li style="margin-bottom:0.4rem;">
                  <a href={link.href} class="sidebar-link" style="display:flex;flex-direction:column;gap:0.1rem;text-decoration:none;padding:0.5rem;border-radius:2px;transition:background 0.2s;">
                    <span style={'font-size:0.65rem;text-transform:uppercase;letter-spacing:0.08em;color:' + link.catColor + ';'}>{link.catLabel}</span>
                    <span style="font-family:'Cormorant Garamond',serif;font-size:0.95rem;color:#F5EDD8;line-height:1.3;">{link.title}</span>
                  </a>
                </li>
              ))}
            </ul>
            <a href={yearHref} class="sidebar-back" style="display:block;margin-top:1rem;padding-top:0.75rem;border-top:1px solid rgba(201,168,76,0.15);font-size:0.85rem;color:#C9A84C;text-decoration:none;font-family:'Crimson Pro',serif;letter-spacing:0.08em;">
              ← Wszystkie z {rok}
            </a>
          </div>
        </aside>

      </div>
    </section>

    <!-- NAWIGACJA PREV / NEXT -->
<nav style="background:#0D0A05;border-top:1px solid rgba(201,168,76,0.12);padding:clamp(2rem,4vw,3rem) clamp(1rem,4vw,2rem);">
  <div class="entry-nav" style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr auto 1fr;gap:2rem;align-items:center;">

    <!-- LEWA STRONA: teraz Nowsze (←) -->
    <div>
      {nastepny && (
        <a href={nextHref} class="nav-link">
          <span class="nav-dir">← Nowsze</span>
          <span class="nav-title">{nastepny.title}</span>
        </a>
      )}
    </div>

    <a href={yearHref} class="nav-center">↑ {rok}</a>

    <!-- PRAWA STRONA: teraz Starsze (→) -->
    <div style="text-align:right;">
      {poprzedni && (
        <a href={prevHref} class="nav-link nav-next">
          <span class="nav-dir">Starsze →</span>
          <span class="nav-title">{poprzedni.title}</span>
        </a>
      )}
    </div>

  </div>
</nav>

  </div>
)}

</Layout>

<style>
  .bc-link:hover      { color: #C9A84C !important; }
  .sidebar-link:hover { background: rgba(201,168,76,0.07) !important; }
  .sidebar-back:hover { text-decoration: underline !important; }
  .yt-wrap:hover .yt-thumb { transform: scale(1.02); filter: brightness(0.6); }
  .yt-wrap:hover .yt-play  { background: #ff0000 !important; transform: translate(-50%,-50%) scale(1.08) !important; }
  .yt-iframe { position:absolute;inset:0;width:100%;height:100%;border:none; }
  .nav-link  { display:flex;flex-direction:column;gap:0.25rem;text-decoration:none;color:#F5EDD8;padding:1rem;border:1px solid rgba(201,168,76,0.15);transition:all 0.2s; }
  .nav-link:hover { border-color:#C9A84C;background:rgba(201,168,76,0.05); }
  .nav-next  { text-align:right; }
  .nav-dir   { font-size:0.75rem;color:#C9A84C;letter-spacing:0.1em;font-family:'Crimson Pro',serif; }
  .nav-title { font-family:'Cormorant Garamond',serif;font-size:1rem;color:rgba(245,237,216,0.8); }
  .nav-center { text-align:center;font-size:0.9rem;color:rgba(201,168,76,0.6);text-decoration:none;padding:0.5rem 1rem;white-space:nowrap;font-family:'Crimson Pro',serif;letter-spacing:0.08em;transition:color 0.2s; }
  .nav-center:hover { color:#C9A84C; }
  @media (max-width:900px) {
    .entry-layout { grid-template-columns:1fr !important; }
    .entry-nav    { grid-template-columns:1fr 1fr !important; }
    .nav-center   { display:none; }
  }
</style>

<script>
  document.querySelectorAll('.yt-wrap').forEach(function(wrap) {
    wrap.addEventListener('click', function() {
      var id = wrap.getAttribute('data-yt-id');
      if (!id) return;
      var iframe = document.createElement('iframe');
      iframe.src = 'https://www.youtube.com/embed/' + id + '?autoplay=1';
      iframe.className = 'yt-iframe';
      iframe.setAttribute('allow', 'accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture');
      iframe.allowFullscreen = true;
      wrap.innerHTML = '';
      wrap.appendChild(iframe);
    });
  });
</script>
