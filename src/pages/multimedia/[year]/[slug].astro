---
// src/pages/multimedia/[year]/[slug].astro
import Layout from '../../../layouts/Layout.astro';
import {
  getEntriesByYear,
  getEntry,
  getYears,
  categoryLabels,
  categoryColors,
} from '../../../data/multimediaHelpers';

export async function getStaticPaths() {
  const years = await getYears();
  const paths = [];
  for (const year of years) {
    const entries = await getEntriesByYear(year);
    for (const entry of entries) {
      paths.push({ params: { year: String(year), slug: entry.slug } });
    }
  }
  return paths;
}

const { year, slug } = Astro.params;
const rok      = parseInt(year);
const entry    = await getEntry(rok, slug);
const listRoku = await getEntriesByYear(rok);
const idx      = listRoku.findIndex((e) => e.slug === slug);

const hasPrev    = idx < listRoku.length - 1;
const hasNext    = idx > 0;
const poprzedni  = hasPrev ? listRoku[idx + 1] : null;
const nastepny   = hasNext ? listRoku[idx - 1] : null;

const catColor     = entry ? categoryColors[entry.category] : '#C9A84C';
const catLabel     = entry ? categoryLabels[entry.category] : '';
const catMetaStyle = 'font-family:Crimson Pro,serif;font-size:0.72rem;letter-spacing:0.18em;text-transform:uppercase;background:rgba(201,168,76,0.12);color:' + catColor + ';padding:0.25rem 0.75rem;border:1px solid ' + catColor + '55;';

const descParas = entry
  ? entry.description.trim().split('\n').filter((p) => p.trim().length > 0).map((p) => p.trim())
  : [];

const sidebarLinks = listRoku
  .filter((e) => e.slug !== slug)
  .slice(0, 8)
  .map((e) => ({
    href:     '/multimedia/' + rok + '/' + e.slug,
    catLabel: categoryLabels[e.category],
    catColor: categoryColors[e.category] + '99',
    title:    e.title,
  }));

const yearHref  = '/multimedia/' + rok;
const prevHref  = poprzedni ? '/multimedia/' + rok + '/' + poprzedni.slug : '';
const nextHref  = nastepny  ? '/multimedia/' + rok + '/' + nastepny.slug  : '';

const parts    = entry?.parts ?? [];
const hasEntry = !!entry;

// Formatuj datę
const dateDisplay = entry
  ? (entry.date instanceof Date
      ? entry.date.toLocaleDateString('pl-PL', { year:'numeric', month:'long', day:'numeric' })
      : String(entry.date))
  : '';
---

<Layout
  title={entry?.title ?? 'Materiał audiowizualny'}
  description={entry ? entry.title + ' · ' + rok + ' · Ateny Roztocza' : ''}
>

{!hasEntry && (
  <div style="background:#1A1209;min-height:60vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:5rem 2rem;">
    <div>
      <p style="font-family:'Cormorant Garamond',serif;font-size:2rem;color:rgba(232,201,122,0.3);">Materiał nie został znaleziony.</p>
      <a href={yearHref} style="color:#C9A84C;margin-top:1rem;display:inline-block;font-family:'Crimson Pro',serif;font-size:0.85rem;letter-spacing:0.15em;text-transform:uppercase;text-decoration:none;border-bottom:1px solid rgba(201,168,76,0.4);">
        ← Wróć do {rok}
      </a>
    </div>
  </div>
)}

{hasEntry && entry && (
  <div class="page-transition">

    <!-- HERO ZŁOTE ŚWIATŁO -->
    <section style="background:#1A1209; padding:clamp(3.5rem,9vw,6rem) clamp(1rem,4vw,2rem) clamp(2.5rem,5vw,4rem); position:relative; overflow:hidden;">
      <div style="position:absolute; inset:0; pointer-events:none; background:radial-gradient(ellipse at 25% 50%,rgba(201,168,76,0.055) 0%,transparent 65%);"></div>
      
      <div style="max-width:1100px;margin:0 auto; position:relative;">
        
        <!-- Breadcrumby -->
        <nav style="font-family:'Crimson Pro',serif;font-size:0.82rem;letter-spacing:0.1em;margin-bottom:clamp(1.5rem,3vw,2.5rem);">
          <a href="/multimedia" class="bc-link" style="color:rgba(201,168,76,0.5);text-decoration:none;transition:color 0.2s;">Multimedia</a>
          <span style="margin:0 0.6rem;color:rgba(201,168,76,0.2);">›</span>
          <a href={yearHref} class="bc-link" style="color:rgba(201,168,76,0.5);text-decoration:none;transition:color 0.2s;">{rok}</a>
          <span style="margin:0 0.6rem;color:rgba(201,168,76,0.2);">›</span>
          <span style="color:rgba(201,168,76,0.85);">{entry.title}</span>
        </nav>

        <!-- Meta podtytuł -->
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;margin-bottom:clamp(1rem,2.5vw,1.5rem);">
          <span style={catMetaStyle}>{catLabel}</span>
          <span style="font-family:'Crimson Pro',serif; font-size:0.85rem;color:rgba(201,168,76,0.5);letter-spacing:0.05em;">{dateDisplay}</span>
          {entry.place && (
            <span style="font-family:'Crimson Pro',serif; font-size:0.85rem;color:rgba(201,168,76,0.5);">· {entry.place}</span>
          )}
          {parts.length > 1 && (
            <span style="font-family:'Crimson Pro',serif; font-size:0.85rem;color:rgba(201,168,76,0.5);">· {parts.length} części</span>
          )}
        </div>

        <!-- Tytuł główny -->
        <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,6vw,3.5rem);font-weight:400;line-height:1.15;color:#E8C97A;margin-bottom:1.5rem;">
          {entry.title}
        </h1>

        <!-- Tagi -->
        {entry.tags && entry.tags.length > 0 && (
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
            {entry.tags.map((t) => (
              <span style="font-family:'Crimson Pro',serif;font-size:0.75rem;color:rgba(201,168,76,0.6);background:rgba(201,168,76,0.08);padding:0.25rem 0.75rem;border:1px solid rgba(201,168,76,0.15);letter-spacing:0.05em;"># {t}</span>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- TREŚĆ GŁÓWNA I BOCZNA -->
    <section style="background:#1A1209; padding:clamp(2rem,4vw,3rem) clamp(1rem,4vw,2rem) clamp(3rem,6vw,5rem); border-top:1px solid rgba(201,168,76,0.08);">
      <div class="entry-layout" style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 280px;gap:clamp(2rem,4vw,3.5rem);align-items:start;">

        <div>
          {/* Opis w stylu cytatu */}
          <div style="margin-bottom:clamp(2.5rem,5vw,4rem); border-left:2px solid rgba(201,168,76,0.38); padding-left:clamp(0.875rem,2.5vw,1.25rem);">
            {descParas.map((para) => (
              <p style="font-family:'IM Fell English',serif;font-style:italic;font-size:clamp(1.0625rem,2.8vw,1.3rem);line-height:1.88;color:rgba(232,201,122,0.68);margin-bottom:0.75rem;">
                {para}
              </p>
            ))}
          </div>

          {/* Nagłówek listy wideo */}
          {parts.length > 0 && (
            <h2 style="font-family:'Cormorant Garamond',serif;font-size:clamp(1.3rem,4vw,1.85rem);font-weight:400;color:#E8C97A;margin-bottom:clamp(1.5rem,3vw,2.5rem); padding-bottom:1rem; border-bottom:1px solid rgba(201,168,76,0.15);">
              Materiał wideo
            </h2>
          )}

          {/* Lista odtwarzaczy YouTube */}
          {parts.map((part, i) => {
            const partNum  = i < 9 ? '0' + (i + 1) : String(i + 1);
            const isFirst  = i === 0;
            const isMulti  = parts.length > 1;
            const thumbSrc = 'https://img.youtube.com/vi/' + part.id + '/maxresdefault.jpg';
            const errSrc   = 'https://img.youtube.com/vi/' + part.id + '/mqdefault.jpg';
            const altText  = isMulti ? entry.title + ' — ' + part.label : entry.title;
            return (
              <div style="margin-bottom:clamp(2.5rem,5vw,4rem);">
                {isMulti && (
                  <div style="display:flex;gap:1.25rem;align-items:flex-start;margin-bottom:1.25rem;">
                    <span style="font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,5vw,3rem);color:rgba(201,168,76,0.2);line-height:1;">{partNum}</span>
                    <div>
                      <h3 style="font-family:'Cormorant Garamond',serif;font-size:clamp(1.1rem,3vw,1.4rem);font-weight:400;color:#F5EDD8;margin-bottom:0.35rem;">{part.label}</h3>
                      <span style="font-family:'Crimson Pro',serif;font-size:0.85rem;color:rgba(201,168,76,0.5);letter-spacing:0.1em;text-transform:uppercase;">⏱ {part.duration}</span>
                    </div>
                  </div>
                )}
                {part.description && (
                  <p style="font-family:'Crimson Pro',serif;font-size:0.95rem;color:rgba(245,237,216,0.6);margin-bottom:1.25rem;font-style:italic;line-height:1.6;">{part.description}</p>
                )}
                <div class="yt-wrap" data-yt-id={part.id} style="position:relative;aspect-ratio:16/9;background:#000;cursor:pointer;overflow:hidden;border:1px solid rgba(201,168,76,0.12);">
                  <img
                    src={thumbSrc}
                    alt={altText}
                    loading={isFirst ? 'eager' : 'lazy'}
                    class="yt-thumb"
                    style="width:100%;height:100%;object-fit:cover;transition:transform 0.3s,filter 0.3s;"
                    onerror={'this.src=\'' + errSrc + '\''}
                  />
                  <div class="yt-play" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:72px;height:50px;background:rgba(201,168,76,0.9);border-radius:14px;display:flex;align-items:center;justify-content:center;pointer-events:none;transition:transform 0.2s,background 0.2s;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="#1A1209"><path d="M5 3l14 9-14 9V3z"/></svg>
                  </div>
                  <div style="position:absolute;bottom:0;left:0;right:0;padding:1.25rem;background:linear-gradient(transparent,rgba(26,18,9,0.8));display:flex;justify-content:space-between;align-items:flex-end;pointer-events:none;">
                    <span style="font-family:'Crimson Pro',serif;font-size:0.8rem;color:rgba(232,201,122,0.7);letter-spacing:0.05em;">▶ Kliknij aby odtworzyć</span>
                    <span style="font-family:'Crimson Pro',serif;font-size:0.8rem;color:rgba(232,201,122,0.6);">{part.duration}</span>
                  </div>
                </div>
              </div>
            );
          })}
        </div>

        <!-- SIDEBAR -->
        <aside style="position:sticky;top:90px;">
          <div style="background:linear-gradient(135deg,rgba(201,168,76,0.04) 0%,rgba(201,168,76,0.01) 100%);border:1px solid rgba(201,168,76,0.15);padding:1.5rem;">
            <h4 style="font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:400;color:#E8C97A;margin-bottom:1.25rem;padding-bottom:0.75rem;border-bottom:1px solid rgba(201,168,76,0.15);">
              Inne z {rok}
            </h4>
            <ul style="list-style:none;padding:0;margin:0;">
              {sidebarLinks.map((link) => (
                <li style="margin-bottom:0.25rem;">
                  <a href={link.href} class="sidebar-link" style="display:flex;flex-direction:column;gap:0.15rem;text-decoration:none;padding:0.6rem 0.5rem;border-radius:2px;transition:background 0.2s;">
                    <span style={'font-family:Crimson Pro,serif;font-size:0.65rem;text-transform:uppercase;letter-spacing:0.12em;color:' + link.catColor + ';'}>{link.catLabel}</span>
                    <span style="font-family:'Cormorant Garamond',serif;font-size:0.95rem;color:rgba(245,237,216,0.8);line-height:1.3;">{link.title}</span>
                  </a>
                </li>
              ))}
            </ul>
            <a href={yearHref} class="sidebar-back" style="display:block;margin-top:1.25rem;padding-top:0.75rem;border-top:1px solid rgba(201,168,76,0.15);font-family:'Crimson Pro',serif;font-size:0.85rem;color:rgba(201,168,76,0.7);text-decoration:none;letter-spacing:0.08em;transition:color 0.2s;">
              ← Wszystkie z {rok}
            </a>
          </div>
        </aside>

      </div>
    </section>

    <!-- NAWIGACJA PREV / NEXT -->
    <nav style="background:#0D0A05;border-top:1px solid rgba(201,168,76,0.1);padding:clamp(2rem,4vw,3rem) clamp(1rem,4vw,2rem);">
      <div class="entry-nav" style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr auto 1fr;gap:2rem;align-items:center;">
        <div>
          {poprzedni && (
            <a href={prevHref} class="nav-link">
              <span class="nav-dir">← Starsze</span>
              <span class="nav-title">{poprzedni.title}</span>
            </a>
          )}
        </div>
        <a href={yearHref} class="nav-center">↑ {rok}</a>
        <div style="text-align:right;">
          {nastepny && (
            <a href={nextHref} class="nav-link nav-next">
              <span class="nav-dir">Nowsze →</span>
              <span class="nav-title">{nastepny.title}</span>
            </a>
          )}
        </div>
      </div>
    </nav>

  </div>
)}

</Layout>

<style>
  .bc-link:hover       { color: #C9A84C !important; }
  .sidebar-link:hover { background: rgba(201,168,76,0.07) !important; }
  .sidebar-back:hover { color: #E8C97A !important; }
  
  .yt-wrap:hover .yt-thumb { transform: scale(1.02); filter: brightness(0.5); }
  .yt-wrap:hover .yt-play  { background: #C9A84C !important; transform: translate(-50%,-50%) scale(1.08) !important; }
  .yt-iframe { position:absolute;inset:0;width:100%;height:100%;border:none; }
  
  .nav-link  { display:flex;flex-direction:column;gap:0.3rem;text-decoration:none;color:rgba(245,237,216,0.8);padding:clamp(0.75rem,2vw,1.25rem);border:1px solid rgba(201,168,76,0.12);transition:all 0.3s ease;background:linear-gradient(135deg,rgba(201,168,76,0.02) 0%,transparent 100%); }
  .nav-link:hover { border-color:rgba(201,168,76,0.4); background:rgba(201,168,76,0.05); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.3); }
  .nav-next  { text-align:right; }
  .nav-dir   { font-family:'Crimson Pro',serif; font-size:0.75rem;color:#C9A84C;letter-spacing:0.14em; }
  .nav-title { font-family:'Cormorant Garamond',serif;font-size:1rem;color:rgba(245,237,216,0.9); }
  .nav-center { text-align:center;font-family:'Crimson Pro',serif;font-size:0.9rem;color:rgba(201,168,76,0.5);text-decoration:none;padding:0.5rem 1rem;white-space:nowrap;letter-spacing:0.08em;transition:color 0.2s; }
  .nav-center:hover { color:#E8C97A; }
  
  @media (max-width:900px) {
    .entry-layout { grid-template-columns:1fr !important; }
    .entry-nav    { grid-template-columns:1fr 1fr !important; }
    .nav-center   { display:none; }
  }
</style>

<script>
  document.querySelectorAll('.yt-wrap').forEach(function(wrap) {
    wrap.addEventListener('click', function() {
      var id = wrap.getAttribute('data-yt-id');
      if (!id) return;
      var iframe = document.createElement('iframe');
      iframe.src = 'https://www.youtube.com/embed/' + id + '?autoplay=1';
      iframe.className = 'yt-iframe';
      iframe.setAttribute('allow', 'accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture');
      iframe.setAttribute('allowfullscreen', '');
      wrap.innerHTML = '';
      wrap.appendChild(iframe);
    });
  });
</script>
