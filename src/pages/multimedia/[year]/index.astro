---
import Layout from '../../../layouts/Layout.astro';
import { getLataArchiwum, getMaterialyRoku } from '../../../lib/sanity';

export async function getStaticPaths() {
  const lata = await getLataArchiwum();
  return (lata ?? []).map((rok: number) => ({ params: { year: String(rok) } }));
}

const { year } = Astro.params;
const rok = parseInt(year);

const materialy = await getMaterialyRoku(rok);
const lata = await getLataArchiwum();
const lataSort = [...(lata ?? [])].sort((a: number, b: number) => b - a);
const rokIdx = lataSort.indexOf(rok);
const rokNowszy  = rokIdx > 0              ? lataSort[rokIdx - 1] : null;
const rokStarszy = rokIdx < lataSort.length - 1 ? lataSort[rokIdx + 1] : null;
---

<Layout
  title={`Materiały ${rok} — Ateny Roztocza`}
  description={`Archiwum materiałów audiowizualnych projektu Ateny Roztocza z roku ${rok}. ${materialy?.length ?? 0} wystąpień.`}
>
  <div class="page-transition">

    <!-- Hero -->
    <div class="page-hero" style="position:relative;">
      <div style="position:relative; z-index:2; max-width:760px; margin:0 auto;">
        <nav style="font-family:'Crimson Pro',serif; font-size:0.8rem; letter-spacing:0.12em; color:rgba(201,168,76,0.5); margin-bottom:1.5rem;">
          <a href="/multimedia" style="color:rgba(201,168,76,0.6); text-decoration:none; transition:color 0.2s;" class="breadcrumb-link">Multimedia</a>
          <span style="margin:0 0.6rem; color:rgba(201,168,76,0.3);">›</span>
          <span style="color:rgba(201,168,76,0.9);">{rok}</span>
        </nav>
        <p style="font-family:'Crimson Pro',serif; font-size:clamp(0.65rem,1.5vw,0.75rem); letter-spacing:0.35em; text-transform:uppercase; color:rgba(201,168,76,0.65); margin-bottom:1rem;">
          Archiwum audiowizualne
        </p>
        <h1 class="section-title gold-shimmer" style="font-size:clamp(3rem,10vw,6rem); margin-bottom:0.75rem; line-height:1;">
          {rok}
        </h1>
        <p style="font-family:'IM Fell English',serif; font-style:italic; font-size:clamp(1rem,2.2vw,1.2rem); color:rgba(232,201,122,0.65);">
          {materialy?.length ?? 0} {(materialy?.length ?? 0) === 1 ? 'wystąpienie' : (materialy?.length ?? 0) < 5 ? 'wystąpienia' : 'wystąpień'}
        </p>
      </div>
    </div>

    <!-- Content -->
    <div style="background:#F5EDD8; min-height:60vh; padding:clamp(2.5rem,5vw,4rem) clamp(1rem,4vw,2rem);">
      <div style="max-width:1000px; margin:0 auto;">

        {(!materialy || materialy.length === 0) ? (
          <div style="text-align:center; padding:5rem 0;">
            <p style="font-family:'Cormorant Garamond',serif; font-size:1.5rem; color:rgba(26,18,9,0.3);">
              Brak materiałów dla roku {rok}.
            </p>
            <a href="/multimedia" style="display:inline-block; margin-top:1.5rem; font-family:'Crimson Pro',serif; font-size:0.85rem; letter-spacing:0.15em; text-transform:uppercase; color:#C9A84C; text-decoration:none; border-bottom:1px solid rgba(201,168,76,0.4); padding-bottom:2px;">
              ← Powrót do archiwum
            </a>
          </div>
        ) : (
          <div style="display:flex; flex-direction:column;">
            {materialy.map((m: any, i: number) => {
              const totalParts = m.czesci?.length ?? m.liczbaCzesci ?? 1;
              return (
                
                  href={`/multimedia/${rok}/${m.slug?.current}`}
                  style="text-decoration:none;"
                  class="entry-row-link"
                >
                  <div
                    class="entry-row"
                    style="display:grid; grid-template-columns:3rem 1fr auto; gap:clamp(1rem,3vw,2rem); padding:clamp(1.25rem,3vw,2rem) 0; border-bottom:1px solid rgba(26,18,9,0.09); align-items:start; transition:padding-left 0.25s ease, background 0.2s;"
                  >
                    <!-- Index number -->
                    <div style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.4rem,3.5vw,1.8rem); font-weight:300; color:rgba(201,168,76,0.3); line-height:1; padding-top:0.15rem; text-align:right;">
                      {String(i + 1).padStart(2, '0')}
                    </div>

                    <!-- Content -->
                    <div>
                      <div style="display:flex; gap:0.5rem; align-items:center; flex-wrap:wrap; margin-bottom:0.4rem;">
                        {m.kategoria && (
                          <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.6rem,1.4vw,0.68rem); letter-spacing:0.18em; text-transform:uppercase; color:#C9A84C; border:1px solid rgba(201,168,76,0.35); padding:2px 7px;">
                            {m.kategoria}
                          </span>
                        )}
                        {totalParts > 1 && (
                          <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.6rem,1.4vw,0.68rem); letter-spacing:0.12em; text-transform:uppercase; color:rgba(201,168,76,0.7); background:rgba(201,168,76,0.08); border:1px solid rgba(201,168,76,0.2); padding:2px 7px;">
                            {totalParts} części
                          </span>
                        )}
                        {m.data && (
                          <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.78rem,1.8vw,0.85rem); color:rgba(26,18,9,0.38); font-style:italic;">
                            {new Date(m.data).toLocaleDateString('pl-PL', { day: '2-digit', month: 'long' })}
                          </span>
                        )}
                      </div>

                      <h2 style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.05rem,3vw,1.5rem); font-weight:400; color:#1A1209; line-height:1.35; margin-bottom:0.35rem;">
                        {m.tytul}
                      </h2>

                      {m.miejsce && (
                        <p style="font-family:'Crimson Pro',serif; font-size:clamp(0.82rem,2vw,0.9rem); color:rgba(26,18,9,0.42); font-style:italic; margin:0;">
                          📍 {m.miejsce}
                        </p>
                      )}
                    </div>

                    <!-- Arrow -->
                    <div style="padding-top:0.5rem; flex-shrink:0;">
                      <svg width="18" height="18" fill="none" stroke="rgba(201,168,76,0.45)" stroke-width="1.5">
                        <path d="M3 9h12M11 5l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        )}

        <!-- Year navigation -->
        <nav style="display:flex; justify-content:space-between; align-items:center; margin-top:clamp(2.5rem,5vw,4rem); padding-top:clamp(1.5rem,3vw,2rem); border-top:1px solid rgba(201,168,76,0.2); flex-wrap:wrap; gap:1rem;">
          {rokStarszy ? (
            <a href={`/multimedia/${rokStarszy}`} class="year-nav-btn">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 3L5 7l5 4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              ← {rokStarszy}
            </a>
          ) : <span></span>}

          <a href="/multimedia" style="font-family:'Crimson Pro',serif; font-size:0.8rem; letter-spacing:0.15em; text-transform:uppercase; color:rgba(26,18,9,0.45); text-decoration:none; border-bottom:1px solid rgba(201,168,76,0.3); padding-bottom:1px; transition:color 0.2s;" class="year-nav-all">
            Wszystkie lata
          </a>

          {rokNowszy ? (
            <a href={`/multimedia/${rokNowszy}`} class="year-nav-btn">
              {rokNowszy} →
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 3l5 4-5 4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          ) : <span></span>}
        </nav>

      </div>
    </div>

  </div>
</Layout>

<style>
  .breadcrumb-link:hover { color: #C9A84C !important; }
  .year-nav-all:hover    { color: #C9A84C !important; }

  .year-nav-btn {
    font-family: 'Crimson Pro', serif;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(26, 18, 9, 0.55);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid rgba(201, 168, 76, 0.25);
    padding: 0.55rem 1.1rem;
    transition: all 0.25s;
  }
  .year-nav-btn:hover { color: #C9A84C; border-color: #C9A84C; background: rgba(201,168,76,0.05); }

  .entry-row-link:hover .entry-row {
    padding-left: 0.75rem !important;
    background: rgba(201, 168, 76, 0.03);
  }
</style>
