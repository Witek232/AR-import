<style>
  .mm-article-row:hover { padding-left: 0.75rem !important; }
  .mm-recent-row:hover > div { background: rgba(201,168,76,0.06) !important; padding-left: clamp(1rem,2.5vw,1.25rem) !important; }
  @media (max-width: 480px) { .tab-label { display: none; } }
</style>

<script>
  // ── Tab switching ─────────────────────────────────────────
  const tabBtns  = document.querySelectorAll<HTMLButtonElement>('.mm-tab-btn');
  const panels   = document.querySelectorAll<HTMLElement>('.mm-panel');

  function activateTab(key: string) {
    tabBtns.forEach((btn) => {
      const isActive = btn.dataset.tab === key;
      btn.style.color             = isActive ? '#E8C97A'                  : 'rgba(245,237,216,0.42)';
      btn.style.borderBottomColor = isActive ? '#C9A84C'                  : 'transparent';
      // count badge colour
      const countEl = btn.querySelector<HTMLElement>('span:last-child');
      if (countEl) countEl.style.color = isActive ? 'rgba(201,168,76,0.7)' : 'rgba(201,168,76,0.3)';
    });
    panels.forEach((panel) => {
      panel.style.display = panel.id === `mm-panel-${key}` ? 'block' : 'none';
    });
  }

  // ── URL param on load ─────────────────────────────────────
  const params  = new URLSearchParams(window.location.search);
  const tabParam = params.get('tab');
  const validTabs = ['audiowizualne', 'nasz-dziennik', 'niedziela', 'inne'];
  activateTab(validTabs.includes(tabParam ?? '') ? tabParam! : 'audiowizualne');

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.tab ?? 'audiowizualne';
      activateTab(key);
      // Update URL without reload
      const url = new URL(window.location.href);
      url.searchParams.set('tab', key);
      history.replaceState(null, '', url);
    });
  });
</script>
