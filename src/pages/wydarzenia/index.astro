---
// src/pages/wydarzenia/index.astro
import Layout from '../../layouts/Layout.astro';
import {
  getAllWydarzenia,
  typeLabels,
  typeColors,
  formatEventDate,
} from '../../data/wydarzeniaHelpers';

const allWydarzenia = await getAllWydarzenia();

const eventsDisplay = allWydarzenia.map((event) => {
  const d = formatEventDate(event.date);
  const type = typeLabels[event.type] ?? event.type;
  const typeColor = typeColors[event.type] ?? '#C9A84C';
  const langLabel = (event.languages ?? ['PL']).join('/');
  const isMultiLang = (event.languages ?? []).length > 1;
  return { event, d, type, typeColor, langLabel, isMultiLang };
});

const filterButtons = [
  { key: 'all', label: 'Wszystkie' },
  { key: 'upcoming', label: 'Nadchodzące' },
  { key: 'past', label: 'Archiwum' },
];
---

<Layout
  title="Wydarzenia"
  description="Seminaria, wykłady i konferencje projektu Ateny Roztocza."
>
  <div class="page-transition">

    <!-- Hero -->
    <div class="page-hero">
      <div style="position:relative; z-index:2; max-width:700px; margin:0 auto;">
        <p style="font-family:'Crimson Pro',serif; font-size:clamp(0.65rem,1.5vw,0.75rem); letter-spacing:0.35em; text-transform:uppercase; color:rgba(201,168,76,0.65); margin-bottom:1.25rem;">
          Seminaria · Wykłady · Konferencje
        </p>
        <h1 class="section-title gold-shimmer" style="font-size:clamp(2.4rem,7vw,4.8rem); margin-bottom:1rem;">
          Wydarzenia
        </h1>
        <p style="font-family:'Charm',serif; font-style:italic; font-size:clamp(1rem,2.2vw,1.25rem); color:rgba(232,201,122,0.7); line-height:1.75;">
          Spotkania w przestrzeni kultury, filozofii i wiary
        </p>
      </div>
    </div>

    <!-- Filtry -->
    <div style="background:#1A1209; border-bottom:1px solid rgba(201,168,76,0.15); position:sticky; top:70px; z-index:100;">
      <div style="max-width:1100px; margin:0 auto; padding:0 1.5rem; display:flex;">
        {filterButtons.map((btn) => (
          <button class="tab-btn w-filter-btn" data-filter={btn.key}>
            {btn.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Lista wydarzeń -->
    <div style="background:#F5EDD8; min-height:60vh;">
      <div style="max-width:1000px; margin:0 auto; padding:clamp(2.5rem,5vw,4rem) 1.5rem; display:flex; flex-direction:column; gap:clamp(1rem,2.5vw,1.5rem);">

        {eventsDisplay.map(({ event, d, type, typeColor, langLabel, isMultiLang }) => (
          <a 
            href={`/wydarzenia/${event.slug}`}
            class="reveal w-event-row"
            data-status={event.status}
          >
            <!-- Data -->
            <div class="w-event-date">
              <div class={`w-event-day ${event.status === 'upcoming' ? 'upcoming' : ''}`}>
                {d.day}
              </div>
              <div class="w-event-month">
                {d.month}
              </div>
              <div class="w-event-year">
                {d.year}
              </div>
            </div>

            <!-- Treść -->
            <div class="w-event-content">
              <div style="display:flex; gap:0.55rem; align-items:center; margin-bottom:0.5rem; flex-wrap:wrap;">
                <span 
                  class="w-event-type"
                  style={`color:${event.status === 'upcoming' ? typeColor : 'rgba(201,168,76,0.55)'}; border-color:${event.status === 'upcoming' ? typeColor + '88' : 'rgba(201,168,76,0.2)'};`}
                >
                  {type}
                </span>

                {event.status === 'past' && event.hasReport && (
                  <span class="w-badge-relacja">
                    <svg width="9" height="9" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="rgba(255,255,255,0.7)" stroke-width="1.2"/><circle cx="5" cy="5" r="2" fill="white"/></svg>
                    Relacja
                  </span>
                )}

                {event.status === 'upcoming' && (
                  <span class="w-badge-upcoming">
                    Wkrótce
                  </span>
                )}

                {isMultiLang && (
                  <span style="font-family:'Crimson Pro',serif; font-size:0.68rem; color:rgba(26,18,9,0.4); letter-spacing:0.1em;">
                    🌐 {langLabel}
                  </span>
                )}

                <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.82rem,1.8vw,0.9rem); color:rgba(26,18,9,0.45); font-style:italic;">
                  {event.place}
                </span>
              </div>

              <h3 class="w-event-title">
                {event.title}
              </h3>

              {event.description && (
                <p class="w-event-desc">
                  {event.description}
                </p>
              )}
            </div>

            <!-- Strzałka -->
            <div class="w-event-arrow">
              <svg width="20" height="20" fill="none" stroke="rgba(201,168,76,0.4)" stroke-width="1.5">
                <path d="M7 4l8 8-8 8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </a>
        ))}

      </div>
    </div>
  </div>
</Layout>

<style>
  /* ── Kafelek wydarzenia ── */
  .w-event-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: clamp(1.25rem, 3vw, 2.5rem);
    padding: clamp(1.5rem, 3.5vw, 2.5rem);
    background: #EDE0C4;
    border: 1px solid rgba(201,168,76,0.2);
    cursor: pointer;
    align-items: start;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .w-event-row:hover {
    transform: translateY(-4px);
    border-color: #C9A84C;
    box-shadow: 0 10px 30px rgba(26,18,9,0.12);
  }

  .w-event-row:hover .w-event-title {
    color: #C9A84C;
  }

  .w-event-row:hover .w-event-arrow svg {
    stroke: #C9A84C;
    transform: translateX(4px);
  }

  .w-event-row:hover .w-event-day {
    color: #C9A84C;
  }

  /* ── Data ── */
  .w-event-date {
    text-align: center;
    min-width: clamp(52px, 10vw, 70px);
    border-right: 1px solid rgba(201,168,76,0.3);
    padding-right: clamp(1rem, 2.5vw, 1.75rem);
  }

  .w-event-day {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 300;
    color: rgba(201,168,76,0.45);
    line-height: 1;
    transition: color 0.3s ease;
  }

  .w-event-day.upcoming {
    color: #C9A84C;
  }

  .w-event-month {
    font-family: 'Crimson Pro', serif;
    font-size: clamp(0.62rem, 1.4vw, 0.72rem);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(26,18,9,0.4);
    margin-top: 0.2rem;
  }

  .w-event-year {
    font-family: 'Crimson Pro', serif;
    font-size: clamp(0.68rem, 1.4vw, 0.78rem);
    color: rgba(26,18,9,0.3);
  }

  /* ── Treść ── */
  .w-event-content {
    min-width: 0;
  }

  .w-event-type {
    font-family: 'Crimson Pro', serif;
    font-size: clamp(0.6rem, 1.4vw, 0.67rem);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    border: 1px solid;
    padding: 2px 8px;
  }

  .w-badge-relacja {
    font-family: 'Crimson Pro', serif;
    font-size: clamp(0.58rem, 1.3vw, 0.65rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
    background: #7A1C2E;
    padding: 2px 9px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .w-badge-upcoming {
    font-family: 'Crimson Pro', serif;
    font-size: clamp(0.58rem, 1.3vw, 0.65rem);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #C9A84C;
    background: rgba(201,168,76,0.1);
    border: 1px solid rgba(201,168,76,0.35);
    padding: 2px 8px;
  }

  .w-event-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.1rem, 3vw, 1.65rem);
    font-weight: 400;
    color: #1A1209;
    line-height: 1.3;
    margin-bottom: 0.5rem;
    transition: color 0.3s ease;
  }

  .w-event-desc {
    font-family: 'Crimson Pro', serif;
    font-style: italic;
    font-size: clamp(0.9rem, 2vw, 1rem);
    color: rgba(26,18,9,0.5);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Strzałka ── */
  .w-event-arrow {
    align-self: center;
  }

  .w-event-arrow svg {
    transition: stroke 0.3s ease, transform 0.3s ease;
  }

  /* ── Filtry ── */
  .w-filter-btn {
    color: rgba(245, 237, 216, 0.45);
    border-bottom-color: transparent;
  }
  .w-filter-btn.active {
    color: #E8C97A;
    border-bottom-color: #C9A84C;
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .w-event-row {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .w-event-date {
      display: flex;
      gap: 0.5rem;
      align-items: baseline;
      border-right: none;
      border-bottom: 1px solid rgba(201,168,76,0.2);
      padding-right: 0;
      padding-bottom: 0.75rem;
      text-align: left;
    }

    .w-event-day {
      font-size: 1.75rem;
    }

    .w-event-arrow {
      display: none;
    }
  }
</style>

<script>
  var filterBtns = document.querySelectorAll('.w-filter-btn');
  var eventRows = document.querySelectorAll('.w-event-row');

  function applyFilter(filter) {
    filterBtns.forEach(function(btn) {
      btn.classList.toggle('active', btn.getAttribute('data-filter') === filter);
    });
    eventRows.forEach(function(row) {
      var status = row.getAttribute('data-status') || '';
      var visible = (filter === 'all' || status === filter);
      row.style.display = visible ? 'grid' : 'none';
    });
  }

  applyFilter('all');

  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      applyFilter(btn.getAttribute('data-filter') || 'all');
    });
  });
</script>
