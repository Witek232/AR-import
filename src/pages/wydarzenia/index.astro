---
import Layout from '../../layouts/Layout.astro';
import {
  getAllWydarzenia,
  typeLabels,
  typeColors,
} from '../../data/wydarzeniaHelpers';

// ── Dane z content collections ────────────────────────────────
const allEvents = await getAllWydarzenia();

// ── Formatowanie daty do wyświetlenia ─────────────────────────
function formatDate(date: Date) {
  return {
    day:   String(date.getDate()).padStart(2, '0'),
    month: date.toLocaleString('pl-PL', { month: 'short' }).replace('.', ''),
    year:  String(date.getFullYear()),
  };
}

const eventsDisplay = allEvents.map((event) => ({
  ...event,
  dateFormatted: formatDate(new Date(event.date)),
  typeLabel:     typeLabels[event.type] ?? event.type,
  typeColor:     typeColors[event.type] ?? '#C9A84C',
  langDisplay:   event.languages && event.languages.length > 0 && event.languages[0] !== 'PL'
                   ? event.languages.join('/') : null,
  href:          '/wydarzenia/' + event.slug,
}));

const upcomingCount = eventsDisplay.filter(e => e.status === 'upcoming').length;

const filterButtons = [
  { key: 'all',      label: 'Wszystkie (' + allEvents.length + ')' },
  { key: 'upcoming', label: 'Nadchodzące (' + upcomingCount + ')' },
  { key: 'past',     label: 'Archiwum' },
];
---

<Layout
  title="Wydarzenia"
  description="Seminaria, wykłady i konferencje projektu Ateny Roztocza. Spotkania w przestrzeni kultury, filozofii i wiary."
>
  <div class="page-transition">

    <!-- ── HERO ─────────────────────────────────────────────── -->
    <div class="page-hero">
      <div style="position:relative; z-index:2; max-width:700px; margin:0 auto;">
        <p style="font-family:'Crimson Pro',serif; font-size:clamp(0.65rem,1.5vw,0.75rem); letter-spacing:0.35em; text-transform:uppercase; color:rgba(201,168,76,0.65); margin-bottom:1.25rem;">
          Seminaria · Wykłady · Konferencje
        </p>
        <h1 class="section-title gold-shimmer" style="font-size:clamp(2.4rem,7vw,4.8rem); margin-bottom:1rem;">
          Wydarzenia
        </h1>
        <p style="font-family:'IM Fell English',serif; font-style:italic; font-size:clamp(1rem,2.2vw,1.25rem); color:rgba(232,201,122,0.7); line-height:1.75;">
          Spotkania w przestrzeni kultury, filozofii i wiary
        </p>
      </div>
    </div>

    <!-- ── STICKY FILTER BAR ─────────────────────────────────── -->
    <div style="background:#1A1209; border-bottom:1px solid rgba(201,168,76,0.15); position:sticky; top:70px; z-index:100;">
      <div style="max-width:1100px; margin:0 auto; padding:0 1.5rem; display:flex;">
        {filterButtons.map((btn) => (
          <button
            class="tab-btn w-filter-btn"
            data-filter={btn.key}
          >
            {btn.label}
          </button>
        ))}
      </div>
    </div>

    <!-- ── LISTA WYDARZEŃ ────────────────────────────────────── -->
    <div style="background:#F5EDD8; min-height:60vh;">
      <div style="max-width:1000px; margin:0 auto; padding:clamp(2.5rem,5vw,4rem) 1.5rem;">

        <!-- Legenda -->
        <div style="display:flex; gap:clamp(0.75rem,2.5vw,1.5rem); flex-wrap:wrap; align-items:center; margin-bottom:clamp(1.5rem,3.5vw,2.5rem); padding:clamp(0.75rem,2vw,1rem) clamp(1rem,2.5vw,1.25rem); background:rgba(26,18,9,0.04); border:1px solid rgba(201,168,76,0.15);">
          <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.68rem,1.6vw,0.75rem); letter-spacing:0.15em; text-transform:uppercase; color:rgba(26,18,9,0.38); flex-shrink:0;">
            Oznaczenia:
          </span>
          <span style="display:inline-flex; align-items:center; gap:6px;">
            <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.6rem,1.4vw,0.65rem); letter-spacing:0.16em; text-transform:uppercase; color:#fff; background:#7A1C2E; padding:2px 8px; display:inline-flex; align-items:center; gap:4px;">
              <svg width="8" height="8" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="rgba(255,255,255,0.6)" stroke-width="1.2"/><circle cx="5" cy="5" r="2" fill="white"/></svg>
              Relacja
            </span>
            <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.78rem,2vw,0.88rem); color:rgba(26,18,9,0.5); font-style:italic;">— dostępna relacja z wydarzenia</span>
          </span>
          <span style="display:inline-flex; align-items:center; gap:6px;">
            <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.6rem,1.4vw,0.65rem); letter-spacing:0.16em; text-transform:uppercase; color:rgba(26,18,9,0.38); border:1px solid rgba(26,18,9,0.15); padding:2px 8px;">Archiwum</span>
            <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.78rem,2vw,0.88rem); color:rgba(26,18,9,0.5); font-style:italic;">— bez relacji</span>
          </span>
          <span style="display:inline-flex; align-items:center; gap:6px;">
            <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.6rem,1.4vw,0.65rem); letter-spacing:0.16em; text-transform:uppercase; color:#C9A84C; border:1px solid rgba(201,168,76,0.35); background:rgba(201,168,76,0.1); padding:2px 8px;">Wkrótce</span>
            <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.78rem,2vw,0.88rem); color:rgba(26,18,9,0.5); font-style:italic;">— wydarzenie nadchodzące</span>
          </span>
        </div>

        <!-- Wiersze wydarzeń -->
        <div id="events-list" style="display:flex; flex-direction:column;">
          {eventsDisplay.map((event) => (
            <a
              href={event.href}
              class="reveal w-event-row"
              data-status={event.status}
              style="display:grid; grid-template-columns:auto 1fr auto; gap:clamp(1.25rem,3vw,2.5rem); padding:clamp(1.5rem,3.5vw,2.5rem) 0; border-bottom:1px solid rgba(26,18,9,0.1); cursor:pointer; transition:padding-left 0.3s ease, background 0.2s; align-items:start; text-decoration:none;"
            >
              <!-- Data -->
              <div style="text-align:center; min-width:clamp(52px,10vw,70px); border-right:1px solid rgba(201,168,76,0.25); padding-right:clamp(1rem,2.5vw,1.75rem);">
                <div style={`font-family:'Cormorant Garamond',serif; font-size:clamp(2rem,5vw,3rem); font-weight:300; color:${event.status === 'upcoming' ? '#C9A84C' : 'rgba(201,168,76,0.45)'}; line-height:1;`}>
                  {event.dateFormatted.day}
                </div>
                <div style="font-family:'Crimson Pro',serif; font-size:clamp(0.62rem,1.4vw,0.72rem); letter-spacing:0.2em; text-transform:uppercase; color:rgba(26,18,9,0.4); margin-top:0.2rem;">
                  {event.dateFormatted.month}
                </div>
                <div style="font-family:'Crimson Pro',serif; font-size:clamp(0.68rem,1.4vw,0.78rem); color:rgba(26,18,9,0.3);">
                  {event.dateFormatted.year}
                </div>
              </div>

              <!-- Treść -->
              <div>
                <div style="display:flex; gap:0.55rem; align-items:center; margin-bottom:0.5rem; flex-wrap:wrap;">
                  <span style={`font-family:'Crimson Pro',serif; font-size:clamp(0.6rem,1.4vw,0.67rem); letter-spacing:0.2em; text-transform:uppercase; color:${event.status === 'upcoming' ? '#C9A84C' : 'rgba(201,168,76,0.55)'}; border:1px solid ${event.status === 'upcoming' ? 'rgba(201,168,76,0.4)' : 'rgba(201,168,76,0.2)'}; padding:2px 8px;`}>
                    {event.typeLabel}
                  </span>

                  {event.status === 'past' && event.hasReport && (
                    <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.58rem,1.3vw,0.65rem); letter-spacing:0.18em; text-transform:uppercase; color:#fff; background:#7A1C2E; padding:2px 9px; display:inline-flex; align-items:center; gap:4px; flex-shrink:0;">
                      <svg width="9" height="9" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="rgba(255,255,255,0.7)" stroke-width="1.2"/><circle cx="5" cy="5" r="2" fill="white"/></svg>
                      Relacja
                    </span>
                  )}

                  {event.status === 'past' && !event.hasReport && (
                    <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.58rem,1.3vw,0.65rem); letter-spacing:0.15em; text-transform:uppercase; color:rgba(26,18,9,0.38); border:1px solid rgba(26,18,9,0.15); padding:2px 8px; flex-shrink:0;">
                      Archiwum
                    </span>
                  )}

                  {event.langDisplay && (
                    <span style="font-family:'Crimson Pro',serif; font-size:0.68rem; color:rgba(26,18,9,0.4); letter-spacing:0.1em;">
                      🌐 {event.langDisplay}
                    </span>
                  )}

                  {event.place && (
                    <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.82rem,1.8vw,0.9rem); color:rgba(26,18,9,0.45); font-style:italic;">
                      {event.place}
                    </span>
                  )}
                </div>

                <h3 style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.1rem,3vw,1.65rem); font-weight:400; color:#1A1209; line-height:1.3; margin-bottom:0.5rem;">
                  {event.title}
                </h3>

                {event.description && (
                  <p style="font-family:'Crimson Pro',serif; font-style:italic; font-size:clamp(0.9rem,2vw,1rem); color:rgba(26,18,9,0.5); line-height:1.65; margin:0;">
                    {event.description}
                  </p>
                )}
              </div>

              <!-- Badge prawy -->
              <div style="align-self:start; margin-top:0.25rem; display:flex; flex-direction:column; gap:0.4rem; align-items:flex-end;">
                {event.status === 'upcoming' && (
                  <div style="font-family:'Crimson Pro',serif; font-size:clamp(0.6rem,1.4vw,0.68rem); letter-spacing:0.18em; text-transform:uppercase; color:#C9A84C; background:rgba(201,168,76,0.1); border:1px solid rgba(201,168,76,0.35); padding:4px 10px; white-space:nowrap;">
                    Wkrótce
                  </div>
                )}
                {event.status === 'past' && event.hasReport && (
                  <div style="font-family:'Crimson Pro',serif; font-size:clamp(0.6rem,1.4vw,0.68rem); letter-spacing:0.14em; text-transform:uppercase; color:rgba(255,255,255,0.85); background:#7A1C2E; padding:4px 10px; white-space:nowrap; display:flex; align-items:center; gap:5px;">
                    <svg width="9" height="9" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="rgba(255,255,255,0.6)" stroke-width="1.2"/><circle cx="5" cy="5" r="2" fill="white"/></svg>
                    Relacja
                  </div>
                )}
                <svg width="16" height="16" fill="none" stroke="rgba(201,168,76,0.3)" stroke-width="1.5" style="margin-top:0.5rem;"><path d="M3 8h10M9 5l4 3-4 3" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
            </a>
          ))}
        </div>

        <!-- Pusty stan -->
        <div id="empty-state" style="display:none; text-align:center; padding:5rem 0;">
          <p style="font-family:'Cormorant Garamond',serif; font-size:1.5rem; color:rgba(26,18,9,0.3);">
            Brak wydarzeń w tej kategorii.
          </p>
        </div>

      </div>
    </div>
  </div>
</Layout>

<style>
  .w-event-row:hover {
    padding-left: 0.75rem !important;
    background: rgba(201,168,76,0.03);
  }

  .w-filter-btn {
    color: rgba(245, 237, 216, 0.45);
    border-bottom-color: transparent;
  }
  .w-filter-btn.active {
    color: #E8C97A;
    border-bottom-color: #C9A84C;
  }
</style>

<script>
  var activeFilter = 'all';
  var filterBtns   = document.querySelectorAll('.w-filter-btn');
  var eventRows    = document.querySelectorAll('.w-event-row');
  var emptyState   = document.getElementById('empty-state');

  function applyFilter(filter) {
    activeFilter = filter;

    filterBtns.forEach(function(btn) {
      btn.classList.toggle('active', btn.getAttribute('data-filter') === filter);
    });

    var visible = 0;
    eventRows.forEach(function(row) {
      var status  = row.getAttribute('data-status') || '';
      var show    = filter === 'all' || status === filter;
      row.style.display = show ? 'grid' : 'none';
      if (show) {
        visible++;
        // Ponów reveal przy odkryciu
        row.classList.remove('visible');
        setTimeout(function() {
          if (row.getBoundingClientRect().top < window.innerHeight) {
            row.classList.add('visible');
          }
        }, 60);
      }
    });

    if (emptyState) {
      emptyState.style.display = visible === 0 ? 'block' : 'none';
    }
  }

  applyFilter('all');

  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      applyFilter(btn.getAttribute('data-filter') || 'all');
    });
  });
</script>
