---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import {
  getAllWydarzenia,
  getSiblings,
  typeLabels,
  typeColors,
} from '../../data/wydarzeniaHelpers';

// ── Static paths ──────────────────────────────────────────────
export async function getStaticPaths() {
  const entries = await getCollection('wydarzenia');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug ?? entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

// ── Dane bieżącego wydarzenia ─────────────────────────────────
const { entry } = Astro.props;
const { slug }  = Astro.params;

const event = {
  ...entry.data,
  slug: entry.data.slug ?? entry.id.replace(/\.md$/, ''),
  body: entry.body ?? '',
};

// Renderuj body (Markdown)
const { Content } = await render(entry);

// Nawigacja prev / next
const { prev, next } = await getSiblings(slug!);

// Pomocnicze
const catColor  = typeColors[event.type]  ?? '#C9A84C';
const catLabel  = typeLabels[event.type]  ?? event.type;
const hasBody   = entry.body && entry.body.trim().length > 0;

function formatDate(date: Date) {
  return date.toLocaleDateString('pl-PL', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
}
const dateDisplay = formatDate(new Date(event.date));
---

<Layout
  title={event.title}
  description={event.description ?? event.title + ' · ' + dateDisplay + ' · Ateny Roztocza'}
>
  <div class="page-transition">

    <!-- ── HERO ─────────────────────────────────────────────── -->
    <section style="background:#1A1209; color:#F5EDD8; padding:clamp(4.5rem,10vw,7.5rem) clamp(1rem,4vw,2rem) clamp(2.5rem,5vw,3.5rem);">
      <div style="max-width:1000px; margin:0 auto;">

        <!-- Breadcrumb -->
        <nav style="font-family:'Crimson Pro',serif; font-size:0.82rem; letter-spacing:0.1em; margin-bottom:1.75rem;">
          <a href="/wydarzenia" class="bc-link" style="color:rgba(201,168,76,0.6); text-decoration:none;">
            ← Wydarzenia
          </a>
          <span style="margin:0 0.6rem; color:rgba(201,168,76,0.25);">›</span>
          <span style="color:rgba(201,168,76,0.85);">{event.title}</span>
        </nav>

        <!-- Meta chips -->
        <div style="display:flex; gap:0.65rem; flex-wrap:wrap; align-items:center; margin-bottom:1.25rem;">
          <span style={`font-family:'Crimson Pro',serif; font-size:clamp(0.62rem,1.4vw,0.68rem); letter-spacing:0.2em; text-transform:uppercase; color:${catColor}; border:1px solid ${catColor}55; padding:3px 10px;`}>
            {catLabel}
          </span>

          {event.status === 'upcoming' && (
            <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.62rem,1.4vw,0.68rem); letter-spacing:0.18em; text-transform:uppercase; color:#C9A84C; background:rgba(201,168,76,0.12); border:1px solid rgba(201,168,76,0.35); padding:3px 10px;">
              Wkrótce
            </span>
          )}

          {event.status === 'past' && event.hasReport && (
            <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.58rem,1.3vw,0.65rem); letter-spacing:0.15em; text-transform:uppercase; color:#fff; background:#7A1C2E; padding:3px 10px; display:inline-flex; align-items:center; gap:4px;">
              <svg width="9" height="9" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="rgba(255,255,255,0.7)" stroke-width="1.2"/><circle cx="5" cy="5" r="2" fill="white"/></svg>
              Relacja dostępna
            </span>
          )}

          <span style="font-size:0.85rem; color:rgba(245,237,216,0.5);">
            📅 {dateDisplay}
          </span>

          {event.place && (
            <span style="font-size:0.85rem; color:rgba(245,237,216,0.5);">
              📍 {event.place}
            </span>
          )}

          {event.languages && event.languages.length > 0 && (
            <span style="font-size:0.85rem; color:rgba(245,237,216,0.5);">
              🌐 {event.languages.join(' / ')}
            </span>
          )}
        </div>

        <!-- Tytuł -->
        <h1 style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.85rem,5vw,3.75rem); font-weight:300; line-height:1.2; color:#F5EDD8; margin-bottom:0;">
          {event.title}
        </h1>
        {event.titleEN && (
          <p style="font-family:'IM Fell English',serif; font-style:italic; font-size:clamp(1rem,2.5vw,1.25rem); color:rgba(201,168,76,0.45); margin-top:0.6rem;">
            {event.titleEN}
          </p>
        )}
      </div>
    </section>

    <!-- ── TREŚĆ ─────────────────────────────────────────────── -->
    <section style="background:#0D0A05; padding:clamp(3rem,6vw,5rem) clamp(1rem,4vw,2rem);">
      <div style="max-width:1000px; margin:0 auto; display:grid; grid-template-columns:1fr min(280px,30%); gap:3.5rem; align-items:start;" class="event-layout">

        <!-- Główna kolumna -->
        <div>

          <!-- Streszczenie (description z frontmatter) -->
          {event.description && (
            <div style="margin-bottom:2.5rem; padding-left:1.5rem; border-left:3px solid #C9A84C;">
              <p style="font-family:'IM Fell English',serif; font-style:italic; font-size:clamp(1.05rem,2.5vw,1.2rem); color:rgba(245,237,216,0.8); line-height:1.85; margin:0;">
                {event.description}
              </p>
            </div>
          )}

          <!-- Body — markdown treść -->
          {hasBody && (
            <div class="event-content">
              <Content />
            </div>
          )}

          <!-- Relacja -->
          {event.status === 'past' && event.hasReport && event.reportUrl && (
            <div style="margin-top:2.5rem; padding:1.5rem; background:rgba(122,28,46,0.12); border:1px solid rgba(122,28,46,0.3); display:flex; align-items:center; gap:1rem; flex-wrap:wrap;">
              <svg width="24" height="24" fill="none" stroke="#7A1C2E" stroke-width="1.5" viewBox="0 0 24 24" style="flex-shrink:0;"><circle cx="12" cy="12" r="10"/><path d="M10 15l5-5-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <div style="flex:1;">
                <p style="font-family:'Crimson Pro',serif; font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; color:rgba(122,28,46,0.7); margin:0 0 0.3rem;">Relacja z wydarzenia</p>
                <a href={event.reportUrl} style="font-family:'Cormorant Garamond',serif; font-size:clamp(1rem,2.5vw,1.15rem); color:#9E2A40; text-decoration:none; border-bottom:1px solid rgba(122,28,46,0.3);" target="_blank" rel="noopener noreferrer">
                  Zobacz relację →
                </a>
              </div>
            </div>
          )}

        </div>

        <!-- Sidebar -->
        <aside style="position:sticky; top:90px;">
          <div style="background:rgba(255,255,255,0.03); border:1px solid rgba(201,168,76,0.15); padding:1.5rem;">

            <!-- Szczegóły -->
            <h4 style="font-family:'Cormorant Garamond',serif; font-size:1rem; color:#C9A84C; margin-bottom:1.25rem; padding-bottom:0.75rem; border-bottom:1px solid rgba(201,168,76,0.15);">
              Szczegóły
            </h4>

            <div style="display:flex; flex-direction:column; gap:0.85rem;">
              <div>
                <p style="font-size:0.65rem; text-transform:uppercase; letter-spacing:0.18em; color:rgba(245,237,216,0.3); font-family:'Crimson Pro',serif; margin:0 0 0.2rem;">Data</p>
                <p style="font-family:'Cormorant Garamond',serif; font-size:1rem; color:#F5EDD8; margin:0;">{dateDisplay}</p>
              </div>

              {event.place && (
                <div>
                  <p style="font-size:0.65rem; text-transform:uppercase; letter-spacing:0.18em; color:rgba(245,237,216,0.3); font-family:'Crimson Pro',serif; margin:0 0 0.2rem;">Miejsce</p>
                  <p style="font-family:'Cormorant Garamond',serif; font-size:1rem; color:#F5EDD8; margin:0;">{event.place}</p>
                </div>
              )}

              <div>
                <p style="font-size:0.65rem; text-transform:uppercase; letter-spacing:0.18em; color:rgba(245,237,216,0.3); font-family:'Crimson Pro',serif; margin:0 0 0.2rem;">Typ</p>
                <p style="font-family:'Crimson Pro',serif; font-size:0.9rem; color:#C9A84C; margin:0; letter-spacing:0.08em;">{catLabel}</p>
              </div>

              {event.languages && event.languages.length > 0 && (
                <div>
                  <p style="font-size:0.65rem; text-transform:uppercase; letter-spacing:0.18em; color:rgba(245,237,216,0.3); font-family:'Crimson Pro',serif; margin:0 0 0.2rem;">Języki</p>
                  <p style="font-family:'Crimson Pro',serif; font-size:0.9rem; color:rgba(245,237,216,0.65); margin:0;">{event.languages.join(', ')}</p>
                </div>
              )}

              <div style="padding-top:0.5rem; border-top:1px solid rgba(201,168,76,0.12);">
                <span style={`font-size:0.65rem; text-transform:uppercase; letter-spacing:0.18em; font-family:'Crimson Pro',serif; display:inline-block; padding:3px 10px; border:1px solid ${event.status === 'upcoming' ? 'rgba(201,168,76,0.35)' : 'rgba(201,168,76,0.15)'}; color:${event.status === 'upcoming' ? '#C9A84C' : 'rgba(201,168,76,0.4)'};`}>
                  {event.status === 'upcoming' ? 'Nadchodzące' : 'Archiwum'}
                </span>
              </div>
            </div>

          </div>
        </aside>

      </div>
    </section>

    <!-- ── NAWIGACJA PREV / NEXT ───────────────────────────── -->
    <nav style="background:#0D0A05; border-top:1px solid rgba(201,168,76,0.12); padding:clamp(2rem,4vw,3rem) clamp(1rem,4vw,2rem);">
      <div style="max-width:1000px; margin:0 auto; display:grid; grid-template-columns:1fr auto 1fr; gap:2rem; align-items:center;" class="event-nav">

        <div>
          {prev && (
            <a href={'/wydarzenia/' + prev.slug} class="event-nav-link">
              <span class="nav-dir">← Poprzednie</span>
              <span class="nav-title">{prev.title}</span>
            </a>
          )}
        </div>

        <a href="/wydarzenia" class="nav-center">↑ Wszystkie</a>

        <div style="text-align:right;">
          {next && (
            <a href={'/wydarzenia/' + next.slug} class="event-nav-link event-nav-next">
              <span class="nav-dir">Następne →</span>
              <span class="nav-title">{next.title}</span>
            </a>
          )}
        </div>

      </div>
    </nav>

  </div>
</Layout>

<style>
  /* ── Treść markdown ── */
  .event-content {
    font-family: 'Crimson Pro', serif;
    font-size: clamp(1.0625rem, 2.5vw, 1.15rem);
    line-height: 1.85;
    color: rgba(245, 237, 216, 0.82);
  }
  .event-content h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.3rem, 3.5vw, 1.8rem);
    font-weight: 400;
    color: #C9A84C;
    margin: 2rem 0 1rem;
  }
  .event-content h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.1rem, 3vw, 1.4rem);
    font-weight: 400;
    color: rgba(232, 201, 122, 0.85);
    margin: 1.75rem 0 0.75rem;
  }
  .event-content p  { margin-bottom: 1.25rem; }
  .event-content ul,
  .event-content ol { padding-left: 1.5rem; margin-bottom: 1.25rem; }
  .event-content li { margin-bottom: 0.45rem; }
  .event-content blockquote {
    font-family: 'IM Fell English', serif;
    font-style: italic;
    font-size: clamp(1.0625rem, 2.5vw, 1.2rem);
    color: rgba(232, 201, 122, 0.65);
    border-left: 3px solid rgba(201, 168, 76, 0.4);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
  }
  .event-content a {
    color: #C9A84C;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .event-content hr {
    border: none;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(201,168,76,0.3), transparent);
    margin: 2rem 0;
  }

  /* ── Breadcrumb ── */
  .bc-link:hover { color: #C9A84C !important; }

  /* ── Nawigacja ── */
  .event-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    color: #F5EDD8;
    padding: 1rem;
    border: 1px solid rgba(201,168,76,0.15);
    transition: all 0.2s;
  }
  .event-nav-link:hover  { border-color: #C9A84C; background: rgba(201,168,76,0.05); }
  .event-nav-next        { text-align: right; }
  .nav-dir               { font-size: 0.75rem; color: #C9A84C; letter-spacing: 0.1em; font-family: 'Crimson Pro', serif; }
  .nav-title             { font-family: 'Cormorant Garamond', serif; font-size: 1rem; color: rgba(245,237,216,0.8); }
  .nav-center            { text-align: center; font-size: 0.9rem; color: rgba(201,168,76,0.6); text-decoration: none; padding: 0.5rem 1rem; white-space: nowrap; font-family: 'Crimson Pro', serif; letter-spacing: 0.08em; transition: color 0.2s; }
  .nav-center:hover      { color: #C9A84C; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .event-layout { grid-template-columns: 1fr !important; }
    .event-nav    { grid-template-columns: 1fr 1fr !important; }
    .nav-center   { display: none; }
  }
</style>
