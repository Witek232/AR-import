---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import {
  getSiblings,
  getEventStatus,
  typeLabels,
  typeColors,
  formatEventDate,
} from '../../data/wydarzeniaHelpers';

export async function getStaticPaths() {
  const entries = await getCollection('wydarzenia');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug ?? entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { slug } = Astro.params;

const status = getEventStatus(entry.data.date);
const event = {
  ...entry.data,
  slug: entry.data.slug ?? entry.id.replace(/\.md$/, ''),
  status,
};

const { Content } = await render(entry);
const { prev, next } = await getSiblings(slug!);

const catColor = typeColors[event.type] ?? '#C9A84C';
const catLabel = typeLabels[event.type] ?? event.type;
const hasBody = entry.body && entry.body.trim().length > 0;
const dateDisplay = formatEventDate(new Date(event.date)).full;
---

<Layout
  title={event.title}
  description={event.description ?? event.title}
>
  <div class="page-transition">

    <!-- ── HERO ─────────────────────────────────────────────── -->
    <div class="page-hero">
      <div style="position:relative; z-index:2; max-width:800px; margin:0 auto;">

        <!-- Breadcrumb -->
        <a href="/wydarzenia" style="display:inline-flex; align-items:center; gap:0.5rem; font-family:'Inter',serif; font-size:0.85rem; letter-spacing:0.1em; text-transform:uppercase; color:rgba(201,168,76,0.6); text-decoration:none; margin-bottom:1.5rem; transition:color 0.2s;" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(201,168,76,0.6)'">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 3L5 9l6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Wydarzenia
        </a>

        <!-- Badges -->
        <div style="display:flex; gap:0.65rem; flex-wrap:wrap; align-items:center; margin-bottom:1.25rem;">
          <span style={`font-family:'Inter',serif; font-size:clamp(0.62rem,1.4vw,0.68rem); letter-spacing:0.2em; text-transform:uppercase; color:${catColor}; border:1px solid ${catColor}55; padding:3px 10px;`}>
            {catLabel}
          </span>

          {status === 'upcoming' && (
            <span style="font-family:'Inter',serif; font-size:clamp(0.62rem,1.4vw,0.68rem); letter-spacing:0.18em; text-transform:uppercase; color:#C9A84C; background:rgba(201,168,76,0.12); border:1px solid rgba(201,168,76,0.35); padding:3px 10px;">
              Nadchodzące
            </span>
          )}

          {status === 'past' && event.hasReport && (
            <span style="font-family:'Inter',serif; font-size:clamp(0.58rem,1.3vw,0.65rem); letter-spacing:0.15em; text-transform:uppercase; color:#fff; background:#7A1C2E; padding:3px 10px; display:inline-flex; align-items:center; gap:4px;">
              <svg width="9" height="9" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="rgba(255,255,255,0.7)" stroke-width="1.2"/><circle cx="5" cy="5" r="2" fill="white"/></svg>
              Relacja dostępna
            </span>
          )}
        </div>

        <!-- Meta -->
        <p class="section-label" style="color:rgba(201,168,76,0.6); margin-bottom:1rem;">
          📅 {dateDisplay} · 📍 {event.place}
          {event.languages && event.languages.length > 1 && ` · 🌐 ${event.languages.join(' / ')}`}
        </p>

        <!-- Tytuł -->
        <h1 class="section-title gold-shimmer" style="font-size:clamp(2rem,6vw,3.5rem); margin-bottom:1.5rem;">
          {event.title}
        </h1>

        <!-- Ornament -->
        <div class="section-ornament" style="margin-top:2rem; margin-bottom:0;">
          <div class="section-ornament-line"></div>
          <svg width="12" height="12" viewBox="0 0 16 16" fill="#C9A84C">
            <path d="M8 1l1.8 4.4L14.4 6l-3.2 3.1.75 4.4L8 11.4l-3.95 2.1.75-4.4L1.6 6l4.6-.6L8 1z" />
          </svg>
          <div class="section-ornament-line"></div>
        </div>

      </div>
    </div>

    <!-- ── TREŚĆ ─────────────────────────────────────────────── -->
    <section style="background:#F5EDD8; position:relative; overflow:hidden;">
      
      <!-- Decorative BG -->
      <div style="position:absolute; right:-5rem; top:50%; transform:translateY(-50%); opacity:0.04; pointer-events:none;">
        <svg width="500" height="500" viewBox="0 0 500 500" fill="none">
          <circle cx="250" cy="250" r="240" stroke="#1A1209" stroke-width="1" />
          <circle cx="250" cy="250" r="200" stroke="#1A1209" stroke-width="1" />
          <circle cx="250" cy="250" r="160" stroke="#1A1209" stroke-width="1" />
          <polygon points="250,30 470,195 385,440 115,440 30,195" stroke="#1A1209" stroke-width="1" fill="none" />
          <polygon points="250,80 420,205 360,400 140,400 80,205" stroke="#C9A84C" stroke-width="0.5" fill="none" />
        </svg>
      </div>

      <div style="max-width:800px; margin:0 auto; padding:clamp(3rem,8vw,5rem) clamp(1.25rem,5vw,3rem); position:relative; z-index:2;">

        <!-- Description -->
        {event.description && (
          <div class="reveal" style="margin-bottom:2.5rem;">
            <blockquote class="elegant-quote" style="border-color:#C9A84C; margin-left:0;">
              {event.description}
            </blockquote>
          </div>
        )}

        <!-- Markdown content -->
        {hasBody && (
          <div class="event-content">
            <Content />
          </div>
        )}

        {!hasBody && (
          <p style="font-family:'Playfair Display',serif; font-style:italic; font-size:1.1rem; color:rgba(26,18,9,0.45); text-align:center; padding:3rem 0;">
            {status === 'upcoming' 
              ? 'Szczegółowy program zostanie opublikowany wkrótce…'
              : 'Sprawozdanie zostanie dodane wkrótce…'}
          </p>
        )}

        <!-- Separator -->
        <div style="height:1px; background:linear-gradient(to right,transparent,rgba(201,168,76,0.5),transparent); margin:clamp(2.5rem,6vw,4rem) 0;"></div>

        <!-- Nawigacja prev/next -->
        <nav style="display:flex; justify-content:space-between; align-items:center; gap:1rem; flex-wrap:wrap;">
          
          {prev ? (
            <a href={'/wydarzenia/' + prev.slug} class="event-nav-link">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 3L5 9l6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <div>
                <span class="nav-dir">Poprzednie</span>
                <span class="nav-title">{prev.title}</span>
              </div>
            </a>
          ) : <div></div>}

          <a href="/wydarzenia" style="font-family:'Inter',serif; font-size:0.85rem; letter-spacing:0.15em; text-transform:uppercase; color:rgba(26,18,9,0.45); text-decoration:none; border-bottom:1px solid rgba(201,168,76,0.35); padding-bottom:2px; transition:color 0.2s;" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(26,18,9,0.45)'">
            Wszystkie wydarzenia
          </a>

          {next ? (
            <a href={'/wydarzenia/' + next.slug} class="event-nav-link event-nav-next">
              <div>
                <span class="nav-dir">Następne</span>
                <span class="nav-title">{next.title}</span>
              </div>
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 3l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          ) : <div></div>}

        </nav>

      </div>
    </section>

  </div>
</Layout>

<style>
  /* ── Treść Markdown ── */
  .event-content {
    font-family: 'Inter', serif;
    font-size: clamp(1.0625rem, 2.5vw, 1.1875rem);
    line-height: 1.85;
    color: #4A3A28;
  }

  .event-content :global(h2) {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.1rem, 4.8vw, 2.7rem);
    font-weight: 400;
    color: #1A1209;
    margin-top: 3.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(201,168,76,0.3);
    line-height: 1.2;
  }

  .event-content :global(h3) {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.68rem, 3.6vw, 2.1rem);
    font-weight: 400;
    color: #1A1209;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .event-content :global(p) {
    margin-bottom: 1.5rem;
    text-align: justify;
    hyphens: auto;
  }

  .event-content :global(ul),
  .event-content :global(ol) {
    padding-left: 2rem;
    margin-bottom: 1.5rem;
  }

  .event-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .event-content :global(blockquote) {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: clamp(1.0625rem, 2.5vw, 1.1875rem);
    line-height: 1.85;
    color: #4A3A28;
    border-left: 3px solid #C9A84C;
    padding: 1rem 1rem 1rem clamp(1rem, 3vw, 1.5rem);
    margin: 2.5rem 0;
    background: rgba(201,168,76,0.06);
  }

  .event-content :global(blockquote p) {
    margin-bottom: 0;
    font-family: 'Playfair Display', serif;
    font-style: italic;
  }

  .event-content :global(strong) {
    color: #1A1209;
    font-weight: 600;
  }

  .event-content :global(em) {
    color: rgba(26,18,9,0.65);
  }

  .event-content :global(a) {
    color: #C9A84C;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .event-content :global(img) {
    max-width: 100%;
    height: auto;
    margin: 2rem 0;
    border: 1px solid rgba(201,168,76,0.25);
    box-shadow: 0 4px 16px rgba(26,18,9,0.1);
  }

  .event-content :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(201,168,76,0.5), transparent);
    margin: 3rem 0;
  }

  /* ── Tabele (programy) ── */
  .event-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  .event-content :global(th),
  .event-content :global(td) {
    padding: 0.75rem 1rem;
    border: 1px solid rgba(201,168,76,0.25);
    text-align: left;
  }

  .event-content :global(th) {
    background: rgba(201,168,76,0.12);
    color: #1A1209;
    font-family: 'Inter', serif;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* ── YouTube embed ── */
  .event-content :global(.yt-embed) {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 2.5rem 0;
    background: #1A1209;
    border: 1px solid rgba(201,168,76,0.25);
    box-shadow: 0 6px 24px rgba(26,18,9,0.15);
  }

  .event-content :global(.yt-embed iframe) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* ── Nawigacja ── */
  .event-nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: #1A1209;
    padding: 1rem;
    border: 1px solid rgba(201,168,76,0.25);
    background: rgba(201,168,76,0.06);
    transition: all 0.25s;
    max-width: 40%;
  }

  .event-nav-link:hover {
    border-color: #C9A84C;
    background: rgba(201,168,76,0.12);
  }

  .event-nav-next {
    text-align: right;
  }

  .nav-dir {
    display: block;
    font-family: 'Inter', serif;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #C9A84C;
    margin-bottom: 0.2rem;
  }

  .nav-title {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: clamp(0.9rem, 2vw, 1.05rem);
    color: rgba(26,18,9,0.7);
    line-height: 1.3;
  }

  @media (max-width: 600px) {
    .event-nav-link {
      max-width: 100%;
    }
  }
</style>
