---
// src/pages/wydarzenia/[slug].astro
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import {
  getSiblings,
  getEventStatus,
  typeLabels,
  typeColors,
  formatEventDate,
} from '../../data/wydarzeniaHelpers';

export async function getStaticPaths() {
  const entries = await getCollection('wydarzenia');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug ?? entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { slug } = Astro.params;

const status = getEventStatus(entry.data.date);
const event = {
  ...entry.data,
  slug: entry.data.slug ?? entry.id.replace(/\.md$/, ''),
  status,
};

const { Content } = await render(entry);
const { prev, next } = await getSiblings(slug!);

const catColor = typeColors[event.type] ?? '#C9A84C';
const catLabel = typeLabels[event.type] ?? event.type;
const hasBody = entry.body && entry.body.trim().length > 0;
const dateDisplay = formatEventDate(new Date(event.date)).full;
---

<Layout
  title={event.title}
  description={event.description ?? event.title}
>
  <div class="page-transition">

    <!-- HERO -->
    <section style="background:#1A1209; color:#F5EDD8; padding:clamp(4.5rem,10vw,7.5rem) clamp(1rem,4vw,2rem) clamp(2.5rem,5vw,3.5rem);">
      <div style="max-width:1000px; margin:0 auto;">

        <!-- Breadcrumb -->
        <nav style="font-family:'Crimson Pro',serif; font-size:0.82rem; letter-spacing:0.1em; margin-bottom:1.75rem;">
          <a href="/wydarzenia" style="color:rgba(201,168,76,0.6); text-decoration:none; transition:color 0.2s;" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(201,168,76,0.6)'">
            ← Wydarzenia
          </a>
        </nav>

        <!-- Badges -->
        <div style="display:flex; gap:0.65rem; flex-wrap:wrap; align-items:center; margin-bottom:1.25rem;">
          <span style={`font-family:'Crimson Pro',serif; font-size:clamp(0.62rem,1.4vw,0.68rem); letter-spacing:0.2em; text-transform:uppercase; color:${catColor}; border:1px solid ${catColor}55; padding:3px 10px;`}>
            {catLabel}
          </span>

          {status === 'upcoming' && (
            <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.62rem,1.4vw,0.68rem); letter-spacing:0.18em; text-transform:uppercase; color:#C9A84C; background:rgba(201,168,76,0.12); border:1px solid rgba(201,168,76,0.35); padding:3px 10px;">
              Nadchodzące
            </span>
          )}

          {status === 'past' && event.hasReport && (
            <span style="font-family:'Crimson Pro',serif; font-size:clamp(0.58rem,1.3vw,0.65rem); letter-spacing:0.15em; text-transform:uppercase; color:#fff; background:#7A1C2E; padding:3px 10px; display:inline-flex; align-items:center; gap:4px;">
              <svg width="9" height="9" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="rgba(255,255,255,0.7)" stroke-width="1.2"/><circle cx="5" cy="5" r="2" fill="white"/></svg>
              Relacja dostępna
            </span>
          )}

          <span style="font-size:0.85rem; color:rgba(245,237,216,0.5);">📅 {dateDisplay}</span>

          {event.place && (
            <span style="font-size:0.85rem; color:rgba(245,237,216,0.5);">📍 {event.place}</span>
          )}

          {event.languages && event.languages.length > 0 && (
            <span style="font-size:0.85rem; color:rgba(245,237,216,0.5);">🌐 {event.languages.join(' / ')}</span>
          )}
        </div>

        <!-- Tytuł -->
        <h1 style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.85rem,5vw,3.75rem); font-weight:300; line-height:1.2; color:#F5EDD8; margin-bottom:0;">
          {event.title}
        </h1>

      </div>
    </section>

    <!-- TREŚĆ -->
    <section style="background:#0D0A05; padding:clamp(3rem,6vw,5rem) clamp(1rem,4vw,2rem);">
      <div style="max-width:800px; margin:0 auto;">

        <!-- Description -->
        {event.description && (
          <div style="margin-bottom:2.5rem; padding-left:1.5rem; border-left:3px solid #C9A84C;">
            <p style="font-family:'Charm',serif; font-style:italic; font-size:clamp(1.05rem,2.5vw,1.2rem); color:rgba(245,237,216,0.8); line-height:1.85; margin:0;">
              {event.description}
            </p>
          </div>
        )}

        <!-- Markdown content -->
        {hasBody && (
          <div class="event-content">
            <Content />
          </div>
        )}

      </div>
    </section>

    <!-- NAWIGACJA -->
    <nav style="background:#0D0A05; border-top:1px solid rgba(201,168,76,0.12); padding:clamp(2rem,4vw,3rem) clamp(1rem,4vw,2rem);">
      <div style="max-width:800px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; gap:1rem; flex-wrap:wrap;">
        
        {prev ? (
          <a href={'/wydarzenia/' + prev.slug} style="display:flex; align-items:center; gap:0.5rem; color:rgba(201,168,76,0.7); text-decoration:none; font-family:'Crimson Pro',serif; font-size:0.9rem; transition:color 0.2s;" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(201,168,76,0.7)'">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 3L5 9l6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Poprzednie
          </a>
        ) : <div></div>}

        <a href="/wydarzenia" style="color:rgba(201,168,76,0.5); text-decoration:none; font-family:'Crimson Pro',serif; font-size:0.85rem; letter-spacing:0.1em; transition:color 0.2s;" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(201,168,76,0.5)'">
          Wszystkie wydarzenia
        </a>

        {next ? (
          <a href={'/wydarzenia/' + next.slug} style="display:flex; align-items:center; gap:0.5rem; color:rgba(201,168,76,0.7); text-decoration:none; font-family:'Crimson Pro',serif; font-size:0.9rem; transition:color 0.2s;" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(201,168,76,0.7)'">
            Następne
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 3l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        ) : <div></div>}

      </div>
    </nav>

  </div>
</Layout>

<style>
  /* Markdown content */
  .event-content {
    font-family: 'Crimson Pro', serif;
    font-size: clamp(1.0625rem, 2.5vw, 1.15rem);
    line-height: 1.85;
    color: rgba(245, 237, 216, 0.82);
  }
  
  .event-content :global(h2) {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 400;
    color: #C9A84C;
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(201,168,76,0.2);
  }
  
  .event-content :global(h3) {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.2rem, 3vw, 1.5rem);
    font-weight: 400;
    color: rgba(232, 201, 122, 0.85);
    margin: 2rem 0 0.75rem;
  }
  
  .event-content :global(p) { 
    margin-bottom: 1.25rem; 
  }
  
  .event-content :global(ul),
  .event-content :global(ol) { 
    padding-left: 1.5rem; 
    margin-bottom: 1.25rem; 
  }
  
  .event-content :global(li) { 
    margin-bottom: 0.45rem; 
  }
  
  .event-content :global(blockquote) {
    font-family: 'Charm', serif;
    font-style: italic;
    font-size: clamp(1.0625rem, 2.5vw, 1.2rem);
    color: rgba(232, 201, 122, 0.65);
    border-left: 3px solid rgba(201, 168, 76, 0.4);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
  }
  
  .event-content :global(a) {
    color: #C9A84C;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  
  .event-content :global(img) {
    max-width: 100%;
    height: auto;
    margin: 2rem 0;
    border: 1px solid rgba(201,168,76,0.2);
  }
  
  .event-content :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(201,168,76,0.3), transparent);
    margin: 2.5rem 0;
  }

  /* YouTube embed */
  .event-content :global(.yt-embed) {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 2rem 0;
    background: #000;
    border: 1px solid rgba(201, 168, 76, 0.25);
  }
  
  .event-content :global(.yt-embed iframe) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* Tabele (dla programu) */
  .event-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }
  
  .event-content :global(th),
  .event-content :global(td) {
    padding: 0.75rem 1rem;
    border: 1px solid rgba(201,168,76,0.15);
    text-align: left;
  }
  
  .event-content :global(th) {
    background: rgba(201,168,76,0.1);
    color: #C9A84C;
    font-family: 'Crimson Pro', serif;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
</style>
