---
import Layout from '../layouts/Layout.astro';

// Dane przeniesione 1:1 z KsGuz.tsx
const timeline = [
  { year: '1959-02-07',      event: 'Urodziny w Zwierzyńcu' },
  { year: '1979',            event: 'matura' },
  { year: '1979–1984',       event: 'Studia teologii na Wydziale Teologii Katolickiej KUL – Magister teologii' },
  { year: '1984-12-16',      event: 'Święcenia kapłańskie w Lublinie' },
  { year: '1988–1989',       event: 'Studia filozofii na Wydziale Filozofii Chrześcijańskiej KUL' },
  { year: '1989–1994',       event: 'Studia filozofii i socjologii na Gustav-Siewerth-Akademie w RFN – Magister filozofii i socjologii' },
  { year: '1996',            event: 'Doktor nauk humanistycznych w zakresie filozofii na Wydziale Filozofii Chrześcijańskiej Akademii Teologii Katolickiej w Warszawie' },
  { year: '1996–2001',       event: 'Asystent naukowy na Gustav-Siewerth-Akademie w RFN' },
  { year: '2001',            event: 'Habilitacja z filozofii na Wydziale Filozofii Chrześcijańskiej Uniwersytetu Kard. S. Wyszyńskiego w Warszawie' },
  { year: '2001',            event: 'Stanowisko profesora zwyczajnego; dziekan Wydziału Filozofii na Gustav-Siewerth-Akademie w RFN' },
  { year: 'od 2003',         event: 'Stanowisko profesora nadzwyczajnego na Wydziale Zamiejscowym Nauk Prawnych i Ekonomicznych KUL w Tomaszowie Lub.' },
  { year: 'od 2006',         event: 'Kierownik Katedry Filozofii Prawa na Wydziale Zamiejscowym Nauk Prawnych i Ekonomicznych KUL w Tomaszowie Lub.' },
  { year: '2005/06',         event: 'Prodziekan Wydziału Zamiejscowego Nauk Prawnych i Ekonomicznych KUL w Tomaszowie Lub.' },
  { year: '2006-2012',       event: 'Dziekan Wydziału Zamiejscowego Nauk Prawnych i Ekonomicznych KUL w Tomaszowie Lub.' },
  { year: '2012-2013',       event: 'Prodziekan Wydziału Zamiejscowego Nauk Prawnych i Ekonomicznych KUL w Tomaszowie Lub.' },
  { year: '2017',            event: 'Tytuł profesora nauk humanistycznych z rąk prezydenta RP Andrzeja Dudy' },
];

const filary = [
  { roman:'I',   city:'Jerozolima', theme:'Wiara i Objawienie',  icon:'✝', color:'#7A1C2E', text:'Badanie relacji między Objawieniem biblijnym a myślą filozoficzną. Jak Słowo Boże oświeca rozum i prowadzi ku pełni prawdy, której filozofia poszukuje.' },
  { roman:'II',  city:'Ateny',      theme:'Rozum i Filozofia',    icon:'Φ', color:'#C9A84C', text:'Gruntowna znajomość Platona, Arystotelesa, stoików i neoplatoników. Filozofia klasyczna jako niezbędne narzędzie chrześcijańskiego rozumienia świata.' },
  { roman:'III', city:'Rzym',       theme:'Prawo i Tradycja',     icon:'Σ', color:'#4A6741', text:'Studia nad rolą prawa naturalnego, tradycji i instytucji w budowaniu cywilizacji. Rzym jako wzorzec ładu społecznego w służbie godności człowieka.' },
];
---

<Layout title="Ks. prof. Tadeusz Guz" description="Filozof, teolog, kapłan — strażnik dialogu między Atenami a Jerozolimą. Duchowy fundament projektu Ateny Roztocza.">
  <div class="page-transition">
    <section id="ks-guz" style="background:#F5EDD8; position:relative; overflow:hidden;">

      <!-- PAGE HERO -->
      <div class="page-hero" style="position:relative;">
        <svg viewBox="0 0 1440 500" style="position:absolute; inset:0; width:100%; height:100%; opacity:0.07; pointer-events:none;" preserveAspectRatio="xMidYMid slice">
          {[100,180,260,1180,1260,1340].map((x) => (
            <g stroke="#C9A84C" stroke-width="1" fill="none">
              <rect x={x} y={80} width={28} height={340} rx="1" />
              <rect x={x-7} y={75} width={42} height={14} rx="1" />
              <rect x={x-7} y={417} width={42} height={12} rx="1" />
              <rect x={x-11} y={429} width={50} height={10} rx="1" />
            </g>
          ))}
          <ellipse cx="720" cy="80" rx="120" ry="40" stroke="#C9A84C" stroke-width="0.8" fill="none" />
        </svg>
        <div style="position:relative; z-index:2; max-width:760px; margin:0 auto;">
          <p class="reveal" style="font-family:'Crimson Pro',serif; font-size:clamp(0.65rem,1.5vw,0.75rem); letter-spacing:0.35em; text-transform:uppercase; color:rgba(201,168,76,0.65); margin-bottom:1.25rem;">
            Fundament duchowy projektu
          </p>
          <h1 class="reveal section-title gold-shimmer" style="font-size:clamp(2.2rem,6vw,4.5rem); margin-bottom:0.5rem;">
            Ks. prof. Tadeusz Guz
          </h1>
          <div class="ornament reveal" style="max-width:320px; margin:1.5rem auto; color:#C9A84C;">
            <svg width="14" height="14" viewBox="0 0 12 12" fill="#C9A84C">
              <path d="M6 0l1.5 3.5L11 5 8.5 7.5l.5 3.5L6 9l-3 2 .5-3.5L1 5l3.5-1.5L6 0z" />
            </svg>
          </div>
          <p class="reveal" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.1rem,2.5vw,1.4rem); color:rgba(232,201,122,0.8); line-height:1.75;">
            Filozof, teolog, kapłan — strażnik dialogu między Atenami a Jerozolimą
          </p>
        </div>
      </div>

      <!-- MAIN CONTENT -->
      <div style="max-width:1200px; margin:0 auto; padding:5rem 2rem;">

        <!-- Portrait + Bio -->
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:4rem; align-items:start; margin-bottom:6rem;">

          <!-- Portrait -->
          <div class="reveal" style="position:relative;">
            <div style="background:#EDE0C4; border:1px solid rgba(201,168,76,0.3); aspect-ratio:3/4; position:relative; overflow:hidden; max-width:380px;">
              <img
                src="https://res.cloudinary.com/dmb0xngy0/image/upload/q_auto/f_auto/v1776448708/TG_vunjd2.png"
                alt="Ks. prof. Tadeusz Guz"
                style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block;"
              />
              <svg viewBox="0 0 300 400" style="position:absolute; inset:0; width:100%; height:100%; opacity:0.4; pointer-events:none; z-index:1;">
                <rect x="12" y="12" width="276" height="376" fill="none" stroke="#C9A84C" stroke-width="1" />
                <rect x="20" y="20" width="260" height="360" fill="none" stroke="#C9A84C" stroke-width="0.5" />
                <line x1="12" y1="12" x2="20" y2="20" stroke="#C9A84C" stroke-width="0.5" />
                <line x1="288" y1="12" x2="280" y2="20" stroke="#C9A84C" stroke-width="0.5" />
                <line x1="12" y1="388" x2="20" y2="380" stroke="#C9A84C" stroke-width="0.5" />
                <line x1="288" y1="388" x2="280" y2="380" stroke="#C9A84C" stroke-width="0.5" />
              </svg>
              <div style="position:absolute; bottom:0; left:0; right:0; z-index:2; background:rgba(26,18,9,0.8); padding:1rem 1.25rem; backdrop-filter:blur(4px);">
                <p style="font-family:'Cormorant Garamond',serif; font-size:clamp(1rem,2vw,1.15rem); color:#E8C97A; margin:0; text-align:center; letter-spacing:0.06em;">
                  Ks. prof. dr hab. Tadeusz Guz
                </p>
                <p style="font-family:'Crimson Pro',serif; font-style:italic; font-size:0.82rem; color:rgba(232,201,122,0.6); margin:0.25rem 0 0; text-align:center;">
                  Profesor filozofii i teologii
                </p>
              </div>
            </div>
            <div style="position:absolute; top:2rem; left:-1rem; width:4px; height:calc(100% - 4rem); background:linear-gradient(to bottom,transparent,#C9A84C 20%,#C9A84C 80%,transparent);"></div>
          </div>

          <!-- Bio text -->
          <div>
            <h2 class="reveal section-title" style="color:#1A1209; margin-bottom:2rem; font-size:clamp(1.8rem,4vw,2.8rem);">
              Człowiek i jego misja
            </h2>
            <div class="reveal body-text" style="margin-bottom:1.5rem;">
              W rodzinnej wsi Szody koło Zwierzyńca na Roztoczu, wśród wzgórz ciągnących się od Kraśnika do Lwowa, rośnie dziś niezwykłe dzieło — centrum „Ateny Roztocza". Jego twórca, ks. prof. Tadeusz Guz, jest postacią rzadką w polskim życiu intelektualnym i duchowym: filozofem, który swą naukę rozumie jako służbę prawdzie, i kapłanem, który swoje kapłaństwo rozumie jako służbę człowiekowi.
            </div>
            <div class="reveal elegant-quote" style="margin-bottom:2rem; border-left:3px solid rgba(201,168,76,0.4); padding-left:1.5rem;">
              „Jest to dzieło Boże powierzone temu łagodnemu Człowiekowi, by w Jego rodzinnej wsi Szody koło Zwierzyńca na Roztoczu, mógł głosić i bronić prawdę."<br/>
              <span style="font-family:'Crimson Pro',serif; font-size:0.85rem; color:rgba(26,18,9,0.5); letter-spacing:0.05em;">— Aldona Ciborowska</span>
            </div>
            <div class="reveal body-text" style="margin-bottom:1.5rem;">
              Ks. Tadeusz Guz pochodzi z Roztocza — krainy o wyjątkowym charakterze, gdzie natura i historia splotły się w niepowtarzalny sposób. To na tej ziemi ukształtowała się jego wrażliwość, tu zakorzenione jest jego myślenie o Polsce, Kościele i człowieku. Już jako młody człowiek wiedział, że filozofia będzie jego powołaniem.
            </div>
            <div class="reveal body-text" style="margin-bottom:2rem;">
              Droga do kapłaństwa wiodła przez lata formacji, których owocem były święcenia kapłańskie w katedrze lubelskiej. Moment ten zbiegł się z jednym z najważniejszych wydarzeń w historii polskiego Kościoła — śmiercią męczeńską bł. ks. Jerzego Popiełuszki.
            </div>
          </div>
        </div>

        <!-- Bł. ks. Jerzy Popiełuszko -->
        <div style="margin-bottom:6rem;">
          <div style="text-align:center; margin-bottom:3rem;">
            <p class="reveal section-label" style="margin-bottom:1rem;">Duchowy ojciec</p>
            <h2 class="reveal section-title" style="color:#1A1209;">Błogosławiony ks. Jerzy</h2>
            <div class="ornament reveal" style="max-width:280px; margin:1.5rem auto; color:#C9A84C;">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="#C9A84C"><path d="M6 0l1.5 3.5L11 5 8.5 7.5l.5 3.5L6 9l-3 2 .5-3.5L1 5l3.5-1.5L6 0z" /></svg>
            </div>
          </div>
          <div style="max-width:800px; margin:0 auto;">
            <div class="reveal body-text" style="margin-bottom:1.5rem;">
              Związek ks. prof. Guza z postacią bł. ks. Jerzego Popiełuszki jest głęboki i wielowymiarowy. Jako młody wikariusz przywoził on na Żoliborz młodzież z ziemi lubelskiej, by czerpała z mądrości kapłana-męczennika. Śmierć ks. Popiełuszki stała się dla młodego ks. Guza momentem przełomowym — chwilą, w której zrodziło się pytanie o kontynuację jego misji na drodze filozofii:
            </div>
            <div class="reveal elegant-quote" style="margin-bottom:2rem;">
              „Na krótko przed święceniami kapłańskimi mogłem oglądać relację telewizyjną z jego pogrzebu i wtedy tak sobie pomyślałem: »Jerzy, Twoja misja tutaj na tym świecie zakończona, ale nie w wieczności. A ja, ponieważ mam takie zacięcie filozoficzne — pomyślę, jak kontynuować Twoje niedoścignione dzieło«."
            </div>
            <div class="reveal body-text" style="margin-bottom:1.5rem;">
              Ten wewnętrzny dialog z postacią męczennika przybrał z czasem wymiar mistyczny. Ks. Guz opowiada o śnie, w którym ks. Jerzy zjeżdżał na rowerze i bez słów obdarzał młodego kapłana listami, które ten zbierał do kieszeni sutanny. Ten obraz — listów powierzonych i przyjętych — stał się dla ks. Guza symbolem misji, którą czuł się zobowiązany podjąć. Wyznał wprost:
            </div>
            <div class="reveal elegant-quote" style="margin-bottom:2rem;">
              „Gdyby nie Ty, błogosławiony księże Jerzy, to by mnie tutaj nie było."
            </div>
          </div>
        </div>

        <!-- Modlitwa św. Ignacego -->
        <div class="reveal" style="background:#1A1209; padding:clamp(2.5rem,6vw,4rem); text-align:center; position:relative; overflow:hidden; margin-bottom:6rem;">
          <div style="position:absolute; inset:0; background:radial-gradient(ellipse at center,rgba(201,168,76,0.06) 0%,transparent 70%); pointer-events:none;"></div>
          <p class="reveal section-label" style="color:rgba(201,168,76,0.5); margin-bottom:1.5rem;">Duchowość kapłańska</p>
          <blockquote style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.15rem,2.8vw,1.6rem); line-height:1.9; color:rgba(232,201,122,0.85); max-width:700px; margin:0 auto 1.5rem;">
            Słowo Odwieczne, Jednorodzony Synu Boży, proszę Cię, naucz mnie służyć Ci tak, jak tego jesteś godzien. Naucz mnie dawać, a nie liczyć, walczyć, a nie zważać na rany, pracować, a nie szukać spoczynku, ofiarować się, a nie szukać nagrody innej prócz poczucia, że spełniłem Twoją Najświętszą Wolę. Amen.
          </blockquote>
          <cite style="font-family:'Crimson Pro',serif; font-size:0.85rem; letter-spacing:0.2em; text-transform:uppercase; color:rgba(201,168,76,0.5);">
            — Modlitwa św. Ignacego Loyoli
          </cite>
        </div>

        <!-- Three pillars -->
        <div style="margin-bottom:6rem;">
          <div style="text-align:center; margin-bottom:3rem;">
            <p class="reveal section-label" style="margin-bottom:1rem;">Główne nurty myśli</p>
            <h2 class="reveal section-title" style="color:#1A1209;">Trzy osie intelektualne</h2>
            <div class="ornament reveal" style="max-width:280px; margin:1.5rem auto; color:#C9A84C;">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="#C9A84C"><path d="M6 0l1.5 3.5L11 5 8.5 7.5l.5 3.5L6 9l-3 2 .5-3.5L1 5l3.5-1.5L6 0z" /></svg>
            </div>
          </div>
          <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:2rem;">
            {filary.map((f, i) => (
              <div class="reveal card-hover gold-border-hover" style={`background:#EDE0C4; border:1px solid rgba(26,18,9,0.08); padding:2.5rem 2rem; position:relative; transition-delay:${i*0.1}s;`}>
                <div style={`font-family:'Cormorant Garamond',serif; font-size:clamp(3.5rem,7vw,5rem); font-weight:300; color:${f.color}; opacity:0.18; position:absolute; top:1.25rem; right:1.5rem; line-height:1;`}>{f.roman}</div>
                <div style={`font-size:2rem; margin-bottom:1rem; color:${f.color};`}>{f.icon}</div>
                <h3 style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.5rem,3vw,2rem); font-weight:400; color:#1A1209; margin-bottom:0.35rem; line-height:1.2;">{f.city}</h3>
                <p style={`font-family:'Crimson Pro',serif; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; color:${f.color}; margin-bottom:1.25rem;`}>{f.theme}</p>
                <p class="body-text" style="font-size:0.98rem; margin:0;">{f.text}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Lata w Niemczech i Powrót -->
        <div style="margin-bottom:6rem; max-width:800px; margin-left:auto; margin-right:auto;">
          <div style="text-align:center; margin-bottom:3rem;">
            <p class="reveal section-label" style="margin-bottom:1rem;">Droga nauki</p>
            <h2 class="reveal section-title" style="color:#1A1209;">Filozof i Nauczyciel</h2>
            <div class="ornament reveal" style="max-width:280px; margin:1.5rem auto; color:#C9A84C;">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="#C9A84C"><path d="M6 0l1.5 3.5L11 5 8.5 7.5l.5 3.5L6 9l-3 2 .5-3.5L1 5l3.5-1.5L6 0z" /></svg>
            </div>
          </div>
          <div class="reveal body-text" style="margin-bottom:1.5rem;">
            W roku 1989 ks. prof. Guz wyjechał do Republiki Federalnej Niemiec, gdzie spędził czternaście lat. Był to okres intensywnych studiów filozoficznych, zakończonych doktoratem, który stał się fundamentem jego późniejszej działalności naukowej. To właśnie tam ukształtował się w pełni jego warsztat filozoficzny i jego szczególne zainteresowanie ideologiami nowożytności — komunizmem, materializmem, ateizmem — które uczynił przedmiotem swoich wieloletnich badań:
          </div>
          <div class="reveal elegant-quote" style="margin-bottom:2rem;">
            „Zajmuję się między innymi rozprawami teoretycznymi z tymi ideologiami, które uśmierciły ciało błogosławionego księdza Jerzego."
          </div>
          <div class="reveal body-text" style="margin-bottom:1.5rem;">
            Po powrocie do kraju podjął pracę akademicką, stając się jednym z najbardziej rozpoznawalnych filozofów katolickich w Polsce. Jego wykłady, audycje radiowe i telewizyjne, a także liczne publikacje naukowe, zjednały mu szerokie grono słuchaczy i czytelników. Dziedzinę swojej pracy naukowej opisuje precyzyjnie:
          </div>
          <div class="reveal elegant-quote" style="margin-bottom:2rem;">
            „Dziedzina nauki, którą się zajmuję już dwudziesty ósmy rok, nakazuje mi jako filozofowi poszukiwać pierwszych racji dla tego, co jest, czyli dla całej rzeczywistości. Według Arystotelesa człowiek dopiero wtedy mówi właściwie, czyli zgodnie z prawdą, o badanej rzeczywistości, gdy na drodze poznania dochodzi do źródeł."
          </div>
          <div class="reveal body-text" style="margin-bottom:1.5rem;">
            Centrum jego zainteresowań naukowych stanowi relacja między rozumem a wiarą, między filozofią klasyczną a Objawieniem chrześcijańskim, między prawdą a ideologią. Szczególne miejsce zajmuje w jego badaniach Osoba Jezusa Chrystusa — jako najdotkliwiej atakowana i zarazem jedyna odpowiedź na pytania, które stawia sobie rozum ludzki:
          </div>
          <div class="reveal elegant-quote">
            „W ostatnich pięciu wiekach osobą najbardziej zaatakowaną ze wszystkich osób Boskich i anielskich, i ludzkich, jest Osoba Jezusa z Nazaretu. We wszystkich ideologiach jakkolwiek się one nazywają. Już od prawie trzydziestu lat są one przedmiotem moich badań i muszę z całą odpowiedzialnością powiedzieć, że nikogo w ostatnich pięciu wiekach tak nie sponiewierano, jak Pana Jezusa."
          </div>
        </div>

        <!-- Timeline -->
        <div style="margin-bottom:6rem;">
          <div style="text-align:center; margin-bottom:3rem;">
            <p class="reveal section-label" style="margin-bottom:1rem;">Chronologia</p>
            <h2 class="reveal section-title" style="color:#1A1209;">Droga życia i myśli</h2>
          </div>
          <div style="max-width:780px; margin:0 auto; position:relative;">
            <div style="position:absolute; left:162px; top:0; bottom:0; width:1px; background:linear-gradient(to bottom,transparent,rgba(201,168,76,0.4) 10%,rgba(201,168,76,0.4) 90%,transparent);"></div>
            {timeline.map(item => (
              <div class="reveal" style="display:grid; grid-template-columns: 150px 24px 1fr; margin-bottom:2rem; position:relative; align-items:start;">
                <div style="font-family:'Cormorant Garamond',serif; font-size:clamp(1rem,2.2vw,1.2rem); font-weight:700; color:#7A6429; text-align:right; padding-top:0.1rem; padding-right:20px; letter-spacing:0.03em; line-height:1.3; white-space:nowrap;">
                  {item.year}
                </div>
                <div style="display:flex; justify-content:center; padding-top:6px;">
                  <div style="width:16px; height:16px; border-radius:50%; background:#F5EDD8; border:2px solid #C9A84C; z-index:1; flex-shrink:0;"></div>
                </div>
                <div style="padding-top:0.1rem; padding-left:24px;">
                  <p class="body-text" style="margin:0; font-size:1rem;">{item.event}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Ateny Roztocza -->
        <div style="margin-bottom:6rem;">
          <div style="text-align:center; margin-bottom:3rem;">
            <p class="reveal section-label" style="margin-bottom:1rem;">Dzieło życia</p>
            <h2 class="reveal section-title" style="color:#1A1209;">Ateny Roztocza</h2>
            <div class="ornament reveal" style="max-width:280px; margin:1.5rem auto; color:#C9A84C;">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="#C9A84C"><path d="M6 0l1.5 3.5L11 5 8.5 7.5l.5 3.5L6 9l-3 2 .5-3.5L1 5l3.5-1.5L6 0z" /></svg>
            </div>
          </div>
          <div style="max-width:800px; margin:0 auto;">
            <div class="reveal body-text" style="margin-bottom:1.5rem;">
              Owocem całej drogi duchowej, kapłańskiej i filozoficznej ks. prof. Guza jest centrum „Ateny Roztocza — Deo, Reginae Poloniae et Patriae", wznoszone od marca 2020 roku na ojcowiźnie w Szozdach. Jest to projekt bez precedensu w historii Kościoła w Polsce — synteza Jerozolimy, Aten i Rzymu, wcielona w kamień, drewno i brąz:
            </div>
            <div class="reveal elegant-quote" style="margin-bottom:2rem;">
              „Ateny Roztocza są projektem-syntezą Jerozolimy jako symbolu Bożego Objawienia Starego i Nowego Testamentu, antyku ze starożytnej Grecji jako kolebki filozofii i nauki w ogóle, starożytnego Rzymu z prawem rzymskim zdumiewająco wiernym prawu naturalnemu i zarazem stolicy św. Kościoła katolickiego naszego Pana Jezusa Chrystusa."
            </div>
            <div class="reveal body-text" style="margin-bottom:1.5rem;">
              Centrum obejmuje Dom Filozofii Starożytnej poświęcony Bogu Ojcu, Dom Filozofii Średniowiecznej poświęcony Synowi Bożemu, Kaplicę Królowej Polski, Ogród Różańcowy oraz planowaną monumentalną figurę Jezusa Króla Wszechświata. Każdy element tego dzieła jest przemyślany do najdrobniejszego szczegółu — od czarnych belek dębowych liczących ponad 1700 lat, przez krzyże partyzanckie, aż po granitowe płyty ze zdemontowanego mostu „Przyjaźni" między Słubicami a Frankfurtem nad Odrą.
            </div>
            <div class="reveal body-text" style="margin-bottom:1.5rem;">
              Figura Chrystusa Króla, witająca wchodzących do centrum, wyraża serce całego dzieła. Ks. Guz tłumaczy jej symbolikę:
            </div>
            <div class="reveal elegant-quote" style="margin-bottom:2rem;">
              „Wchodzących do Aten wita Wcielony Logos Odwiecznego Boga Ojca – Odwieczny Syn Boga Ojca i zarazem nasz Pan Jezus Chrystus, jedynie prawdziwy Mesjasz. On jest tym kluczem dla rozumienia całego wszechświata, całego stworzenia, bo w Nim, i z Nim, i dla Niego Bóg Ojciec wraz z Duchem Świętym stworzyli cały wszechświat. I dlatego tutaj umieściliśmy Chrystusa, żeby witał wszystkich przychodzących do tego miejsca."
            </div>
            <div class="reveal body-text">
              Jednym z najważniejszych owoców posługi ks. prof. Guza są również audycje z cyklu „Rozmowy Niedokończone" emitowane w Radio Maryja i TV Trwam — tysiące godzin rozmów o filozofii, teologii, historii idei, prawie naturalnym, rodzinie, państwie i kulturze. Ich tytuł jest programowy — rozmowy te są niedokończone, bo prawda, którą głoszą, nigdy nie wyczerpuje się w jednym spotkaniu.
            </div>
          </div>
        </div>

